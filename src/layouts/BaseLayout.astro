                    <svg class="nav-chevron h-3 w-3 opacity-50 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                    </svg>
                  </a>
                  <div class="nav-dropdown absolute left-0 top-full hidden pt-2">
                    <div class="min-w-[270px] rounded-lg border border-(--color-border-strong) bg-(--color-bg-secondary) p-2 shadow-[0_18px_38px_rgba(0,0,0,0.18)]">
                      {item.children.map((child) => (
                        <a href={child.href} class="group flex items-start gap-3 rounded-md px-3 py-2.5 transition-colors hover:bg-(--color-bg-primary)">
                          <div class="mt-1 h-1.5 w-1.5 shrink-0 rounded-sm bg-(--color-accent) opacity-70 group-hover:opacity-100"></div>
