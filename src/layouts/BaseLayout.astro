          <div class="airh-site-ticker-window">
            <div class="airh-site-ticker-stream">
              {[...globalTickerItems, ...globalTickerItems].map((item) => (
                <a href={item.href} class="airh-site-ticker-item">
                  <span>{item.time}</span>
                  <b>{item.category}</b>
                  {item.title}
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    )}

    {!compactChrome && (
    <header class="sticky top-0 z-50 border-b border-(--color-border-strong) bg-(--color-bg-primary)/92 backdrop-blur-md">
      <nav class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8" aria-label="Primary">
        <a href={base} class="flex shrink-0 items-center gap-3">
          <img src={`${base}favicon.svg`} alt="" class="h-8 w-8 rounded-[0.95rem] border border-(--color-border-strong) bg-(--color-bg-tertiary) p-0.5 shadow-[0_10px_24px_rgba(0,0,0,0.16)]" width="32" height="32" />
          <div class="hidden sm:block">
            <p class="text-base font-display font-semibold text-(--color-text-primary) leading-tight">The AI Resource Hub</p>
            <p class="mt-1 text-[11px] text-(--color-text-muted)">Models, benchmarks, pricing, and live AI updates</p>
          </div>
          <span class="sm:hidden text-sm font-display font-semibold text-(--color-text-primary)">AI Resource Hub</span>
        </a>

        <div class="hidden lg:flex items-center gap-1">
          {primaryNav.map((item) => (
            item.children ? (
              <div class="nav-dropdown-group relative">
                <a
                  href={item.href}
                  class="nav-dropdown-trigger flex items-center gap-1 rounded-full px-3 py-2 text-sm font-medium text-(--color-text-secondary) transition-colors hover:bg-(--color-bg-secondary) hover:text-(--color-text-primary)"
                >
                  {item.label}
                  <svg class="nav-chevron h-3.5 w-3.5 opacity-50 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </a>
                <div class="nav-dropdown absolute left-0 top-full hidden pt-2">
                  <div class="min-w-[290px] rounded-[1.5rem] border border-(--color-border-strong) bg-(--color-bg-secondary) p-2 shadow-[0_18px_40px_rgba(47,27,12,0.12)]">
                    {item.children.map((child) => (
                      <a
                        href={child.href}
                        class="group flex items-start gap-3 rounded-[1.1rem] px-3 py-3 transition-colors hover:bg-(--color-bg-primary)"
                      >
                        <div class="mt-0.5 h-1.5 w-1.5 rounded-full bg-(--color-accent) opacity-70 shrink-0 group-hover:opacity-100 transition-opacity"></div>
                        <div>
                          <p class="text-sm font-medium text-(--color-text-primary)">{child.label}</p>
                          {child.note && <p class="mt-0.5 text-xs leading-5 text-(--color-text-muted)">{child.note}</p>}
                        </div>
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            ) : (
              <a
                href={item.href}
                class="rounded-full px-3 py-2 text-sm font-medium text-(--color-text-secondary) transition-colors hover:bg-(--color-bg-secondary) hover:text-(--color-text-primary)"
              >
                {item.label}
              </a>
            )
          ))}
        </div>

        <div class="flex items-center gap-2">
          <details class="locale-switcher hidden lg:block">
            <summary class="locale-switcher-trigger">
              <span>{localeMeta.nativeLabel}</span>
              <svg class="h-3.5 w-3.5 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="locale-switcher-panel">
              <p class="locale-switcher-heading">Language</p>
              <ul class="locale-switcher-list">
                {localeSwitcherLinks.map((link) => (
                  <li>
                    <a href={link.href} class:list={['locale-switcher-link', { 'is-current': link.current }]}>
                      <span>{link.nativeLabel}</span>
                      <span class="locale-switcher-muted">{link.label}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </details>

          <GlobalSearch items={searchIndex} baseUrl={base} />

          <button
            id="theme-toggle"
            class="rounded-full border border-(--color-border-strong) p-2 text-(--color-text-secondary) transition-colors hover:border-(--color-accent) hover:text-(--color-text-primary)"
            aria-label="Toggle theme"
          >
            <svg id="theme-icon-moon" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
            <svg id="theme-icon-sun" class="hidden h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
          </button>

          <button
            id="mobile-menu-btn"
            class="lg:hidden rounded-full border border-(--color-border-strong) p-2 text-(--color-text-secondary) transition-colors hover:border-(--color-accent) hover:text-(--color-text-primary)"
            aria-label="Toggle navigation menu"
            aria-expanded="false"
          >
            <svg id="mobile-menu-icon-bars" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7h16M4 12h16M4 17h16" />
            </svg>
            <svg id="mobile-menu-icon-x" class="hidden h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </nav>

      <div id="mobile-menu" class="hidden border-t border-(--color-border) bg-(--color-bg-secondary) lg:hidden">
        <div class="mx-auto max-w-7xl px-4 py-4 sm:px-6">
          <div class="space-y-2">
            <details class="rounded-[1.4rem] border border-(--color-border-strong) bg-(--color-bg-primary)">
              <summary class="cursor-pointer list-none px-4 py-3 text-sm font-semibold text-(--color-text-primary) flex items-center justify-between">
                Language
                <svg class="h-3.5 w-3.5 text-(--color-text-muted)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="px-2 pb-2">
                {localeSwitcherLinks.map((link) => (
                  <a
                    href={link.href}
                    class:list={['locale-switcher-link mobile', { 'is-current': link.current }]}
                  >
                    <span>{link.nativeLabel}</span>
                    <span class="locale-switcher-muted">{link.label}</span>
                  </a>
                ))}
              </div>
            </details>
            {mobileSections.map((section) => (
              <details class="rounded-[1.4rem] border border-(--color-border-strong) bg-(--color-bg-primary)">
                <summary class="cursor-pointer list-none px-4 py-3 text-sm font-semibold text-(--color-text-primary) flex items-center justify-between">
                  {section.title}
                  <svg class="h-3.5 w-3.5 text-(--color-text-muted)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </summary>
                <div class="grid grid-cols-2 gap-1 px-2 pb-2">
                  {section.links.map((link) => (
                    <a
                      href={link.href}
                      class="rounded-xl px-3 py-2 text-sm text-(--color-text-secondary) transition-colors hover:bg-(--color-bg-secondary) hover:text-(--color-text-primary)"
                    >
                      {link.label}
                    </a>
                  ))}
                </div>
              </details>
            ))}
          </div>
          <div class="mt-3 grid grid-cols-2 gap-1">
            <a href={`${base}about/`} class="rounded-xl px-4 py-3 text-sm font-medium text-(--color-text-secondary) transition-colors hover:bg-(--color-bg-primary) hover:text-(--color-text-primary)">About</a>
            <a href={`${base}rss.xml`} class="rounded-xl px-4 py-3 text-sm font-medium text-(--color-text-secondary) transition-colors hover:bg-(--color-bg-primary) hover:text-(--color-text-primary)">RSS Feed</a>
          </div>
        </div>
      </div>
    </header>
    )}

    {(locale !== DEFAULT_LOCALE || translationState !== 'source' || translationNote) && (
      <div class="translation-banner-shell">
        <div class="translation-banner mx-auto max-w-7xl px-4 py-3 sm:px-6 lg:px-8">
          <div>
            <p class="translation-banner-title">{translationMeta.label}</p>
            <p class="translation-banner-copy">
              {translationNote ?? translationMeta.detail}
            </p>
          </div>
        </div>
      </div>
    )}

    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <footer class="relative mt-auto border-t border-(--color-border-strong) bg-(--color-bg-secondary)">
      <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-(--color-accent)/40 to-transparent"></div>
      <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
        <div class="grid gap-10 lg:grid-cols-[1.35fr_1fr_1fr_1fr_1fr]">
          <div class="max-w-sm">
            <div class="mb-4 flex items-center gap-2.5">
              <img src={`${base}favicon.svg`} alt="" class="h-8 w-8 rounded-[0.95rem] border border-(--color-border-strong) bg-(--color-bg-tertiary) p-0.5 shadow-[0_10px_24px_rgba(0,0,0,0.16)]" width="32" height="32" />
              <p class="text-base font-display font-semibold text-(--color-text-primary)">The AI Resource Hub</p>
            </div>
            <p class="text-sm leading-6 text-(--color-text-secondary)">
              Pricing, benchmarks, provider context, learning resources, and daily news in one place.
              Built more like a reference desk than a landing page.
            </p>
            <p class="mt-4 text-xs leading-5 text-(--color-text-muted)">
              Independent and unaffiliated. Data is provided for research and comparison purposes only. Updated throughout the day.
            </p>
          </div>

          {footerSections.map((section) => (
            <div>
              <h3 class="mb-4 text-xs font-semibold uppercase tracking-[0.2em] text-(--color-text-muted)">{section.title}</h3>
              <div class="space-y-2.5">
                {section.links.map((link) => (
                  <a
                    href={link.href}
                    target={link.external ? '_blank' : undefined}
                    rel={link.external ? 'noopener noreferrer' : undefined}
                    class="block text-sm text-(--color-text-secondary) transition-colors hover:text-(--color-text-primary)"
                  >
                    {link.label}
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>

        <section
          class="mt-10 grid gap-4 border-y border-(--color-border) py-5 md:grid-cols-[minmax(160px,0.8fr)_minmax(240px,1.5fr)_auto] md:items-center"
          aria-label="Elusion Works umbrella"
        >
          <div>
            <p class="text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-(--color-accent)">Umbrella home</p>
            <a
              href="https://elusionworks.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="mt-1 block font-display text-xl font-semibold text-(--color-text-primary) transition-colors hover:text-(--color-accent)"
            >
              Elusion Works
            </a>
          </div>
          <p class="max-w-2xl text-sm leading-6 text-(--color-text-secondary)">
            The showcase for Kol's websites, tools, games, and web experiments.
          </p>
          <a
            href="https://elusionworks.com/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-xs font-semibold uppercase tracking-[0.18em] text-(--color-accent) transition-colors hover:text-(--color-text-primary)"
          >
            Visit Elusion Works -&gt;
          </a>
        </section>

        <div class="mt-10 flex flex-col gap-2 border-t border-(--color-border) pt-6 text-xs uppercase tracking-[0.18em] text-(--color-text-muted) sm:flex-row sm:items-center sm:justify-between">
          <span>Copyright {new Date().getFullYear()} The AI Resource Hub / Kol Tregaskes</span>
          <p>Independent reference for research, comparison, corrections, and source review.</p>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      const barsIcon = document.getElementById('mobile-menu-icon-bars');
      const xIcon = document.getElementById('mobile-menu-icon-x');

      btn?.addEventListener('click', () => {
        const isHidden = menu?.classList.toggle('hidden');
        btn.setAttribute('aria-expanded', String(!isHidden));
        barsIcon?.classList.toggle('hidden', !isHidden);
        xIcon?.classList.toggle('hidden', isHidden ?? true);
      });

      const themeToggle = document.getElementById('theme-toggle');
      const moonIcon = document.getElementById('theme-icon-moon');
      const sunIcon = document.getElementById('theme-icon-sun');
      const themeColorMeta = document.querySelector('meta[name="theme-color"]');
      const validThemes = new Set(['dark', 'light', 'cream', 'paper', 'slate', 'contrast']);

      function isLightTheme(theme: string) {
        return theme === 'light' || theme === 'cream' || theme === 'paper';
      }

      function setTheme(theme: string) {
        const nextTheme = validThemes.has(theme) ? theme : 'dark';
        document.documentElement.setAttribute('data-theme', nextTheme);
        localStorage.setItem('theme', nextTheme);
        updateThemeIcons();
      }

      function updateThemeIcons() {
        const theme = document.documentElement.getAttribute('data-theme') || 'dark';
        const isDark = !isLightTheme(theme);
        moonIcon?.classList.toggle('hidden', isDark);
        sunIcon?.classList.toggle('hidden', !isDark);
        themeColorMeta?.setAttribute('content', isLightTheme(theme) ? '#f6f0e3' : '#12100f');

        document.querySelectorAll<HTMLElement>('[data-theme-choice]').forEach((button) => {
          button.classList.toggle('is-active', button.getAttribute('data-theme-choice') === theme);
        });
      }
      updateThemeIcons();

      themeToggle?.addEventListener('click', () => {
        const currentTheme = document.documentElement.getAttribute('data-theme') || 'dark';
        setTheme(isLightTheme(currentTheme) ? 'dark' : 'light');
      });

      document.querySelectorAll<HTMLElement>('[data-theme-choice]').forEach((button) => {
        button.addEventListener('click', () => {
          setTheme(button.getAttribute('data-theme-choice') || 'dark');
        });
      });

      const layoutKey = 'airh:home-layout';
      const validLayouts = new Set(['spreadsheet', 'dossier', 'monitor', 'terminal']);
      const layoutButtons = document.querySelectorAll<HTMLElement>('[data-airh-layout-switch]');
      const hasHomeLayoutRuntime = Boolean(document.querySelector('[data-airh-home]'));
      const homeHref = document.querySelector<HTMLAnchorElement>('.airh-compact-brand')?.href || '/';

      function syncLayoutButtons(layout: string) {
        const nextLayout = validLayouts.has(layout) ? layout : 'spreadsheet';
        layoutButtons.forEach((button) => {
          button.classList.toggle('is-active', button.getAttribute('data-airh-layout-switch') === nextLayout);
        });
      }

      try {
        syncLayoutButtons(localStorage.getItem(layoutKey) || 'spreadsheet');
      } catch (_) {
        syncLayoutButtons('spreadsheet');
      }

      if (!hasHomeLayoutRuntime) {
        layoutButtons.forEach((button) => {
          button.addEventListener('click', () => {
            const layout = button.getAttribute('data-airh-layout-switch') || 'spreadsheet';
            if (!validLayouts.has(layout)) return;
            localStorage.setItem(layoutKey, layout);
            syncLayoutButtons(layout);
            window.location.href = `${homeHref}?layout=${encodeURIComponent(layout)}`;
          });
        });
      }

      const groups = document.querySelectorAll('.nav-dropdown-group');
      groups.forEach((group) => {
        const dropdown = group.querySelector<HTMLElement>('.nav-dropdown');
        const chevron = group.querySelector<HTMLElement>('.nav-chevron');
        let hideTimer: ReturnType<typeof setTimeout> | null = null;

        const show = () => {
          if (hideTimer) clearTimeout(hideTimer);
          dropdown?.classList.remove('hidden');
          if (chevron) chevron.style.transform = 'rotate(180deg)';
        };
        const hide = () => {
          hideTimer = setTimeout(() => {
            dropdown?.classList.add('hidden');
            if (chevron) chevron.style.transform = '';
          }, 80);
        };

        group.addEventListener('mouseenter', show);
        group.addEventListener('mouseleave', hide);
        dropdown?.addEventListener('mouseenter', show);
        dropdown?.addEventListener('mouseleave', hide);
      });
    </script>
    <script src={`${base}cross-site-nav.js`} defer></script>
  </body>
</html>
