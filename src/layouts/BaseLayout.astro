---
import '../styles/global.css';
import GlobalSearch from '../components/GlobalSearch';
import { getSearchIndex } from '../data/search-index';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Independent AI model comparison for pricing, benchmarks, tools, and live news across the AI landscape.',
  ogImage,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const searchIndex = getSearchIndex(base);
const ogImageUrl = ogImage
  ? new URL(ogImage, Astro.site).href
  : new URL(`${base}og-default.svg`, Astro.site).href;

const primaryNav = [
  {
    label: 'Compare',
    href: `${base}compare/llm/`,
    children: [
      { href: `${base}compare/llm/`, label: 'LLM Comparison', note: 'Pricing, speed, context, quality' },
      { href: `${base}compare/head-to-head/`, label: 'Head-to-Head', note: 'Compare two models directly' },
      { href: `${base}leaderboard/`, label: 'Leaderboard', note: 'Top models ranked by quality' },
      { href: `${base}best-value/`, label: 'Best Value', note: 'Cost-performance ratio' },
      { href: `${base}benchmarks/`, label: 'Benchmarks', note: 'MMLU, SWE-bench, HumanEval, and more' },
      { href: `${base}pricing-trends/`, label: 'Pricing Trends', note: 'How costs are moving over time' },
    ],
  },
  {
    label: 'Models',
    href: `${base}compare/llm/`,
    children: [
      { href: `${base}fastest/`, label: 'Fastest Models', note: 'Ranked by tokens per second' },
      { href: `${base}cheapest/`, label: 'Cheapest Models', note: 'Lowest cost per million tokens' },
      { href: `${base}new/`, label: 'Recently Added', note: 'Latest entries in the database' },
      { href: `${base}context-window/`, label: 'Context Window', note: 'Max context by model' },
      { href: `${base}open-source/`, label: 'Open Source', note: 'Open-weight and open-source models' },
      { href: `${base}reasoning/`, label: 'Reasoning Models', note: 'o1, DeepSeek-R1, and chain-of-thought' },
      { href: `${base}multimodal/`, label: 'Multimodal', note: 'Image, audio, and video inputs' },
    ],
  },
  {
    label: 'Labs',
    href: `${base}labs/`,
    children: [
      { href: `${base}labs/`, label: 'Labs and Providers', note: 'Who is building what' },
      { href: `${base}people/`, label: 'People in AI', note: 'Key figures and researchers' },
      { href: `${base}timeline/`, label: 'AI Timeline', note: 'History of releases and milestones' },
      { href: `${base}rumours/`, label: 'Rumours and Leaks', note: 'Unconfirmed signals and upcoming models' },
      { href: `${base}status/`, label: 'Provider Status', note: 'Live API health and incidents' },
    ],
  },
  {
    label: 'News',
    href: `${base}news/`,
    children: [
      { href: `${base}news/`, label: 'AI News', note: 'Curated daily signal from 74 sources' },
      { href: `${base}twitter/`, label: 'X and Twitter', note: '286 curated accounts across 17 lists' },
      { href: `${base}youtube/`, label: 'YouTube', note: 'Key AI channels and creators' },
      { href: `${base}stats/`, label: 'Stats and Numbers', note: 'Data points and market figures' },
    ],
  },
  {
    label: 'Tools',
    href: `${base}tools/`,
    children: [
      { href: `${base}calculator/`, label: 'Pricing Calculator', note: 'Estimate API spend before you commit' },
      { href: `${base}token-counter/`, label: 'Token Counter', note: 'Count tokens for any model' },
      { href: `${base}tools/`, label: 'Tool Guide', note: 'Curated external AI tools' },
      { href: `${base}quiz/`, label: 'Which AI?', note: 'Find the right model for your task' },
    ],
  },
  {
    label: 'Guides',
    href: `${base}guides/`,
    children: [
      { href: `${base}guides/`, label: 'Guides Overview', note: 'Start here for learning paths' },
      { href: `${base}academy/`, label: 'AI Academy', note: 'Structured learning for all levels' },
      { href: `${base}glossary/`, label: 'Glossary', note: 'Plain-English AI terminology' },
      { href: `${base}prompts/`, label: 'Prompt Library', note: 'Tested prompts across use cases' },
      { href: `${base}use-cases/`, label: 'Use Cases', note: 'AI applied to real problems' },
      { href: `${base}methodology/`, label: 'Methodology', note: 'How data is sourced and scored' },
    ],
  },
  { label: 'About', href: `${base}about/` },
];

const mobileSections = [
  {
    title: 'Compare',
    links: [
      { href: `${base}compare/llm/`, label: 'LLM Comparison' },
      { href: `${base}compare/head-to-head/`, label: 'Head-to-Head' },
      { href: `${base}leaderboard/`, label: 'Leaderboard' },
      { href: `${base}best-value/`, label: 'Best Value' },
      { href: `${base}benchmarks/`, label: 'Benchmarks' },
      { href: `${base}pricing-trends/`, label: 'Pricing Trends' },
    ],
  },
  {
    title: 'Models',
    links: [
      { href: `${base}fastest/`, label: 'Fastest Models' },
      { href: `${base}cheapest/`, label: 'Cheapest Models' },
      { href: `${base}new/`, label: 'Recently Added' },
      { href: `${base}context-window/`, label: 'Context Window' },
      { href: `${base}open-source/`, label: 'Open Source' },
      { href: `${base}reasoning/`, label: 'Reasoning Models' },
    ],
  },
  {
    title: 'Labs and News',
    links: [
      { href: `${base}labs/`, label: 'Labs and Providers' },
      { href: `${base}people/`, label: 'People in AI' },
      { href: `${base}timeline/`, label: 'AI Timeline' },
      { href: `${base}news/`, label: 'AI News' },
      { href: `${base}rumours/`, label: 'Rumours and Leaks' },
      { href: `${base}status/`, label: 'Provider Status' },
    ],
  },
  {
    title: 'Tools and Guides',
    links: [
      { href: `${base}calculator/`, label: 'Pricing Calculator' },
      { href: `${base}token-counter/`, label: 'Token Counter' },
      { href: `${base}guides/`, label: 'Guides' },
      { href: `${base}academy/`, label: 'AI Academy' },
      { href: `${base}glossary/`, label: 'Glossary' },
      { href: `${base}quiz/`, label: 'Which AI?' },
    ],
  },
];

const footerSections = [
  {
    title: 'Compare',
    links: [
      { href: `${base}compare/llm/`, label: 'LLM comparison' },
      { href: `${base}benchmarks/`, label: 'Benchmark library' },
      { href: `${base}leaderboard/`, label: 'Leaderboard' },
      { href: `${base}best-value/`, label: 'Best value' },
      { href: `${base}pricing-trends/`, label: 'Pricing trends' },
    ],
  },
  {
    title: 'Tools',
    links: [
      { href: `${base}calculator/`, label: 'Pricing calculator' },
      { href: `${base}token-counter/`, label: 'Token counter' },
      { href: `${base}compare/head-to-head/`, label: 'Head-to-head' },
      { href: `${base}quiz/`, label: 'Which AI for me?' },
      { href: `${base}tools/`, label: 'External tool guide' },
    ],
  },
  {
    title: 'Learn',
    links: [
      { href: `${base}guides/`, label: 'Guides' },
      { href: `${base}academy/`, label: 'AI Academy' },
      { href: `${base}glossary/`, label: 'Glossary' },
      { href: `${base}prompts/`, label: 'Prompt library' },
      { href: `${base}methodology/`, label: 'Methodology' },
    ],
  },
  {
    title: 'Site',
    links: [
      { href: `${base}about/`, label: 'About' },
      { href: `${base}news/`, label: 'AI news' },
      { href: `${base}rumours/`, label: 'Rumours and leaks' },
      { href: `${base}references/`, label: 'References' },
      { href: `${base}rss.xml`, label: 'RSS feed' },
    ],
  },
];
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,700&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="alternate" type="application/rss+xml" title="The AI Resource Hub RSS" href={`${base}rss.xml`} />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="The AI Resource Hub" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <title>{title}</title>

    <script is:inline>
      (function () {
        const saved = localStorage.getItem('theme');
        if (saved === 'dark') {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
  </head>
  <body class="min-h-screen bg-(--color-bg-primary) text-(--color-text-primary) flex flex-col">
    <header class="sticky top-0 z-50 border-b border-(--color-border-strong) bg-(--color-bg-primary)/92 backdrop-blur-md">
      <div class="border-b border-(--color-border) bg-(--color-bg-secondary)/72">
        <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-2 text-[11px] uppercase tracking-[0.22em] text-(--color-text-muted) sm:px-6 lg:px-8">
          <span>Independent AI reference desk</span>
          <span class="hidden sm:inline">Pricing / Benchmarks / News / Sources</span>
        </div>
      </div>

      <nav class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
        <a href={base} class="flex shrink-0 items-center gap-3">
          <img src={`${base}favicon.svg`} alt="" class="h-8 w-8 rounded-full border border-(--color-border-strong) bg-(--color-bg-secondary) p-1" width="32" height="32" />
          <div class="hidden sm:block">
            <p class="text-[9px] font-semibold uppercase tracking-[0.32em] text-(--color-text-muted) leading-none">Field guide</p>
            <p class="mt-1 text-base font-display font-semibold text-(--color-text-primary) leading-tight">The AI Resource Hub</p>
          </div>
          <span class="sm:hidden text-sm font-display font-semibold text-(--color-text-primary)">AI Resource Hub</span>
        </a>

        <div class="hidden lg:flex items-center gap-1">
          {primaryNav.map((item) => (
            item.children ? (
              <div class="nav-dropdown-group relative">
                <a
                  href={item.href}
                  class="nav-dropdown-trigger flex items-center gap-1 rounded-full px-3 py-2 text-sm font-medium text-(--color-text-secondary) transition-colors hover:bg-(--color-bg-secondary) hover:text-(--color-text-primary)"
                >
                  {item.label}
                  <svg class="nav-chevron h-3.5 w-3.5 opacity-50 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </a>
                <div class="nav-dropdown absolute left-0 top-full hidden pt-2">
                  <div class="min-w-[290px] rounded-[1.5rem] border border-(--color-border-strong) bg-(--color-bg-secondary) p-2 shadow-[0_18px_40px_rgba(47,27,12,0.12)]">
                    {item.children.map((child) => (
                      <a
                        href={child.href}
                        class="group flex items-start gap-3 rounded-[1.1rem] px-3 py-3 transition-colors hover:bg-(--color-bg-primary)"
                      >
                        <div class="mt-0.5 h-1.5 w-1.5 rounded-full bg-(--color-accent) opacity-70 shrink-0 group-hover:opacity-100 transition-opacity"></div>
                        <div>
                          <p class="text-sm font-medium text-(--color-text-primary)">{child.label}</p>
                          {child.note && <p class="mt-0.5 text-xs leading-5 text-(--color-text-muted)">{child.note}</p>}
                        </div>
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            ) : (
              <a
                href={item.href}
                class="rounded-full px-3 py-2 text-sm font-medium text-(--color-text-secondary) transition-colors hover:bg-(--color-bg-secondary) hover:text-(--color-text-primary)"
              >
                {item.label}
              </a>
            )
          ))}
        </div>

        <div class="flex items-center gap-2">
          <GlobalSearch client:load items={searchIndex} baseUrl={base} />

          <button
            id="theme-toggle"
            class="rounded-full border border-(--color-border-strong) p-2 text-(--color-text-secondary) transition-colors hover:border-(--color-accent) hover:text-(--color-text-primary)"
            aria-label="Toggle theme"
          >
            <svg id="theme-icon-moon" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
            <svg id="theme-icon-sun" class="hidden h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
          </button>

          <button
            id="mobile-menu-btn"
            class="lg:hidden rounded-full border border-(--color-border-strong) p-2 text-(--color-text-secondary) transition-colors hover:border-(--color-accent) hover:text-(--color-text-primary)"
            aria-label="Toggle navigation menu"
            aria-expanded="false"
          >
            <svg id="mobile-menu-icon-bars" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7h16M4 12h16M4 17h16" />
            </svg>
            <svg id="mobile-menu-icon-x" class="hidden h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </nav>

      <div id="mobile-menu" class="hidden border-t border-(--color-border) bg-(--color-bg-secondary) lg:hidden">
        <div class="mx-auto max-w-7xl px-4 py-4 sm:px-6">
          <div class="space-y-2">
            {mobileSections.map((section) => (
              <details class="rounded-[1.4rem] border border-(--color-border-strong) bg-(--color-bg-primary)">
                <summary class="cursor-pointer list-none px-4 py-3 text-sm font-semibold text-(--color-text-primary) flex items-center justify-between">
                  {section.title}
                  <svg class="h-3.5 w-3.5 text-(--color-text-muted)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </summary>
                <div class="grid grid-cols-2 gap-1 px-2 pb-2">
                  {section.links.map((link) => (
                    <a
                      href={link.href}
                      class="rounded-xl px-3 py-2 text-sm text-(--color-text-secondary) transition-colors hover:bg-(--color-bg-secondary) hover:text-(--color-text-primary)"
                    >
                      {link.label}
                    </a>
                  ))}
                </div>
              </details>
            ))}
          </div>
          <div class="mt-3 grid grid-cols-2 gap-1">
            <a href={`${base}about/`} class="rounded-xl px-4 py-3 text-sm font-medium text-(--color-text-secondary) transition-colors hover:bg-(--color-bg-primary) hover:text-(--color-text-primary)">About</a>
            <a href={`${base}rss.xml`} class="rounded-xl px-4 py-3 text-sm font-medium text-(--color-text-secondary) transition-colors hover:bg-(--color-bg-primary) hover:text-(--color-text-primary)">RSS Feed</a>
          </div>
        </div>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="relative mt-auto border-t border-(--color-border-strong) bg-(--color-bg-secondary)">
      <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-(--color-accent)/40 to-transparent"></div>
      <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
        <div class="grid gap-10 lg:grid-cols-[1.4fr_1fr_1fr_1fr_1fr]">
          <div class="max-w-sm">
            <div class="mb-4 flex items-center gap-2.5">
              <img src={`${base}favicon.svg`} alt="" class="h-8 w-8 rounded-full border border-(--color-border-strong) bg-(--color-bg-primary) p-1" width="32" height="32" />
              <p class="text-base font-display font-semibold text-(--color-text-primary)">The AI Resource Hub</p>
            </div>
            <p class="text-sm leading-6 text-(--color-text-secondary)">
              Pricing, benchmarks, provider context, learning resources, and daily news in one place.
              Built more like a reference desk than a landing page.
            </p>
            <p class="mt-4 text-xs leading-5 text-(--color-text-muted)">
              Independent and unaffiliated. Data is provided for research and comparison purposes only. Updated daily.
            </p>
          </div>

          {footerSections.map((section) => (
            <div>
              <h3 class="mb-4 text-xs font-semibold uppercase tracking-[0.2em] text-(--color-text-muted)">{section.title}</h3>
              <div class="space-y-2.5">
                {section.links.map((link) => (
                  <a
                    href={link.href}
                    class="block text-sm text-(--color-text-secondary) transition-colors hover:text-(--color-text-primary)"
                  >
                    {link.label}
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>

        <div class="mt-10 flex flex-col gap-2 border-t border-(--color-border) pt-6 text-xs uppercase tracking-[0.18em] text-(--color-text-muted) sm:flex-row sm:items-center sm:justify-between">
          <span>Copyright {new Date().getFullYear()} The AI Resource Hub</span>
          <p>Independent reference for research and comparison.</p>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      const barsIcon = document.getElementById('mobile-menu-icon-bars');
      const xIcon = document.getElementById('mobile-menu-icon-x');

      btn?.addEventListener('click', () => {
        const isHidden = menu?.classList.toggle('hidden');
        btn.setAttribute('aria-expanded', String(!isHidden));
        barsIcon?.classList.toggle('hidden', !isHidden);
        xIcon?.classList.toggle('hidden', isHidden ?? true);
      });

      const themeToggle = document.getElementById('theme-toggle');
      const moonIcon = document.getElementById('theme-icon-moon');
      const sunIcon = document.getElementById('theme-icon-sun');

      function updateThemeIcons() {
        const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        moonIcon?.classList.toggle('hidden', isDark);
        sunIcon?.classList.toggle('hidden', !isDark);
      }
      updateThemeIcons();

      themeToggle?.addEventListener('click', () => {
        const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        if (isDark) {
          document.documentElement.removeAttribute('data-theme');
          localStorage.setItem('theme', 'light');
        } else {
          document.documentElement.setAttribute('data-theme', 'dark');
          localStorage.setItem('theme', 'dark');
        }
        updateThemeIcons();
      });

      const groups = document.querySelectorAll('.nav-dropdown-group');
      groups.forEach((group) => {
        const dropdown = group.querySelector('.nav-dropdown');
        const chevron = group.querySelector('.nav-chevron');
        let hideTimer;

        const show = () => {
          if (hideTimer) clearTimeout(hideTimer);
          dropdown?.classList.remove('hidden');
          if (chevron) chevron.style.transform = 'rotate(180deg)';
        };
        const hide = () => {
          hideTimer = setTimeout(() => {
            dropdown?.classList.add('hidden');
            if (chevron) chevron.style.transform = '';
          }, 80);
        };

        group.addEventListener('mouseenter', show);
        group.addEventListener('mouseleave', hide);
        dropdown?.addEventListener('mouseenter', show);
        dropdown?.addEventListener('mouseleave', hide);
      });
    </script>
  </body>
</html>
