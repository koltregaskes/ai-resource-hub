---
import '../styles/global.css';
import GlobalSearch from '../components/GlobalSearch';
import { getSearchIndex } from '../data/search-index';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Independent AI model comparison for pricing, benchmarks, tools, and live news across the AI landscape.',
  ogImage,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const searchIndex = getSearchIndex(base);
const ogImageUrl = ogImage
  ? new URL(ogImage, Astro.site).href
  : new URL(`${base}og-default.svg`, Astro.site).href;

const primaryNav = [
  { href: `${base}compare/llm/`, label: 'Compare' },
  { href: `${base}benchmarks/`, label: 'Benchmarks' },
  { href: `${base}news/`, label: 'News' },
  { href: `${base}tools/`, label: 'Tools' },
  { href: `${base}guides/`, label: 'Guides' },
  { href: `${base}about/`, label: 'About' },
];

const mobileSections = [
  {
    title: 'Explore',
    links: [
      { href: `${base}leaderboard/`, label: 'Leaderboard' },
      { href: `${base}fastest/`, label: 'Fastest Models' },
      { href: `${base}cheapest/`, label: 'Cheapest Models' },
      { href: `${base}best-value/`, label: 'Best Value' },
      { href: `${base}pricing-trends/`, label: 'Pricing Trends' },
      { href: `${base}labs/`, label: 'Labs & Providers' },
      { href: `${base}people/`, label: 'People in AI' },
    ],
  },
  {
    title: 'Learn',
    links: [
      { href: `${base}academy/`, label: 'AI Academy' },
      { href: `${base}glossary/`, label: 'AI Glossary' },
      { href: `${base}quiz/`, label: 'Which AI Should I Use?' },
      { href: `${base}token-counter/`, label: 'Token Counter' },
      { href: `${base}prompts/`, label: 'Prompt Library' },
      { href: `${base}references/`, label: 'References' },
    ],
  },
  {
    title: 'More',
    links: [
      { href: `${base}status/`, label: 'Provider Status' },
      { href: `${base}rumours/`, label: 'Rumours & Leaks' },
      { href: `${base}youtube/`, label: 'YouTube Channels' },
      { href: `${base}timeline/`, label: 'AI Timeline' },
      { href: `${base}methodology/`, label: 'Methodology' },
      { href: `${base}rss.xml`, label: 'RSS Feed' },
    ],
  },
];

const footerSections = [
  {
    title: 'Core Paths',
    links: [
      { href: `${base}compare/llm/`, label: 'Model comparison' },
      { href: `${base}benchmarks/`, label: 'Benchmark library' },
      { href: `${base}leaderboard/`, label: 'Leaderboard' },
      { href: `${base}news/`, label: 'AI news' },
    ],
  },
  {
    title: 'Built-In Tools',
    links: [
      { href: `${base}calculator/`, label: 'Pricing calculator' },
      { href: `${base}token-counter/`, label: 'Token counter' },
      { href: `${base}compare/head-to-head/`, label: 'Head-to-head compare' },
      { href: `${base}tools/`, label: 'External tool guide' },
    ],
  },
  {
    title: 'Learn',
    links: [
      { href: `${base}guides/`, label: 'Guides' },
      { href: `${base}academy/`, label: 'AI Academy' },
      { href: `${base}glossary/`, label: 'Glossary' },
      { href: `${base}methodology/`, label: 'Methodology' },
    ],
  },
  {
    title: 'Site',
    links: [
      { href: `${base}about/`, label: 'About' },
      { href: `${base}references/`, label: 'References' },
      { href: `${base}scheduling/`, label: 'Automation' },
      { href: `${base}rss.xml`, label: 'RSS feed' },
    ],
  },
];
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="alternate" type="application/rss+xml" title="The AI Resource Hub RSS" href={`${base}rss.xml`} />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="The AI Resource Hub" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <title>{title}</title>

    <script is:inline>
      (function () {
        const saved = localStorage.getItem('theme');
        if (saved === 'light') {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
  </head>
  <body class="min-h-screen bg-(--color-bg-primary) text-(--color-text-primary) flex flex-col">
    <header class="sticky top-0 z-50 border-b border-white/6 bg-(--color-bg-primary)/86 backdrop-blur-xl">
      <nav class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
        <a href={base} class="flex items-center gap-3">
          <img src={`${base}favicon.svg`} alt="" class="h-8 w-8 rounded-xl" width="32" height="32" />
          <div class="hidden sm:block">
            <p class="text-[11px] font-semibold uppercase tracking-[0.25em] text-(--color-text-muted)">Independent AI Reference</p>
            <p class="text-sm font-bold font-display text-(--color-text-primary)">The AI Resource Hub</p>
          </div>
          <span class="sm:hidden text-sm font-bold font-display text-(--color-text-primary)">AI Resource Hub</span>
        </a>

        <div class="hidden lg:flex items-center gap-1">
          {primaryNav.map((item) => (
            <a
              href={item.href}
              class="rounded-full px-3 py-2 text-sm font-medium text-(--color-text-secondary) transition-colors hover:bg-(--color-bg-tertiary) hover:text-(--color-text-primary)"
            >
              {item.label}
            </a>
          ))}
        </div>

        <div class="flex items-center gap-2">
          <GlobalSearch client:load items={searchIndex} baseUrl={base} />

          <button
            id="theme-toggle"
            class="rounded-full border border-(--color-border) p-2 text-(--color-text-secondary) transition-colors hover:border-(--color-border-hover) hover:text-(--color-text-primary)"
            aria-label="Toggle theme"
          >
            <svg id="theme-icon-moon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
            <svg id="theme-icon-sun" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
          </button>

          <button
            id="mobile-menu-btn"
            class="lg:hidden rounded-full border border-(--color-border) p-2 text-(--color-text-secondary) transition-colors hover:border-(--color-border-hover) hover:text-(--color-text-primary)"
            aria-label="Toggle navigation menu"
            aria-expanded="false"
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7h16M4 12h16M4 17h16" />
            </svg>
          </button>
        </div>
      </nav>

      <div id="mobile-menu" class="hidden border-t border-(--color-border) bg-(--color-bg-secondary) lg:hidden">
        <div class="mx-auto max-w-7xl px-4 py-4 sm:px-6">
          <div class="grid gap-2">
            {primaryNav.map((item) => (
              <a
                href={item.href}
                class="rounded-2xl px-4 py-3 text-sm font-medium text-(--color-text-secondary) transition-colors hover:bg-(--color-bg-tertiary) hover:text-(--color-text-primary)"
              >
                {item.label}
              </a>
            ))}
          </div>

          <div class="mt-4 space-y-3">
            {mobileSections.map((section) => (
              <details class="rounded-2xl border border-(--color-border) bg-(--color-bg-primary)">
                <summary class="cursor-pointer list-none px-4 py-3 text-sm font-semibold text-(--color-text-primary)">
                  {section.title}
                </summary>
                <div class="grid gap-1 px-2 pb-2">
                  {section.links.map((link) => (
                    <a
                      href={link.href}
                      class="rounded-xl px-3 py-2 text-sm text-(--color-text-secondary) transition-colors hover:bg-(--color-bg-tertiary) hover:text-(--color-text-primary)"
                    >
                      {link.label}
                    </a>
                  ))}
                </div>
              </details>
            ))}
          </div>
        </div>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="relative mt-auto border-t border-white/6 bg-(--color-bg-secondary)">
      <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/15 to-transparent"></div>
      <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
        <div class="grid gap-10 lg:grid-cols-[1.2fr_1fr_1fr_1fr_1fr]">
          <div class="max-w-sm">
            <p class="text-[11px] font-semibold uppercase tracking-[0.3em] text-(--color-text-muted)">Launch-ready reference</p>
            <h2 class="mt-3 text-2xl font-black font-display text-(--color-text-primary)">A practical map of AI tools, models, and signals.</h2>
            <p class="mt-4 text-sm leading-6 text-(--color-text-secondary)">
              Pricing, benchmarks, provider context, learning resources, and daily news in one place.
              Built to be useful first and flashy second.
            </p>
            <p class="mt-4 text-xs text-(--color-text-muted)">
              Automated refreshes run daily on the always-on local machine. GitHub is used as a manual fallback, not the primary scheduler.
            </p>
          </div>

          {footerSections.map((section) => (
            <div>
              <h3 class="text-sm font-semibold text-(--color-text-primary)">{section.title}</h3>
              <div class="mt-4 space-y-2">
                {section.links.map((link) => (
                  <a
                    href={link.href}
                    class="block text-sm text-(--color-text-muted) transition-colors hover:text-(--color-text-primary)"
                  >
                    {link.label}
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>

        <div class="mt-10 flex flex-col gap-3 border-t border-(--color-border) pt-6 text-xs text-(--color-text-muted) sm:flex-row sm:items-center sm:justify-between">
          <div class="flex items-center gap-2">
            <img src={`${base}favicon.svg`} alt="" class="h-5 w-5" width="20" height="20" />
            <span>The AI Resource Hub</span>
          </div>
          <p>Independent and unaffiliated. Data is provided for research and comparison purposes.</p>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => {
        const isHidden = menu?.classList.toggle('hidden');
        btn.setAttribute('aria-expanded', String(!isHidden));
      });

      const themeToggle = document.getElementById('theme-toggle');
      const moonIcon = document.getElementById('theme-icon-moon');
      const sunIcon = document.getElementById('theme-icon-sun');

      function updateThemeIcons() {
        const isLight = document.documentElement.getAttribute('data-theme') === 'light';
        moonIcon?.classList.toggle('hidden', isLight);
        sunIcon?.classList.toggle('hidden', !isLight);
      }

      updateThemeIcons();

      themeToggle?.addEventListener('click', () => {
        const isLight = document.documentElement.getAttribute('data-theme') === 'light';
        if (isLight) {
          document.documentElement.removeAttribute('data-theme');
          localStorage.setItem('theme', 'dark');
        } else {
          document.documentElement.setAttribute('data-theme', 'light');
          localStorage.setItem('theme', 'light');
        }
        updateThemeIcons();
      });
    </script>
  </body>
</html>
