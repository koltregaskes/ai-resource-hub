                            <p class="text-sm font-semibold text-(--color-text-primary)">{child.label}</p>
                            {child.note && <p class="mt-0.5 text-xs leading-5 text-(--color-text-muted)">{child.note}</p>}
                          </div>
                        </a>
                      ))}
                    </div>
                  </div>
                </div>
              ) : (
                <a href={item.href} class="airh-compact-link">{item.label}</a>
              )
            ))}
          </div>

          <div class="airh-compact-actions">
            <GlobalSearch items={searchIndex} baseUrl={base} variant="compact" />

            <div class="airh-layout-switcher" role="group" aria-label="Homepage layout">
              <button type="button" class="airh-tool-icon is-active" data-airh-layout-switch="spreadsheet" data-airh-tip="Spreadsheet view. Dense data first.">
                <svg aria-hidden="true" viewBox="0 0 24 24"><rect x="4" y="4" width="16" height="16" rx="1.5"></rect><path d="M4 9h16M4 14h16M9 4v16M14 4v16"></path></svg>
                <span aria-hidden="true">▦</span>
                <span class="sr-only">Spreadsheet</span>
              </button>
              <button type="button" class="airh-tool-icon" data-airh-layout-switch="dossier" data-airh-tip="Dossier view. Index cards for today's leaders, price moves, releases, and news.">
                <svg aria-hidden="true" viewBox="0 0 24 24"><rect x="4" y="5" width="16" height="14" rx="1.5"></rect><path d="M7 9h6M7 12h10M7 15h8"></path></svg>
                <span aria-hidden="true">▤</span>
                <span class="sr-only">Dossier</span>
              </button>
              <button type="button" class="airh-tool-icon" data-airh-layout-switch="monitor" data-airh-tip="Monitor view. Keep the table open with a persistent since-you rail.">
                <svg aria-hidden="true" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="12" rx="1.5"></rect><path d="M14 5v12M7 9h4M7 13h4M16.5 9h2M16.5 13h2M9 17v2M7 19h4"></path></svg>
                <span aria-hidden="true">▥</span>
                <span class="sr-only">Monitor</span>
              </button>
              <button type="button" class="airh-tool-icon" data-airh-layout-switch="terminal" data-airh-tip="Try Terminal mode. We remember your choice.">
                <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M5 7l5 5-5 5M12 17h7"></path></svg>
                <span aria-hidden="true">›_</span>
                <span class="sr-only">Terminal</span>
              </button>
            </div>

            <details class="airh-theme-menu">
              <summary class="airh-tool-icon" data-airh-tip="Pick a palette. We remember your choice.">
                <span aria-hidden="true">◐</span>
                <span class="sr-only">Theme picker</span>
              </summary>
              <div class="airh-theme-panel">
                <button type="button" data-theme-choice="dark"><span style="background:#12100f"></span>Dark</button>
                <button type="button" data-theme-choice="light"><span style="background:#f6f0e3"></span>Cream</button>
                <button type="button" data-theme-choice="paper"><span style="background:#fffaf0"></span>Paper</button>
                <button type="button" data-theme-choice="slate"><span style="background:#1f2933"></span>Slate</button>
                <button type="button" data-theme-choice="contrast"><span style="background:#050505"></span>Contrast</button>
              </div>
            </details>

            <button type="button" class="airh-signin-placeholder" data-airh-tip="Coming soon: sign in to save filters, watchlist, and layout.">Sign in</button>
          </div>
        </nav>
      </header>
    )}

    {compactChrome && !isHomePage && globalTickerItems.length > 0 && (
