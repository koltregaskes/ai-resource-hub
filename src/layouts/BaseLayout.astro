import {
  buildAlternateTranslations,
  buildLocaleSwitcherLinks,
  DEFAULT_LOCALE,
  getLocaleMeta,
  getTranslationStateMeta,
  type SupportedLocale,
  type TranslationState,
} from '../data/localization';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  locale?: SupportedLocale;
  localeMenuLinks?: Partial<Record<SupportedLocale, string>>;
  alternateTranslations?: Partial<Record<SupportedLocale, string>>;
  translationState?: TranslationState;
  translationNote?: string;
  robots?: string;
  compactChrome?: boolean;
}

const {
  title,
  description = 'Independent AI model comparison for pricing, benchmarks, tools, and live news across the AI landscape.',
  ogImage,
  locale = DEFAULT_LOCALE,
  localeMenuLinks = {},
  alternateTranslations = {},
  translationState = locale === DEFAULT_LOCALE ? 'source' : 'reviewed',
  translationNote,
  robots,
  compactChrome = true,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const searchIndex = getSearchIndex(base);
const basePath = new URL(base, Astro.site).pathname;
const currentPath = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const isHomePage = currentPath === basePath;
const localeMeta = getLocaleMeta(locale);
const localeSwitcherLinks = buildLocaleSwitcherLinks(base, locale, localeMenuLinks);
const alternateLocaleLinks = buildAlternateTranslations(base, alternateTranslations);
const translationMeta = getTranslationStateMeta(translationState);
const ogImageUrl = ogImage
  ? new URL(ogImage, Astro.site).href
  : new URL(`${base}og-default.svg`, Astro.site).href;

