---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { newsPipelineSnapshot } from '../../data/news-pipeline.generated';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

const sites = newsPipelineSnapshot.sites;
const sources = newsPipelineSnapshot.sources;
const activeNewsSites = sites.filter((site) => site.newsEnabled);
const totalSiteIncludeTags = activeNewsSites.reduce((sum, site) => sum + site.includeTags.length, 0);

function humaniseToken(value: string): string {
  return value
    .split(/[-_]/g)
    .filter(Boolean)
    .map((part) => {
      if (part.toLowerCase() === 'ai') return 'AI';
      if (part.toLowerCase() === 'mcp') return 'MCP';
      if (part.toLowerCase() === 'sdk') return 'SDK';
      if (part.toLowerCase() === '3d') return '3D';
      if (part.toLowerCase() === 'rlhf') return 'RLHF';
      return `${part.charAt(0).toUpperCase()}${part.slice(1)}`;
    })
    .join(' ');
}

function joinValues(values: readonly string[]): string {
  return values.join('|').toLowerCase();
}

function routeModeLabel(routeMode: string): string {
  return routeMode === 'shared-default' ? 'Shared default scope' : 'Explicit site scope';
}

const filterOptions = {
  sites: activeNewsSites.map((site) => ({ value: site.slug, label: site.name })),
  categories: newsPipelineSnapshot.sourceCategories,
  routingTags: newsPipelineSnapshot.routingTags,
  sections: newsPipelineSnapshot.sections.map((section) => ({ value: section, label: section })),
  statuses: [...new Set(sources.map((source) => source.status))].map((value) => ({ value, label: humaniseToken(value) })),
  adapters: [...new Set(sources.map((source) => source.adapter))].map((value) => ({ value, label: value.toUpperCase() })),
  collectionModes: [...new Set(sources.map((source) => source.collectionMode))]
    .map((value) => ({
      value,
      label: sources.find((source) => source.collectionMode === value)?.collectionLabel ?? humaniseToken(value),
    })),
};
---

<BaseLayout
  title="News Pipeline - The AI Resource Hub"
  description="Website routing, source categories, and filter rules for the shared news pipeline across the website estate."
>
  <section class="max-w-[1440px] mx-auto px-4 py-8 sm:px-6 sm:py-12 lg:px-8">
    <nav class="mb-4 text-xs text-(--color-text-muted)" aria-label="Breadcrumb">
      <a href={base} class="transition-colors hover:text-(--color-text-secondary)">Home</a>
      <span class="mx-2">/</span>
      <a href={`${base}news/`} class="transition-colors hover:text-(--color-text-secondary)">News</a>
      <span class="mx-2">/</span>
      <span class="text-(--color-text-secondary)">Pipeline</span>
    </nav>

    <div class="relative overflow-hidden rounded-[32px] border border-(--color-border-strong) bg-(--color-bg-secondary) mb-8 shadow-[0_24px_64px_rgba(0,0,0,0.14)]">
      <div class="hero-ruling opacity-35"></div>
      <div class="editorial-burst editorial-burst-left"></div>
      <div class="editorial-burst editorial-burst-right"></div>
      <div class="relative grid gap-8 px-6 py-8 sm:px-8 lg:grid-cols-[minmax(0,1.4fr)_minmax(18rem,0.9fr)] lg:items-end lg:px-10 lg:py-10">
        <div class="max-w-3xl">
          <p class="mb-3 text-[11px] uppercase tracking-[0.3em] text-(--color-accent-muted)">Website News Control Room</p>
          <h1 class="max-w-3xl text-3xl font-black leading-[1.02] text-(--color-text-primary) sm:text-4xl lg:text-5xl">
            One place to see which stories should land on which site, and why.
          </h1>
          <p class="mt-4 max-w-2xl text-sm leading-relaxed text-(--color-text-secondary) sm:text-base">
            This board mirrors the shared website newspipe config so you can inspect estate routing without opening JSON files. It shows the current source registry, each website&apos;s intended news categories, and the source tags that feed filtering.
          </p>
        </div>

        <div class="glass-panel rounded-[28px] p-5">
          <p class="text-[11px] uppercase tracking-[0.26em] text-(--color-text-muted)">Canonical home</p>
          <p class="mt-3 text-sm leading-relaxed text-(--color-text-secondary)">
            Shared routing stays in <code>W:\Websites\shared\website-tools\pipelines\news</code>. This hub page is a synced snapshot for visibility, not a second source of truth.
          </p>
          <div class="mt-4 flex flex-wrap gap-2 text-xs">
            <a href={`${base}collection-policy/`} class="rounded-full border border-(--color-border) px-3 py-1.5 text-(--color-text-secondary) transition-colors hover:border-(--color-border-accent) hover:text-(--color-accent)">
              Collection policy
            </a>
            <a href={`${base}updates/`} class="rounded-full border border-(--color-border) px-3 py-1.5 text-(--color-text-secondary) transition-colors hover:border-(--color-border-accent) hover:text-(--color-accent)">
              Updates & freshness
            </a>
            <a href={`${base}data/source-registry.json`} class="rounded-full border border-(--color-border) px-3 py-1.5 text-(--color-text-secondary) transition-colors hover:border-(--color-border-accent) hover:text-(--color-accent)">
              Raw source registry
            </a>
          </div>
          <p class="mt-4 text-xs text-(--color-text-muted)">
            Snapshot generated {new Date(newsPipelineSnapshot.generatedAt).toLocaleString('en-GB', {
              day: '2-digit',
              month: 'short',
              year: 'numeric',
              hour: '2-digit',
              minute: '2-digit',
              hour12: false,
            })}
          </p>
        </div>
      </div>
    </div>

    <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-6 mb-10">
      <div class="glass-panel rounded-[24px] p-5">
        <p class="text-[11px] uppercase tracking-[0.24em] text-(--color-text-muted)">Estate Sites</p>
        <div class="mt-3 text-3xl font-black text-(--color-text-primary)">{newsPipelineSnapshot.summary.estateSiteCount}</div>
        <p class="mt-2 text-xs text-(--color-text-muted)">All recognised sites in the current website estate.</p>
      </div>
      <div class="glass-panel rounded-[24px] p-5">
        <p class="text-[11px] uppercase tracking-[0.24em] text-(--color-text-muted)">News Destinations</p>
        <div class="mt-3 text-3xl font-black text-(--color-text-primary)">{newsPipelineSnapshot.summary.activeNewsSiteCount}</div>
        <p class="mt-2 text-xs text-(--color-text-muted)">Sites with an active shared routing profile.</p>
      </div>
      <div class="glass-panel rounded-[24px] p-5">
        <p class="text-[11px] uppercase tracking-[0.24em] text-(--color-text-muted)">Configured Sources</p>
        <div class="mt-3 text-3xl font-black text-(--color-text-primary)">{newsPipelineSnapshot.summary.configuredSourceCount}</div>
        <p class="mt-2 text-xs text-(--color-text-muted)">Shared website sources currently declared in the registry.</p>
      </div>
      <div class="glass-panel rounded-[24px] p-5">
        <p class="text-[11px] uppercase tracking-[0.24em] text-(--color-text-muted)">Routing Tags</p>
        <div class="mt-3 text-3xl font-black text-(--color-text-primary)">{newsPipelineSnapshot.summary.routingTagCount}</div>
        <p class="mt-2 text-xs text-(--color-text-muted)">{totalSiteIncludeTags} include rules are active across the news destinations.</p>
      </div>
      <div class="glass-panel rounded-[24px] p-5">
        <p class="text-[11px] uppercase tracking-[0.24em] text-(--color-text-muted)">Automated Sources</p>
        <div class="mt-3 text-3xl font-black text-(--color-text-primary)">{newsPipelineSnapshot.summary.automatedSourceCount}</div>
        <p class="mt-2 text-xs text-(--color-text-muted)">Sources currently treated as safe public automated intake lanes.</p>
      </div>
      <div class="glass-panel rounded-[24px] p-5">
        <p class="text-[11px] uppercase tracking-[0.24em] text-(--color-text-muted)">Manual Review Lanes</p>
        <div class="mt-3 text-3xl font-black text-(--color-text-primary)">{newsPipelineSnapshot.summary.manualReviewSourceCount}</div>
        <p class="mt-2 text-xs text-(--color-text-muted)">Sources that should stay manual-review only or official-API only.</p>
      </div>
    </div>

    <div class="grid gap-4 xl:grid-cols-[minmax(0,2.1fr)_minmax(18rem,0.95fr)] mb-12">
      <div class="rounded-[28px] border border-(--color-border) bg-(--color-bg-card) p-6">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between mb-4">
          <div>
            <p class="text-[11px] uppercase tracking-[0.28em] text-(--color-text-muted)">Filtering Model</p>
            <h2 class="mt-2 text-2xl font-black text-(--color-text-primary)">Best current routing stack</h2>
          </div>
          <span class="badge">{newsPipelineSnapshot.summary.lookbackHours}h lookback</span>
        </div>
        <div class="grid gap-4 lg:grid-cols-4">
          {newsPipelineSnapshot.filteringModel.map((step) => (
            <div class="rounded-[22px] border border-(--color-border) bg-(--color-bg-tertiary) p-4">
              <div class="flex items-center gap-3 mb-3">
                <span class="flex h-9 w-9 items-center justify-center rounded-full border border-(--color-border-accent) bg-(--color-accent-glow) text-sm font-bold text-(--color-accent)">
                  {step.step}
                </span>
                <h3 class="text-sm font-semibold text-(--color-text-primary)">{step.title}</h3>
              </div>
              <p class="text-sm leading-relaxed text-(--color-text-secondary)">{step.detail}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="rounded-[28px] border border-(--color-border-accent) bg-(--color-accent-glow) p-6">
        <p class="text-[11px] uppercase tracking-[0.28em] text-(--color-accent)">Current guidance</p>
        <h2 class="mt-2 text-xl font-black text-(--color-text-primary)">Where this should live</h2>
        <p class="mt-3 text-sm leading-relaxed text-(--color-text-secondary)">
          The website estate should own the canonical news routing config. AI Resource Hub is the right place to inspect it. Agent Workspace 2 can read or mirror it, but it should not silently fork the rules.
        </p>
        <p class="mt-4 text-sm leading-relaxed text-(--color-text-secondary)">
          AI Resource Hub itself should only surface technical AI coverage. If crypto or photography slips through, that is a routing bug, not something the page layer should quietly forgive.
        </p>
      </div>
    </div>

    <div id="websites" class="mb-14">
      <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="text-[11px] uppercase tracking-[0.28em] text-(--color-text-muted)">Website Routing</p>
          <h2 class="mt-2 text-2xl font-black text-(--color-text-primary)">All estate sites and their intended categories</h2>
        </div>
        <span class="text-sm text-(--color-text-muted)">{sites.length} recognised sites</span>
      </div>

      <div class="space-y-4">
        {sites.map((site) => (
          <article class="glass-panel glass-panel-hover rounded-[26px] p-5">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
              <div class="max-w-3xl">
                <div class="flex flex-wrap items-center gap-3">
                  <h3 class="text-xl font-black text-(--color-text-primary)">{site.name}</h3>
                  <span class={`badge ${site.newsEnabled ? 'badge-best-value' : ''}`}>
                    {site.newsEnabled ? 'Shared pipeline active' : 'Estate only'}
                  </span>
                  <span class="badge">{humaniseToken(site.role)}</span>
                </div>
                <p class="mt-3 text-sm leading-relaxed text-(--color-text-secondary)">{site.description}</p>
                {site.note && (
                  <p class="mt-2 text-xs leading-relaxed text-(--color-text-muted)">{site.note}</p>
                )}
              </div>

              <div class="min-w-[15rem] rounded-[22px] border border-(--color-border) bg-(--color-bg-tertiary) px-4 py-3 text-sm">
                <div class="flex items-center justify-between gap-3">
                  <span class="text-(--color-text-muted)">Shared source scope</span>
                  <strong class="text-(--color-text-primary)">{site.sourceCoverageCount}</strong>
                </div>
                <div class="mt-2 flex items-center justify-between gap-3">
                  <span class="text-(--color-text-muted)">Explicit source rules</span>
                  <strong class="text-(--color-text-primary)">{site.explicitSourceCoverageCount}</strong>
                </div>
                {site.maxArticlesPerRun && (
                  <div class="mt-2 flex items-center justify-between gap-3">
                    <span class="text-(--color-text-muted)">Max stories per run</span>
                    <strong class="text-(--color-text-primary)">{site.maxArticlesPerRun}</strong>
                  </div>
                )}
              </div>
            </div>

            <div class="mt-5 grid gap-4 xl:grid-cols-[minmax(0,1.15fr)_minmax(0,1fr)_minmax(15rem,0.7fr)]">
              <div class="rounded-[22px] border border-(--color-border) bg-(--color-bg-tertiary) p-4">
                <p class="text-[11px] uppercase tracking-[0.22em] text-(--color-text-muted)">Included categories</p>
                {site.includeLabels.length > 0 ? (
                  <div class="mt-3 flex flex-wrap gap-2">
                    {site.includeLabels.map((tag) => (
                      <span class="rounded-full border border-(--color-border-accent) bg-(--color-accent-glow) px-3 py-1 text-xs font-medium text-(--color-text-primary)">
                        {tag.label}
                      </span>
                    ))}
                  </div>
                ) : (
                  <p class="mt-3 text-sm text-(--color-text-muted)">No shared include rules for this site.</p>
                )}
              </div>

              <div class="rounded-[22px] border border-(--color-border) bg-(--color-bg-tertiary) p-4">
                <p class="text-[11px] uppercase tracking-[0.22em] text-(--color-text-muted)">Blocked categories</p>
                {site.excludeLabels.length > 0 ? (
                  <div class="mt-3 flex flex-wrap gap-2">
                    {site.excludeLabels.map((tag) => (
                      <span class="rounded-full border border-(--color-border) bg-(--color-bg-primary) px-3 py-1 text-xs font-medium text-(--color-text-secondary)">
                        {tag.label}
                      </span>
                    ))}
                  </div>
                ) : (
                  <p class="mt-3 text-sm text-(--color-text-muted)">No explicit exclusions configured.</p>
                )}
              </div>

              <div class="rounded-[22px] border border-(--color-border) bg-(--color-bg-tertiary) p-4 text-sm">
                <p class="text-[11px] uppercase tracking-[0.22em] text-(--color-text-muted)">Delivery</p>
                <dl class="mt-3 space-y-2">
                  <div>
                    <dt class="text-(--color-text-muted)">Format</dt>
                    <dd class="font-medium text-(--color-text-primary)">{site.outputFormat ? humaniseToken(site.outputFormat) : 'No digest output'}</dd>
                  </div>
                  <div>
                    <dt class="text-(--color-text-muted)">Minimum score</dt>
                    <dd class="font-medium text-(--color-text-primary)">{site.minImportanceScore ?? 'N/A'}</dd>
                  </div>
                  <div>
                    <dt class="text-(--color-text-muted)">Output path</dt>
                    <dd class="break-all font-mono text-xs text-(--color-text-secondary)">{site.outputPath ?? 'None configured'}</dd>
                  </div>
                </dl>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>

    <div id="sources">
      <div class="mb-6 flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="text-[11px] uppercase tracking-[0.28em] text-(--color-text-muted)">Source Registry</p>
          <h2 class="mt-2 text-2xl font-black text-(--color-text-primary)">Configured sources, categories, and routing hints</h2>
        </div>
        <div class="text-sm text-(--color-text-muted)">
          Showing <span id="pipeline-source-count" class="font-semibold text-(--color-text-primary)">{sources.length}</span> of {sources.length} sources
        </div>
      </div>

      <div class="sticky top-[5rem] z-20 mb-5 rounded-[28px] border border-(--color-border) bg-(--color-bg-card)/95 p-4 backdrop-blur-lg">
        <div class="grid gap-3 md:grid-cols-2 xl:grid-cols-6">
          <label class="flex flex-col gap-2">
            <span class="text-xs uppercase tracking-[0.16em] text-(--color-text-muted)">Search</span>
            <input id="pipeline-search" type="search" placeholder="Search source, host, or tag" class="rounded-2xl border border-(--color-border) bg-(--color-bg-secondary) px-3 py-2 text-sm text-(--color-text-primary) outline-none transition-colors focus:border-(--color-border-accent)" />
          </label>

          <label class="flex flex-col gap-2">
            <span class="text-xs uppercase tracking-[0.16em] text-(--color-text-muted)">Website</span>
            <select id="pipeline-site-filter" class="rounded-2xl border border-(--color-border) bg-(--color-bg-secondary) px-3 py-2 text-sm text-(--color-text-primary) outline-none transition-colors focus:border-(--color-border-accent)">
              <option value="all">All websites</option>
              {filterOptions.sites.map((option) => (
                <option value={option.value}>{option.label}</option>
              ))}
            </select>
          </label>

          <label class="flex flex-col gap-2">
            <span class="text-xs uppercase tracking-[0.16em] text-(--color-text-muted)">Source category</span>
            <select id="pipeline-category-filter" class="rounded-2xl border border-(--color-border) bg-(--color-bg-secondary) px-3 py-2 text-sm text-(--color-text-primary) outline-none transition-colors focus:border-(--color-border-accent)">
              <option value="all">All categories</option>
              {filterOptions.categories.map((option) => (
                <option value={option.id}>{option.label}</option>
              ))}
            </select>
          </label>

          <label class="flex flex-col gap-2">
            <span class="text-xs uppercase tracking-[0.16em] text-(--color-text-muted)">Routing tag</span>
            <select id="pipeline-tag-filter" class="rounded-2xl border border-(--color-border) bg-(--color-bg-secondary) px-3 py-2 text-sm text-(--color-text-primary) outline-none transition-colors focus:border-(--color-border-accent)">
              <option value="all">All routing tags</option>
              {filterOptions.routingTags.map((option) => (
                <option value={option.id}>{option.label}</option>
              ))}
            </select>
          </label>

          <label class="flex flex-col gap-2">
            <span class="text-xs uppercase tracking-[0.16em] text-(--color-text-muted)">Section</span>
            <select id="pipeline-section-filter" class="rounded-2xl border border-(--color-border) bg-(--color-bg-secondary) px-3 py-2 text-sm text-(--color-text-primary) outline-none transition-colors focus:border-(--color-border-accent)">
              <option value="all">All sections</option>
              {filterOptions.sections.map((option) => (
                <option value={option.value}>{option.label}</option>
              ))}
            </select>
          </label>

          <div class="grid gap-3 sm:grid-cols-3">
            <label class="flex flex-col gap-2">
              <span class="text-xs uppercase tracking-[0.16em] text-(--color-text-muted)">Status</span>
              <select id="pipeline-status-filter" class="rounded-2xl border border-(--color-border) bg-(--color-bg-secondary) px-3 py-2 text-sm text-(--color-text-primary) outline-none transition-colors focus:border-(--color-border-accent)">
                <option value="all">All statuses</option>
                {filterOptions.statuses.map((option) => (
                  <option value={option.value}>{option.label}</option>
                ))}
              </select>
            </label>
            <label class="flex flex-col gap-2">
              <span class="text-xs uppercase tracking-[0.16em] text-(--color-text-muted)">Adapter</span>
              <select id="pipeline-adapter-filter" class="rounded-2xl border border-(--color-border) bg-(--color-bg-secondary) px-3 py-2 text-sm text-(--color-text-primary) outline-none transition-colors focus:border-(--color-border-accent)">
                <option value="all">All adapters</option>
                {filterOptions.adapters.map((option) => (
                  <option value={option.value}>{option.label}</option>
                ))}
              </select>
            </label>
            <label class="flex flex-col gap-2">
              <span class="text-xs uppercase tracking-[0.16em] text-(--color-text-muted)">Collection lane</span>
              <select id="pipeline-collection-filter" class="rounded-2xl border border-(--color-border) bg-(--color-bg-secondary) px-3 py-2 text-sm text-(--color-text-primary) outline-none transition-colors focus:border-(--color-border-accent)">
                <option value="all">All collection lanes</option>
                {filterOptions.collectionModes.map((option) => (
                  <option value={option.value}>{option.label}</option>
                ))}
              </select>
            </label>
          </div>
        </div>

        <div class="mt-3 flex flex-wrap items-center gap-3">
          <button id="pipeline-clear-filters" type="button" class="rounded-full border border-(--color-border) px-3 py-1.5 text-xs font-medium text-(--color-text-secondary) transition-colors hover:border-(--color-border-accent) hover:text-(--color-accent)">
            Clear filters
          </button>
          <p class="text-xs text-(--color-text-muted)">
            Source categories are editorial labels. Routing tags are the stable hints that feed site filtering before article keyword scoring.
          </p>
        </div>
      </div>

      <div class="table-scroll-container rounded-[28px] border border-(--color-border) bg-(--color-bg-card)">
        <table class="min-w-full border-collapse text-left text-sm">
          <thead>
            <tr class="border-b border-(--color-border)">
              <th class="px-4 py-3 font-semibold text-(--color-text-primary)">Source</th>
              <th class="px-4 py-3 font-semibold text-(--color-text-primary)">Section</th>
              <th class="px-4 py-3 font-semibold text-(--color-text-primary)">Categories</th>
              <th class="px-4 py-3 font-semibold text-(--color-text-primary)">Routing tags</th>
              <th class="px-4 py-3 font-semibold text-(--color-text-primary)">Routes to</th>
              <th class="px-4 py-3 font-semibold text-(--color-text-primary)">Policy lane</th>
              <th class="px-4 py-3 font-semibold text-(--color-text-primary)">Status</th>
            </tr>
          </thead>
          <tbody>
            {sources.map((source) => (
              <tr
                data-source-row
                data-search={`${source.name} ${source.host} ${source.categories.join(' ')} ${source.tags.join(' ')} ${source.routeSiteNames.join(' ')} ${source.collectionLabel} ${source.verificationLabel}`.toLowerCase()}
                data-sites={joinValues(source.routeSiteSlugs)}
                data-categories={joinValues(source.categories)}
                data-tags={joinValues(source.tags)}
                data-section={source.section.toLowerCase()}
                data-status={source.status.toLowerCase()}
                data-adapter={source.adapter.toLowerCase()}
                data-collection={source.collectionMode.toLowerCase()}
                class="border-b border-(--color-border) align-top transition-colors hover:bg-(--color-bg-tertiary)/70"
              >
                <td class="px-4 py-4">
                  <div class="min-w-[15rem]">
                    <div class="flex items-center gap-2">
                      <a href={source.url} target="_blank" rel="noopener noreferrer" class="font-semibold text-(--color-accent) transition-colors hover:text-(--color-accent-hover)">
                        {source.name}
                      </a>
                      <span class="rounded-full border border-(--color-border) px-2 py-0.5 text-[10px] uppercase tracking-[0.16em] text-(--color-text-muted)">
                        {source.adapter}
                      </span>
                      <span class="rounded-full border border-(--color-border-accent) bg-(--color-accent-glow) px-2 py-0.5 text-[10px] uppercase tracking-[0.16em] text-(--color-text-primary)">
                        {source.sourceTypeLabel}
                      </span>
                    </div>
                    <p class="mt-1 text-xs text-(--color-text-muted)">{source.host}</p>
                    {source.maxItems && (
                      <p class="mt-2 text-xs text-(--color-text-muted)">Max items: {source.maxItems}</p>
                    )}
                  </div>
                </td>
                <td class="px-4 py-4">
                  <div class="min-w-[10rem]">
                    <div class="font-medium text-(--color-text-primary)">{source.section}</div>
                    <p class="mt-1 text-xs text-(--color-text-muted)">
                      {routeModeLabel(source.routeMode)}
                    </p>
                  </div>
                </td>
                <td class="px-4 py-4">
                  <div class="flex min-w-[16rem] flex-wrap gap-2">
                    {source.categoryLabels.map((category) => (
                      <span class="rounded-full border border-(--color-border) bg-(--color-bg-primary) px-3 py-1 text-xs font-medium text-(--color-text-secondary)">
                        {category.label}
                      </span>
                    ))}
                  </div>
                </td>
                <td class="px-4 py-4">
                  <div class="flex min-w-[18rem] flex-wrap gap-2">
                    {source.tagLabels.map((tag) => (
                      <span class="rounded-full border border-(--color-border-accent) bg-(--color-accent-glow) px-3 py-1 text-xs font-medium text-(--color-text-primary)">
                        {tag.label}
                      </span>
                    ))}
                  </div>
                </td>
                <td class="px-4 py-4">
                  <div class="flex min-w-[16rem] flex-wrap gap-2">
                    {source.routeSiteNames.map((siteName) => (
                      <span class="rounded-full border border-(--color-border) px-3 py-1 text-xs font-medium text-(--color-text-secondary)">
                        {siteName}
                      </span>
                    ))}
                  </div>
                </td>
                <td class="px-4 py-4">
                  <div class="min-w-[16rem]">
                    <span class={`rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] ${
                      String(source.collectionMode) === 'manual_review'
                        ? 'bg-amber-500/15 text-amber-700 dark:text-amber-300'
                        : 'bg-sky-500/15 text-sky-700 dark:text-sky-300'
                    }`}>
                      {source.collectionLabel}
                    </span>
                    <p class="mt-2 text-xs font-medium text-(--color-text-primary)">{source.verificationLabel}</p>
                    <p class="mt-1 text-xs leading-relaxed text-(--color-text-muted)">{source.policyNote}</p>
                  </div>
                </td>
                <td class="px-4 py-4">
                  <div class="min-w-[9rem]">
                    <span class={`rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] ${
                      source.status === 'active'
                        ? 'bg-emerald-500/15 text-emerald-600 dark:text-emerald-300'
                        : 'bg-amber-500/15 text-amber-700 dark:text-amber-300'
                    }`}>
                      {humaniseToken(source.status)}
                    </span>
                    <p class="mt-2 text-xs text-(--color-text-muted)">{source.policyRiskLabel}</p>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const rows = Array.from(document.querySelectorAll('[data-source-row]'));
      const search = document.getElementById('pipeline-search');
      const siteFilter = document.getElementById('pipeline-site-filter');
      const categoryFilter = document.getElementById('pipeline-category-filter');
      const tagFilter = document.getElementById('pipeline-tag-filter');
      const sectionFilter = document.getElementById('pipeline-section-filter');
      const statusFilter = document.getElementById('pipeline-status-filter');
      const adapterFilter = document.getElementById('pipeline-adapter-filter');
      const collectionFilter = document.getElementById('pipeline-collection-filter');
      const clearButton = document.getElementById('pipeline-clear-filters');
      const countLabel = document.getElementById('pipeline-source-count');

      const matchesToken = (rawValue, expected) => {
        if (!expected || expected === 'all') return true;
        return (rawValue || '').split('|').includes(expected.toLowerCase());
      };

      const normalise = (value) => (value || '').toString().trim().toLowerCase();

      const applyFilters = () => {
        const query = normalise(search?.value);
        const selectedSite = normalise(siteFilter?.value);
        const selectedCategory = normalise(categoryFilter?.value);
        const selectedTag = normalise(tagFilter?.value);
        const selectedSection = normalise(sectionFilter?.value);
        const selectedStatus = normalise(statusFilter?.value);
        const selectedAdapter = normalise(adapterFilter?.value);
        const selectedCollection = normalise(collectionFilter?.value);

        let visible = 0;

        rows.forEach((row) => {
          const matchesSearch = !query || (row.dataset.search || '').includes(query);
          const matchesSiteFilter = matchesToken(row.dataset.sites, selectedSite);
          const matchesCategoryFilter = matchesToken(row.dataset.categories, selectedCategory);
          const matchesTagFilter = matchesToken(row.dataset.tags, selectedTag);
          const matchesSectionFilter = !selectedSection || selectedSection === 'all' || (row.dataset.section || '') === selectedSection;
          const matchesStatusFilter = !selectedStatus || selectedStatus === 'all' || (row.dataset.status || '') === selectedStatus;
          const matchesAdapterFilter = !selectedAdapter || selectedAdapter === 'all' || (row.dataset.adapter || '') === selectedAdapter;
          const matchesCollectionFilter = !selectedCollection || selectedCollection === 'all' || (row.dataset.collection || '') === selectedCollection;

          const show = matchesSearch
            && matchesSiteFilter
            && matchesCategoryFilter
            && matchesTagFilter
            && matchesSectionFilter
            && matchesStatusFilter
            && matchesAdapterFilter
            && matchesCollectionFilter;

          row.hidden = !show;
          if (show) visible += 1;
        });

        if (countLabel) countLabel.textContent = String(visible);
      };

      [search, siteFilter, categoryFilter, tagFilter, sectionFilter, statusFilter, adapterFilter, collectionFilter]
        .filter(Boolean)
        .forEach((element) => {
          element.addEventListener('input', applyFilters);
          element.addEventListener('change', applyFilters);
        });

      clearButton?.addEventListener('click', () => {
        if (search) search.value = '';
        if (siteFilter) siteFilter.value = 'all';
        if (categoryFilter) categoryFilter.value = 'all';
        if (tagFilter) tagFilter.value = 'all';
        if (sectionFilter) sectionFilter.value = 'all';
        if (statusFilter) statusFilter.value = 'all';
        if (adapterFilter) adapterFilter.value = 'all';
        if (collectionFilter) collectionFilter.value = 'all';
        applyFilters();
      });

      applyFilters();
    })();
  </script>
</BaseLayout>
