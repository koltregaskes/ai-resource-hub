---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Tooltip from '../../components/Tooltip.astro';
import NewsFilter from '../../components/NewsFilter';
import { loadNewsItems } from '../../data/news-digests';

const news = loadNewsItems();
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

const sourceCount = new Set(news.map((item) => item.source)).size;
const latestAvailable = news[0]?.date ?? null;
const archiveDays = new Set(news.map((item) => item.digestDate)).size;
---

<BaseLayout
  title="AI News - The AI Resource Hub"
  description="Daily curated AI news from technical sources covering model releases, research breakthroughs, open-source developments, and infrastructure updates."
>
  <section class="max-w-[1400px] mx-auto px-4 py-8 sm:px-6 sm:py-12 lg:px-8">
    <nav class="mb-4 text-xs text-(--color-text-muted)" aria-label="Breadcrumb">
      <a href={base} class="transition-colors hover:text-(--color-text-secondary)">Home</a>
      <span class="mx-2">/</span>
      <span class="text-(--color-text-secondary)">News</span>
    </nav>

    <div class="mb-6">
      <h1 class="mb-3 text-3xl font-extrabold text-(--color-text-primary) sm:text-4xl">
        AI News
      </h1>
      <p class="max-w-2xl text-(--color-text-secondary)">
        {news.length} articles from {sourceCount}
        <Tooltip term="sources" tip="News is collected daily from public RSS feeds, official AI company blogs, and a fallback archive of imported digests." />
        focused on model launches, research, infrastructure, and open-source developments.
      </p>
      <p class="mt-1 text-xs text-(--color-text-muted)">
        {latestAvailable ? `Latest available item: ${latestAvailable}` : 'News feed ready'} - Use the sidebar to filter by date, source, or search
      </p>
      <p class="mt-1 text-xs text-(--color-text-muted)">
        Live news now uses the cleaned database feed first, with {archiveDays} archive day{archiveDays === 1 ? '' : 's'} of digest fallback available if a source goes quiet. Newsletter signup is paused, but the news archive remains live.
      </p>
      <p class="mt-2 text-xs text-(--color-text-muted)">
        Need to inspect routing, source categories, or site filtering? Open the
        <a href={`${base}news/pipeline/`} class="ml-1 text-(--color-accent) hover:text-(--color-accent-hover) transition-colors">
          News Pipeline board
        </a>.
      </p>
    </div>

    <NewsFilter client:load news={news} baseUrl={base} />
  </section>
</BaseLayout>
