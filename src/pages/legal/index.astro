---
import BaseLayout from '../../layouts/BaseLayout.astro';
import UnsupportedSyntheticSurface from '../../components/leaderboards/UnsupportedSyntheticSurface.astro';
import { getSyntheticLeaderboardView } from '../../data/synthetic-leaderboards';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const view = getSyntheticLeaderboardView('legal', 12);
const benchmarkBlurbs = {
  legalbench: 'Legal reasoning benchmark family covering issue spotting, statutory interpretation, and professional legal analysis tasks.',
};
---

<BaseLayout title="Best AI Models for Legal Work - The AI Resource Hub" description="Tracking legal benchmark coverage honestly until canonical legal eval rows are live.">
  <UnsupportedSyntheticSurface
    base={base}
    title="Best AI Models for Legal Work"
    description="Legal model recommendations need real evidence. This page now tracks the benchmark set and the model watchlist instead of publishing a synthetic legal winner table before the registry is ready."
    view={view}
    benchmarkBlurbs={benchmarkBlurbs}
    relatedLinks={[
      { href: `${base}leaderboard/`, label: 'Leaderboard desk' },
      { href: `${base}finance/`, label: 'Finance AI' },
      { href: `${base}healthcare/`, label: 'Healthcare AI' },
    ]}
  />
</BaseLayout>
