---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SyntheticMethodologyNote from '../../components/leaderboards/SyntheticMethodologyNote.astro';
import { getOpenSourceReferenceModels, getSyntheticLeaderboardView } from '../../data/synthetic-leaderboards';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const view = getSyntheticLeaderboardView('open-source', 250);
const ranked = view.rankedEntries;
const tracking = [...view.partialEntries, ...view.trackingEntries].slice(0, 12);
const referenceModels = getOpenSourceReferenceModels().slice(0, 12);
const leader = ranked[0] ?? null;
const categoryLabels: Record<string, string> = {
  image: 'Image generation',
  video: 'Video generation',
  voice: 'Voice and TTS',
  speech: 'Speech to text',
  sound: 'Music and sound',
};
---

<BaseLayout title="Open Source AI Models - The AI Resource Hub" description="Open-weight model leaderboard with benchmark-backed ranking and explicit tracking states.">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    <nav class="text-xs text-(--color-text-muted) mb-4" aria-label="Breadcrumb">
      <a href={base} class="hover:text-(--color-text-secondary) transition-colors">Home</a>
      <span class="mx-2">/</span>
      <span class="text-(--color-text-secondary)">Open Source Models</span>
    </nav>

    <div class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-extrabold text-(--color-text-primary) mb-3">Open Source AI Models</h1>
      <p class="text-(--color-text-secondary) max-w-3xl">The ranked table below is now limited to open-weight language models with enough public benchmark evidence to compare fairly. Other open models still appear on the page, but as reference entries rather than synthetic winners.</p>
    </div>

    <SyntheticMethodologyNote body="Synthetic ranking. Requires 4+ relevant benchmark rows to rank. Open models with thinner evidence are shown separately instead of being propped up by a fallback quality score." />

    {leader && <a href={`${base}models/${leader.id}/`} class="mt-8 block p-4 rounded-xl bg-(--color-bg-card) border border-(--color-border) hover:border-(--color-accent)/30 transition-colors group"><p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-(--color-accent)">Current evaluated open leader</p><div class="mt-2 flex items-center gap-2"><span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${leader.providerColour}`}></span><h2 class="font-semibold text-(--color-text-primary) group-hover:text-(--color-accent) transition-colors">{leader.name}</h2></div><p class="mt-2 text-sm text-(--color-text-secondary)">{leader.provider} with {leader.relevantBenchmarkCount} relevant benchmark rows in the evaluated set.</p></a>}

    <div class="my-8 rounded-xl border border-(--color-border) bg-(--color-bg-card) overflow-hidden">
      <table class="w-full text-sm">
        <thead><tr class="border-b border-(--color-border)"><th class="text-center py-3 px-2 text-(--color-text-muted) font-medium w-10">#</th><th class="text-left py-3 px-4 text-(--color-text-muted) font-medium">Model</th><th class="text-right py-3 px-4 text-(--color-text-muted) font-medium">Open composite</th><th class="text-right py-3 px-4 text-(--color-text-muted) font-medium hidden sm:table-cell">Evidence</th><th class="text-right py-3 px-4 text-(--color-text-muted) font-medium">Price</th></tr></thead>
        <tbody>{ranked.map((model, index) => <tr class={`border-b border-(--color-border)/50 hover:bg-(--color-bg-hover) transition-colors ${index < 3 ? 'bg-(--color-accent)/5' : ''}`}><td class="py-3 px-2 text-center text-sm font-bold text-(--color-text-muted)">{index + 1}</td><td class="py-3 px-4"><a href={`${base}models/${model.id}/`} class="flex items-center gap-2 text-(--color-text-primary) hover:text-(--color-accent) transition-colors"><span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${model.providerColour}`}></span><span class="font-medium">{model.name}</span></a><p class="text-[10px] text-(--color-text-muted)">{model.provider}</p></td><td class="py-3 px-4 text-right font-mono font-medium text-(--color-accent)">{model.score?.toFixed(1)}</td><td class="py-3 px-4 text-right hidden sm:table-cell text-xs text-(--color-text-muted)">{model.relevantBenchmarkCount} rows</td><td class="py-3 px-4 text-right font-mono text-xs text-(--color-text-secondary)">{model.inputPrice > 0 || model.outputPrice > 0 ? `$${model.inputPrice.toFixed(2)} / $${model.outputPrice.toFixed(2)}` : 'Self-host / free'}</td></tr>)}</tbody>
      </table>
    </div>

    {tracking.length > 0 && <div class="mb-10"><h2 class="text-xl font-bold text-(--color-text-primary) mb-4">Tracking / insufficient evidence</h2><div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">{tracking.map((model) => <a href={`${base}models/${model.id}/`} class="p-4 rounded-xl bg-(--color-bg-card) border border-(--color-border) hover:border-(--color-accent)/30 transition-colors group"><div class="flex items-center gap-2 mb-2"><span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${model.providerColour}`}></span><h3 class="font-medium text-(--color-text-primary) group-hover:text-(--color-accent) transition-colors text-sm">{model.name}</h3></div><p class="text-xs text-(--color-text-muted)">{model.provider}</p><p class="mt-2 text-[10px] uppercase tracking-[0.16em] text-(--color-accent)">{model.evidenceTier}</p><p class="mt-1 text-xs text-(--color-text-muted)">{model.reasonIfNotEligible}</p></a>)}</div></div>}

    {referenceModels.length > 0 && <div class="mb-8"><h2 class="text-xl font-bold text-(--color-text-primary) mb-4">Other open-source reference models</h2><div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">{referenceModels.map((model) => <a href={`${base}models/${model.id}/`} class="p-4 rounded-xl bg-(--color-bg-card) border border-(--color-border) hover:border-(--color-accent)/30 transition-colors group"><div class="flex items-center gap-2 mb-2"><span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${model.providerColour}`}></span><h3 class="font-medium text-(--color-text-primary) group-hover:text-(--color-accent) transition-colors text-sm">{model.name}</h3></div><p class="text-xs text-(--color-text-muted)">{model.provider} / {categoryLabels[model.category] ?? model.category}</p></a>)}</div></div>}
  </section>
</BaseLayout>
