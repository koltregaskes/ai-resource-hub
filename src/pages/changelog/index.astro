---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLatestActivities, type ActivityCategory } from '../../data/hub-dashboard';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

const activities = getLatestActivities(80, base);

const categoryLabels: Record<'all' | ActivityCategory, string> = {
  all: 'All activity',
  site: 'Site updates',
  models: 'Models',
  data: 'Data refreshes',
  digest: 'Digest',
  jobs: 'Jobs',
};

const categoryOrder: Array<'all' | ActivityCategory> = ['all', 'site', 'models', 'data', 'digest', 'jobs'];

const counts = categoryOrder.map((category) => ({
  category,
  label: categoryLabels[category],
  count: category === 'all' ? activities.length : activities.filter((entry) => entry.category === category).length,
}));

function formatDateLabel(value: string): string {
  return new Date(value).toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
  });
}

function isExternalLink(href: string | null | undefined): boolean {
  return Boolean(href && /^https?:\/\//.test(href));
}
---

<BaseLayout
  title="Activity Log - The AI Resource Hub"
  description="Live activity log for The AI Resource Hub: model additions, data refreshes, digest publishes, jobs snapshots, and site updates."
>
  <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8 lg:py-12">
    <nav class="text-xs text-(--color-text-muted) mb-4" aria-label="Breadcrumb">
      <a href={base} class="hover:text-(--color-text-secondary) transition-colors">Home</a>
      <span class="mx-2">/</span>
      <span class="text-(--color-text-secondary)">Activity Log</span>
    </nav>

    <div class="activity-shell">
      <div class="activity-hero">
        <div>
          <p class="activity-kicker">Latest activities</p>
          <h1 class="activity-title">The live changelog for the site, the data, and the ranking surfaces.</h1>
          <p class="activity-intro">
            This is where model additions, digest publishes, jobs snapshots, and site-level changes land. Use the filters to
            narrow the feed instead of guessing what moved.
          </p>
        </div>

        <div class="activity-summary-grid">
          {counts.map((item) => (
            <div class="activity-summary-card">
              <p class="activity-summary-value">{item.count}</p>
              <p class="activity-summary-label">{item.label}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="activity-toolbar">
        <div class="activity-filter-group" role="group" aria-label="Filter by category">
          {categoryOrder.map((category, index) => (
            <button
              class={`activity-filter-chip ${index === 0 ? 'is-active' : ''}`}
              type="button"
              data-activity-filter={category}
            >
              {categoryLabels[category]}
            </button>
          ))}
        </div>

        <div class="activity-filter-group" role="group" aria-label="Filter by time">
          <button class="activity-filter-chip is-active" type="button" data-activity-window="all">All time</button>
          <button class="activity-filter-chip" type="button" data-activity-window="7">Last 7 days</button>
          <button class="activity-filter-chip" type="button" data-activity-window="30">Last 30 days</button>
          <button class="activity-filter-chip" type="button" data-activity-window="90">Last 90 days</button>
        </div>
      </div>

      <div class="activity-list">
        {activities.map((entry) => (
          <a
            href={entry.href ?? `${base}changelog/`}
            class="activity-row"
            data-activity-item
            data-category={entry.category}
            data-timestamp={entry.date}
            target={isExternalLink(entry.href) ? '_blank' : undefined}
            rel={isExternalLink(entry.href) ? 'noopener noreferrer' : undefined}
          >
            <div class="activity-row-topline">
              <span class={`hub-home-category is-${entry.category}`}>{entry.category}</span>
              <time class="activity-row-date">{formatDateLabel(entry.date)}</time>
            </div>
            <h2 class="activity-row-title">{entry.title}</h2>
            <p class="activity-row-copy">{entry.detail}</p>
          </a>
        ))}
      </div>

      <div class="activity-empty is-hidden" data-activity-empty>
        No activity matches the current filters.
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const itemNodes = Array.from(document.querySelectorAll('[data-activity-item]'));
      const emptyState = document.querySelector('[data-activity-empty]');
      const categoryButtons = Array.from(document.querySelectorAll('[data-activity-filter]'));
      const windowButtons = Array.from(document.querySelectorAll('[data-activity-window]'));

      let activeCategory = 'all';
      let activeWindow = 'all';

      const applyFilters = () => {
        const now = Date.now();
        let visibleCount = 0;

        itemNodes.forEach((node) => {
          const category = node.getAttribute('data-category') || 'all';
          const timestamp = Date.parse(node.getAttribute('data-timestamp') || '');

          const categoryMatch = activeCategory === 'all' || category === activeCategory;
          const windowMatch = activeWindow === 'all'
            || (Number.isFinite(timestamp) && (now - timestamp) <= Number(activeWindow) * 24 * 60 * 60 * 1000);

          const visible = categoryMatch && windowMatch;
          node.classList.toggle('is-hidden', !visible);
          if (visible) visibleCount += 1;
        });

        emptyState?.classList.toggle('is-hidden', visibleCount !== 0);
      };

      categoryButtons.forEach((button) => {
        button.addEventListener('click', () => {
          activeCategory = button.getAttribute('data-activity-filter') || 'all';
          categoryButtons.forEach((node) => node.classList.toggle('is-active', node === button));
          applyFilters();
        });
      });

      windowButtons.forEach((button) => {
        button.addEventListener('click', () => {
          activeWindow = button.getAttribute('data-activity-window') || 'all';
          windowButtons.forEach((node) => node.classList.toggle('is-active', node === button));
          applyFilters();
        });
      });

      applyFilters();
    })();
  </script>
</BaseLayout>
