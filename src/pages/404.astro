---
import BaseLayout from '../layouts/BaseLayout.astro';
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
---

<BaseLayout title="Page not found — The AI Resource Hub">
  <div class="mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8 text-center">
    <p class="text-[8rem] font-black font-display leading-none text-(--color-border-hover)">404</p>
    <h1 class="mt-4 text-2xl font-bold font-display text-(--color-text-primary)">Page not found</h1>
    <p class="mt-3 max-w-md mx-auto text-sm leading-7 text-(--color-text-secondary)">
      This page doesn't exist or has been moved. Try searching for what you need, or head back to the comparison tables.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href={base} class="inline-flex items-center justify-center rounded-full bg-(--color-text-primary) px-6 py-3 text-sm font-semibold text-(--color-bg-primary) transition-transform hover:-translate-y-0.5">
        Back to homepage
      </a>
      <a href={`${base}compare/llm/`} class="inline-flex items-center justify-center rounded-full border border-(--color-border) bg-(--color-bg-secondary)/70 px-6 py-3 text-sm font-semibold text-(--color-text-primary) transition-colors hover:border-(--color-border-hover)">
        Model comparison
      </a>
    </div>
  </div>
</BaseLayout>
