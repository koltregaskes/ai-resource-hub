---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatAiMilestoneDate, getThisDayInAiOverview } from '../../data/ai-anniversaries';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const overview = getThisDayInAiOverview();

const significanceMeta = {
  major: 'border-amber-500/30 bg-amber-500/12 text-amber-100',
  notable: 'border-slate-500/30 bg-slate-500/12 text-slate-200',
} as const;

const kindLabel = {
  launch: 'Launch',
  founded: 'Founded',
  milestone: 'Milestone',
} as const;

function anniversaryLabel(years: number): string {
  if (years <= 0) return 'New';
  return `${years}${years === 1 ? ' year' : ' years'}`;
}
---

<BaseLayout
  title="This Day in AI - Launch Anniversaries and Lab Founding Dates - The AI Resource Hub"
  description="Track big AI model launch anniversaries, lab founding dates, and upcoming milestones that matter across the AI timeline."
>
  <section class="max-w-[1440px] mx-auto px-4 py-8 sm:px-6 sm:py-12 lg:px-8">
    <nav class="mb-4 text-xs text-(--color-text-muted)" aria-label="Breadcrumb">
      <a href={base} class="transition-colors hover:text-(--color-text-secondary)">Home</a>
      <span class="mx-2">/</span>
      <a href={`${base}timeline/`} class="transition-colors hover:text-(--color-text-secondary)">AI Timeline</a>
      <span class="mx-2">/</span>
      <span class="text-(--color-text-secondary)">This Day in AI</span>
    </nav>

    <div class="activity-shell">
      <div class="activity-hero">
        <div class="max-w-4xl">
          <p class="activity-kicker">This Day in AI</p>
          <h1 class="activity-title">Launch anniversaries, lab birthdays, and the next dates worth remembering.</h1>
          <p class="activity-intro">
            This page tracks the high-signal dates people ask about all the time: when the big model families launched,
            when major labs were founded, and which anniversaries are coming up next. It is intentionally curated and
            source-first rather than auto-filled from noisy news.
          </p>
          <div class="hub-home-chip-row mt-4">
            <a href={`${base}timeline/`} class="hub-home-chip">Full timeline</a>
            <a href={`${base}new/`} class="hub-home-chip">Release desk</a>
            <a href={`${base}labs/`} class="hub-home-chip">Labs and providers</a>
            <a href={`${base}references/`} class="hub-home-chip">References</a>
          </div>
        </div>

        <div class="activity-summary-grid">
          <div class="activity-summary-card">
            <p class="activity-summary-value">{overview.trackedMilestones}</p>
            <p class="activity-summary-label">Curated milestones</p>
          </div>
          <div class="activity-summary-card">
            <p class="activity-summary-value">{overview.exactDateMilestones}</p>
            <p class="activity-summary-label">Exact launch dates</p>
          </div>
          <div class="activity-summary-card">
            <p class="activity-summary-value">{overview.todayMilestones.length}</p>
            <p class="activity-summary-label">Anniversaries today</p>
          </div>
          <div class="activity-summary-card">
            <p class="activity-summary-value">{overview.nextMilestone ? `${overview.nextMilestone.daysUntil}d` : 'n/a'}</p>
            <p class="activity-summary-label">Until the next exact milestone</p>
          </div>
        </div>
      </div>

      <div class="grid gap-4 mt-8 xl:grid-cols-[minmax(0,1.4fr)_minmax(18rem,0.9fr)]">
        <section class="rounded-[1.8rem] border border-(--color-border) bg-(--color-bg-card) p-5 shadow-[0_18px_36px_rgba(47,27,12,0.08)]">
          <div class="hub-home-card-head">
            <div>
              <p class="hub-home-mini-label">Today</p>
              <h2 class="hub-home-card-title">What happened on {overview.generatedForLabel}?</h2>
            </div>
          </div>

          {overview.todayMilestones.length > 0 ? (
            <div class="hub-home-stack mt-4">
              {overview.todayMilestones.map((milestone) => (
                <article class="hub-home-card">
                  <div class="hub-home-activity-topline">
                    <span class={`rounded-full border px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] ${significanceMeta[milestone.significance]}`}>
                      {kindLabel[milestone.kind]}
                    </span>
                    <span class="hub-home-activity-date">{anniversaryLabel(milestone.anniversaryYears)}</span>
                  </div>
                  <h3 class="hub-home-feed-title mt-3">{milestone.title}</h3>
                  <p class="hub-home-feed-copy">{milestone.summary}</p>
                  <div class="mt-4 flex flex-wrap gap-3 text-sm">
                    {milestone.href ? <a href={`${base}${milestone.href.replace(/^\//, '')}`} class="editorial-link">Open related page</a> : null}
                    <a href={milestone.sourceUrl} target="_blank" rel="noopener noreferrer" class="editorial-link">Official source</a>
                  </div>
                </article>
              ))}
            </div>
          ) : (
            <div class="rounded-[1.5rem] border border-dashed border-(--color-border-hover) px-5 py-6 mt-4">
              <p class="hub-home-feed-title">No exact anniversary lands today.</p>
              <p class="hub-home-feed-copy mt-3">
                That is normal. The next useful milestone is <strong>{overview.nextMilestone?.title ?? 'not yet set'}</strong>
                {overview.nextMilestone ? ` in ${overview.nextMilestone.daysUntil} day${overview.nextMilestone.daysUntil === 1 ? '' : 's'}` : ''}.
              </p>
            </div>
          )}
        </section>

        <aside class="rounded-[1.8rem] border border-(--color-border-accent) bg-(--color-accent-glow) p-5">
          <p class="hub-home-mini-label text-(--color-accent)">Next up</p>
          <h2 class="hub-home-side-title mt-2">The next exact anniversaries on the calendar.</h2>
          <div class="hub-home-stack mt-4">
            {overview.upcomingMilestones.slice(0, 5).map((milestone) => (
              <article class="hub-home-activity-row block">
                <div class="hub-home-activity-topline">
                  <span class={`rounded-full border px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] ${significanceMeta[milestone.significance]}`}>
                    {milestone.daysUntil}d
                  </span>
                  <span class="hub-home-activity-date">{milestone.nextOccurrenceLabel}</span>
                </div>
                <h3 class="hub-home-feed-title mt-3">{milestone.title}</h3>
                <p class="hub-home-feed-copy">{milestone.summary}</p>
              </article>
            ))}
          </div>
        </aside>
      </div>

      <div class="grid gap-4 mt-8 xl:grid-cols-2">
        <section class="rounded-[1.8rem] border border-(--color-border) bg-(--color-bg-card) p-5 shadow-[0_18px_36px_rgba(47,27,12,0.08)]">
          <div class="hub-home-card-head">
            <div>
              <p class="hub-home-mini-label">Big model birthdays</p>
              <h2 class="hub-home-card-title">The major model-family launch dates we want to keep on hand.</h2>
            </div>
          </div>

          <div class="hub-home-stack mt-4">
            {overview.launchMilestones.map((milestone) => (
              <article class="hub-home-feed-row">
                <div class="hub-home-activity-topline">
                  <span class={`rounded-full border px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] ${significanceMeta[milestone.significance]}`}>
                    {kindLabel[milestone.kind]}
                  </span>
                  <time class="hub-home-activity-date">{formatAiMilestoneDate(milestone)}</time>
                </div>
                <h3 class="hub-home-feed-title mt-3">{milestone.title}</h3>
                <p class="hub-home-feed-copy">{milestone.summary}</p>
                <div class="mt-4 flex flex-wrap gap-3 text-sm">
                  {milestone.href ? <a href={`${base}${milestone.href.replace(/^\//, '')}`} class="editorial-link">Open related page</a> : null}
                  <a href={milestone.sourceUrl} target="_blank" rel="noopener noreferrer" class="editorial-link">{milestone.sourceLabel}</a>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="rounded-[1.8rem] border border-(--color-border) bg-(--color-bg-card) p-5 shadow-[0_18px_36px_rgba(47,27,12,0.08)]">
          <div class="hub-home-card-head">
            <div>
              <p class="hub-home-mini-label">Lab birthdays</p>
              <h2 class="hub-home-card-title">Founding dates and institutional milestones for the major labs.</h2>
            </div>
          </div>

          <div class="hub-home-stack mt-4">
            {overview.labMilestones.map((milestone) => (
              <article class="hub-home-feed-row">
                <div class="hub-home-activity-topline">
                  <span class={`rounded-full border px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] ${significanceMeta[milestone.significance]}`}>
                    {kindLabel[milestone.kind]}
                  </span>
                  <time class="hub-home-activity-date">{formatAiMilestoneDate(milestone)}</time>
                </div>
                <h3 class="hub-home-feed-title mt-3">{milestone.title}</h3>
                <p class="hub-home-feed-copy">{milestone.summary}</p>
                <div class="mt-4 flex flex-wrap gap-3 text-sm">
                  {milestone.href ? <a href={`${base}${milestone.href.replace(/^\//, '')}`} class="editorial-link">Open labs page</a> : null}
                  <a href={milestone.sourceUrl} target="_blank" rel="noopener noreferrer" class="editorial-link">{milestone.sourceLabel}</a>
                </div>
              </article>
            ))}
          </div>
        </section>
      </div>

      <div class="rounded-[1.6rem] border border-(--color-border-accent) bg-(--color-accent-glow) p-5 mt-8">
        <p class="hub-home-mini-label text-(--color-accent)">How to read this</p>
        <p class="hub-home-feed-copy mt-3">
          This is a curated reference layer, not a speculative one. We only attach exact dates where we have a reasonably direct
          official source. If a founding date is only clear to the month or year, we keep it that way rather than inventing a
          fake anniversary day.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
