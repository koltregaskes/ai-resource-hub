---
import BaseLayout from '../../layouts/BaseLayout.astro';
import UnsupportedSyntheticSurface from '../../components/leaderboards/UnsupportedSyntheticSurface.astro';
import { getSyntheticLeaderboardView } from '../../data/synthetic-leaderboards';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const view = getSyntheticLeaderboardView('finance', 12);
const benchmarkBlurbs = {
  finqa: 'Financial QA benchmark for numerical reasoning across earnings reports and filings.',
  financebench: 'FinanceBench focuses on open-ended financial analysis grounded in real regulatory and investor documents.',
};
---

<BaseLayout title="Best AI Models for Finance - The AI Resource Hub" description="Tracking finance benchmark coverage honestly until canonical finance eval rows are live.">
  <UnsupportedSyntheticSurface
    base={base}
    title="Best AI Models for Finance"
    description="Finance coverage now behaves honestly: we are tracking the benchmark set and the current model watchlist, but we are not publishing a synthetic finance winner table until canonical finance benchmark rows exist in the registry."
    view={view}
    benchmarkBlurbs={benchmarkBlurbs}
    relatedLinks={[
      { href: `${base}leaderboard/`, label: 'Leaderboard desk' },
      { href: `${base}healthcare/`, label: 'Healthcare AI' },
      { href: `${base}legal/`, label: 'Legal AI' },
    ]}
  />
</BaseLayout>
