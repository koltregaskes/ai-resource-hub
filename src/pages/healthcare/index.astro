---
import BaseLayout from '../../layouts/BaseLayout.astro';
import UnsupportedSyntheticSurface from '../../components/leaderboards/UnsupportedSyntheticSurface.astro';
import { getSyntheticLeaderboardView } from '../../data/synthetic-leaderboards';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const view = getSyntheticLeaderboardView('healthcare', 12);
const benchmarkBlurbs = {
  medqa: 'Medical question answering benchmark used to compare reasoning over clinical and professional exam-style prompts.',
};
---

<BaseLayout title="Best AI Models for Healthcare - The AI Resource Hub" description="Tracking healthcare benchmark coverage honestly until canonical medical eval rows are live.">
  <UnsupportedSyntheticSurface
    base={base}
    title="Best AI Models for Healthcare"
    description="Healthcare guidance has to be especially careful. We are tracking the benchmark set and the current model watchlist, but we are not publishing a ranked healthcare leaderboard until canonical medical benchmark data is present."
    view={view}
    benchmarkBlurbs={benchmarkBlurbs}
    relatedLinks={[
      { href: `${base}leaderboard/`, label: 'Leaderboard desk' },
      { href: `${base}finance/`, label: 'Finance AI' },
      { href: `${base}legal/`, label: 'Legal AI' },
    ]}
  />
</BaseLayout>
