---
import BaseLayout from '../../layouts/BaseLayout.astro';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
---

<BaseLayout
  title="You're on the list — AI Operator Starter Pack"
  description="Thanks for joining the AI Operator Starter Pack waitlist. While you wait, read What Is a Harness?"
  robots="noindex, follow"
>
  <article class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24 text-center">
    <p class="text-sm font-bold tracking-[0.18em] uppercase text-blue-400 mb-4">YOU'RE ON THE LIST</p>
    <h1 class="text-4xl sm:text-5xl font-extrabold text-(--color-text-primary) leading-[1.05] mb-6">
      Thanks for joining.
    </h1>
    <p class="text-xl text-(--color-text-secondary) leading-relaxed mb-8">
      You'll get one email when the pack ships, with the founder price link inside.
      No spam, no drip sequence, no "5 ways to" emails — just the launch.
    </p>
    <p class="text-(--color-text-secondary) leading-relaxed mb-10">
      While you wait, the foundation lesson is free to read on AI Resource Hub right now:
    </p>
    <a
      href={`${base}academy/what-is-a-harness/`}
      class="inline-block px-6 py-3 rounded-xl bg-blue-600 hover:bg-blue-500 text-white font-bold transition-colors"
    >
      Read What Is a Harness? →
    </a>
    <p class="text-sm text-(--color-text-muted) mt-12">
      Did this not arrive? Whitelist <code class="px-1 bg-(--color-bg-card) rounded">noreply@buttondown.email</code>
      and check the promotions tab.
    </p>
  </article>
</BaseLayout>
