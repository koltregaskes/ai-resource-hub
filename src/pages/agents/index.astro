---
import BaseLayout from '../../layouts/BaseLayout.astro';
import UnsupportedSyntheticSurface from '../../components/leaderboards/UnsupportedSyntheticSurface.astro';
import { getSyntheticLeaderboardView } from '../../data/synthetic-leaderboards';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const view = getSyntheticLeaderboardView('agents', 12);
const benchmarkBlurbs = {
  gaia: 'General AI assistant benchmark for browser use, tool use, and multi-step task completion.',
  webarena: 'Browser-environment benchmark for realistic multi-site navigation and web task execution.',
  'tau-bench': 'Tool-agent-user benchmark focused on multi-step task execution with tool calls and workflow discipline.',
};
---

<BaseLayout title="Best AI Agent Models - The AI Resource Hub" description="Tracking benchmark-backed AI agent coverage honestly until canonical agent eval rows are live.">
  <UnsupportedSyntheticSurface
    base={base}
    title="Best AI Agent Models"
    description="We are tracking agent-specific benchmark coverage and current frontier models, but this page is not publishing a scored winner table until the canonical registry contains real agent benchmark data."
    view={view}
    benchmarkBlurbs={benchmarkBlurbs}
    relatedLinks={[
      { href: `${base}coding/`, label: 'Coding models' },
      { href: `${base}leaderboard/`, label: 'Leaderboard desk' },
      { href: `${base}compare/head-to-head/`, label: 'Compare head-to-head' },
    ]}
  />
</BaseLayout>
