---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getModelsByCategory } from '../../db/queries';
import { OFFICIAL_TOKEN_TOOLS } from '../../data/token-tools';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

const models = getModelsByCategory('llm')
  .filter((model) => model.inputPrice > 0 || model.outputPrice > 0)
  .sort((a, b) => {
    const blendA = (a.inputPrice + 3 * a.outputPrice) / 4;
    const blendB = (b.inputPrice + 3 * b.outputPrice) / 4;
    return blendA - blendB;
  })
  .slice(0, 20);

const safeJson = (value: unknown) => JSON.stringify(value).replace(/</g, '\\u003c');
const modelsJSON = safeJson(models.map((model) => ({
  id: model.id,
  name: model.name,
  provider: model.provider,
  colour: model.providerColour,
  inputPrice: model.inputPrice,
  outputPrice: model.outputPrice,
})));

const officialTokenTools = OFFICIAL_TOKEN_TOOLS;
---

<BaseLayout
  title="Tokenizer & Token Counter - The AI Resource Hub"
  description="Estimate prompt tokens quickly, compare rough API cost, and jump out to official token counting tools from OpenAI, Anthropic, Google, xAI, and Cohere."
>
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    <nav class="text-xs text-(--color-text-muted) mb-4" aria-label="Breadcrumb">
      <a href={base} class="hover:text-(--color-text-secondary) transition-colors">Home</a>
      <span class="mx-2">/</span>
      <span class="text-(--color-text-secondary)">Tokenizer</span>
    </nav>

    <div class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-extrabold text-(--color-text-primary) mb-3">
        Tokenizer & Token Counter
      </h1>
      <p class="text-(--color-text-secondary) max-w-3xl">
        Use the built-in estimator for a fast answer, then jump to official lab tools when you need an exact or model-specific count.
        This page is intentionally honest: our on-site counter is quick and useful, but it is still an estimate.
      </p>
    </div>

    <div class="mb-6">
      <label for="text-input" class="text-sm font-medium text-(--color-text-primary) mb-2 block">Your text</label>
      <textarea
        id="text-input"
        rows="8"
        placeholder="Paste your text here to estimate tokens..."
        class="w-full rounded-xl bg-(--color-bg-card) border border-(--color-border) text-(--color-text-primary) text-sm p-4 focus:outline-none focus:border-(--color-accent) transition-colors resize-y placeholder:text-(--color-text-muted)"
      ></textarea>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8">
      <div class="p-4 rounded-xl bg-(--color-bg-card) border border-(--color-border)">
        <p class="text-xs text-(--color-text-muted) mb-1">Characters</p>
        <p id="stat-chars" class="text-2xl font-bold text-(--color-text-primary)">0</p>
      </div>
      <div class="p-4 rounded-xl bg-(--color-bg-card) border border-(--color-border)">
        <p class="text-xs text-(--color-text-muted) mb-1">Words</p>
        <p id="stat-words" class="text-2xl font-bold text-(--color-text-primary)">0</p>
      </div>
      <div class="p-4 rounded-xl bg-(--color-bg-card) border border-(--color-border)">
        <p class="text-xs text-(--color-text-muted) mb-1">Estimated tokens</p>
        <p id="stat-tokens" class="text-2xl font-bold text-(--color-accent)">0</p>
      </div>
      <div class="p-4 rounded-xl bg-(--color-bg-card) border border-(--color-border)">
        <p class="text-xs text-(--color-text-muted) mb-1">Lines</p>
        <p id="stat-lines" class="text-2xl font-bold text-(--color-text-primary)">0</p>
      </div>
    </div>

    <div class="p-4 rounded-xl bg-(--color-bg-card) border border-(--color-border) mb-8">
      <h2 class="text-sm font-semibold text-(--color-text-primary) mb-2">How the on-site estimate works</h2>
      <p class="text-xs text-(--color-text-secondary) mb-3">
        Different labs use different tokenizers, so exact counts vary by model and request format.
        The built-in counter uses the common English rule of thumb for quick budgeting:
      </p>
      <div class="flex flex-wrap items-center gap-3 text-xs">
        <div class="p-2 rounded-lg bg-(--color-bg-tertiary)">
          <span class="font-mono text-(--color-accent)">1 token ~= 4 characters</span>
        </div>
        <div class="p-2 rounded-lg bg-(--color-bg-tertiary)">
          <span class="font-mono text-(--color-accent)">1 token ~= 0.75 words</span>
        </div>
      </div>
      <p class="text-xs text-(--color-text-muted) mt-3">
        Treat the estimate as a fast budgeting tool, not a billing guarantee. Providers often add system formatting, tool wrappers, or other hidden tokens at request time.
      </p>
    </div>

    <div class="mb-8">
      <div class="flex items-end justify-between gap-4 mb-3">
        <div>
          <h2 class="text-lg font-bold text-(--color-text-primary)">Official token tools</h2>
          <p class="text-xs text-(--color-text-muted)">
            Verified provider links for exact or provider-native token counting workflows.
          </p>
        </div>
        <a href={`${base}tools/`} class="text-xs text-(--color-accent) hover:text-(--color-accent-hover)">See full tools directory</a>
      </div>
      <div class="grid gap-3 md:grid-cols-2 xl:grid-cols-3">
        {officialTokenTools.map((tool) => (
          <a
            href={tool.url}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-xl border border-(--color-border) bg-(--color-bg-card) p-4 hover:border-(--color-border-hover) transition-colors group"
          >
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-(--color-text-muted)">{tool.lab}</p>
                <h3 class="mt-2 text-sm font-semibold text-(--color-text-primary) group-hover:text-(--color-accent) transition-colors">
                  {tool.name}
                </h3>
              </div>
              <span class="shrink-0 rounded-full bg-(--color-bg-tertiary) px-2 py-1 text-[10px] text-(--color-text-muted)">
                {tool.access}
              </span>
            </div>
            <p class="mt-3 text-xs text-(--color-text-secondary)">
              {tool.description}
            </p>
            {tool.notes && (
              <p class="mt-3 text-[11px] text-(--color-text-muted)">
                {tool.notes}
              </p>
            )}
          </a>
        ))}
      </div>
    </div>

    <div class="mb-8">
      <h2 class="text-lg font-bold text-(--color-text-primary) mb-3">Cost estimates (input side)</h2>
      <p class="text-xs text-(--color-text-muted) mb-3">
        What this text would cost as input tokens across different models. Output tokens are usually billed separately and often cost more.
      </p>
      <div class="grid gap-3 md:grid-cols-[minmax(0,1fr)_220px_220px] mb-3">
        <input
          id="token-model-search"
          type="search"
          placeholder="Search model or provider..."
          class="w-full rounded-lg bg-(--color-bg-card) border border-(--color-border) text-(--color-text-primary) text-sm px-3 py-2"
        />
        <select
          id="token-provider-filter"
          class="w-full rounded-lg bg-(--color-bg-card) border border-(--color-border) text-(--color-text-primary) text-sm px-3 py-2"
        >
          <option value="">All labs</option>
        </select>
        <select
          id="token-sort"
          class="w-full rounded-lg bg-(--color-bg-card) border border-(--color-border) text-(--color-text-primary) text-sm px-3 py-2"
        >
          <option value="cost">Lowest cost first</option>
          <option value="name">Alphabetical</option>
          <option value="provider">Lab then model</option>
          <option value="input">Lowest input price</option>
        </select>
      </div>
      <div class="rounded-xl border border-(--color-border) bg-(--color-bg-card) overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-(--color-border)">
              <th class="text-left py-3 px-4 text-(--color-text-muted) font-medium">Model</th>
              <th class="text-right py-3 px-4 text-(--color-text-muted) font-medium">Input $/1M</th>
              <th class="text-right py-3 px-4 text-(--color-text-muted) font-medium">Cost for this text</th>
              <th class="text-right py-3 px-4 text-(--color-text-muted) font-medium hidden sm:table-cell">x1000 requests</th>
            </tr>
          </thead>
          <tbody id="cost-table-body"></tbody>
        </table>
      </div>
    </div>

    <div class="mb-8">
      <h2 class="text-lg font-bold text-(--color-text-primary) mb-3">Context window check</h2>
      <p class="text-xs text-(--color-text-muted) mb-3">Does your text fit within a few common context-window tiers?</p>
      <div id="context-checks" class="grid sm:grid-cols-3 gap-3"></div>
    </div>

    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
      <a href={`${base}tools/`} class="p-4 rounded-xl bg-(--color-bg-card) border border-(--color-border) hover:border-(--color-accent)/50 transition-colors">
        <p class="text-sm font-medium text-(--color-text-primary) mb-1">Tools directory</p>
        <p class="text-xs text-(--color-text-muted)">See internal utilities plus the wider external tool map.</p>
      </a>
      <a href={`${base}glossary/`} class="p-4 rounded-xl bg-(--color-bg-card) border border-(--color-border) hover:border-(--color-accent)/50 transition-colors">
        <p class="text-sm font-medium text-(--color-text-primary) mb-1">AI glossary</p>
        <p class="text-xs text-(--color-text-muted)">Look up tokenization, MCP, context rot, TTFT, and more.</p>
      </a>
      <a href={`${base}context-window/`} class="p-4 rounded-xl bg-(--color-bg-card) border border-(--color-border) hover:border-(--color-accent)/50 transition-colors">
        <p class="text-sm font-medium text-(--color-text-primary) mb-1">Context windows</p>
        <p class="text-xs text-(--color-text-muted)">Compare context sizes across tracked models.</p>
      </a>
      <a href={`${base}academy/how-llms-work/`} class="p-4 rounded-xl bg-(--color-bg-card) border border-(--color-border) hover:border-(--color-accent)/50 transition-colors">
        <p class="text-sm font-medium text-(--color-text-primary) mb-1">How LLMs work</p>
        <p class="text-xs text-(--color-text-muted)">Read the academy explainer on tokens and tokenization.</p>
      </a>
    </div>
  </section>

  <script is:inline type="application/json" id="token-counter-models-data" set:html={modelsJSON}></script>

  <script is:inline>
    const tokenCounterModelsPayload = document.getElementById('token-counter-models-data');
    const models = tokenCounterModelsPayload?.textContent ? JSON.parse(tokenCounterModelsPayload.textContent) : [];
    const providerFilter = document.getElementById('token-provider-filter');
    const modelSearch = document.getElementById('token-model-search');
    const sortSelect = document.getElementById('token-sort');

    if (providerFilter instanceof HTMLSelectElement) {
      const providers = [...new Set(models.map((model) => model.provider))].sort((a, b) => a.localeCompare(b));
      providerFilter.innerHTML = '<option value="">All labs</option>' +
        providers.map((provider) => `<option value="${provider}">${provider}</option>`).join('');
    }

    const contextWindows = [
      { name: '128k tier', tokens: 128000 },
      { name: '200k tier', tokens: 200000 },
      { name: '1M tier', tokens: 1048576 },
    ];

    function estimateTokens(text) {
      if (!text) return 0;
      return Math.ceil(text.length / 4);
    }

    function formatCost(cost) {
      if (cost === 0) return 'Free';
      if (cost < 0.0001) return '<$0.0001';
      if (cost < 0.01) return '$' + cost.toFixed(4);
      if (cost < 1) return '$' + cost.toFixed(3);
      return '$' + cost.toFixed(2);
    }

    function formatNumber(value) {
      if (value >= 1000000) return (value / 1000000).toFixed(1) + 'M';
      if (value >= 1000) return (value / 1000).toFixed(1) + 'K';
      return value.toLocaleString();
    }

    function update() {
      const text = document.getElementById('text-input').value;
      const providerValue = providerFilter instanceof HTMLSelectElement ? providerFilter.value : '';
      const searchValue = modelSearch instanceof HTMLInputElement ? modelSearch.value.toLowerCase().trim() : '';
      const sortValue = sortSelect instanceof HTMLSelectElement ? sortSelect.value : 'cost';
      const chars = text.length;
      const words = text.trim() ? text.trim().split(/\s+/).length : 0;
      const tokens = estimateTokens(text);
      const lines = text ? text.split('\n').length : 0;

      document.getElementById('stat-chars').textContent = chars.toLocaleString();
      document.getElementById('stat-words').textContent = words.toLocaleString();
      document.getElementById('stat-tokens').textContent = tokens.toLocaleString();
      document.getElementById('stat-lines').textContent = lines.toLocaleString();

      const tbody = document.getElementById('cost-table-body');
      const filteredModels = models
        .filter((model) => {
          const matchesProvider = !providerValue || model.provider === providerValue;
          const haystack = `${model.name} ${model.provider}`.toLowerCase();
          const matchesSearch = !searchValue || haystack.includes(searchValue);
          return matchesProvider && matchesSearch;
        })
        .sort((a, b) => {
          const costA = (tokens / 1000000) * a.inputPrice;
          const costB = (tokens / 1000000) * b.inputPrice;

          switch (sortValue) {
            case 'name':
              return a.name.localeCompare(b.name);
            case 'provider':
              return a.provider.localeCompare(b.provider) || a.name.localeCompare(b.name);
            case 'input':
              return a.inputPrice - b.inputPrice || costA - costB;
            case 'cost':
            default:
              return costA - costB;
          }
        });

      tbody.innerHTML = filteredModels.map((model) => {
        const cost = (tokens / 1000000) * model.inputPrice;
        const cost1k = cost * 1000;
        const visibleValue = tokens > 0 ? formatCost(cost) : '-';
        const visibleBulkValue = tokens > 0 ? formatCost(cost1k) : '-';
        return `<tr class="border-b border-[var(--color-border)]/50 hover:bg-[var(--color-bg-hover)] transition-colors">
          <td class="py-2 px-4">
            <span class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full shrink-0" style="background-color: ${model.colour}"></span>
              <span class="text-[var(--color-text-primary)]">${model.name}</span>
            </span>
            <span class="text-[10px] text-[var(--color-text-muted)]">${model.provider}</span>
          </td>
          <td class="py-2 px-4 text-right font-mono text-xs text-[var(--color-text-secondary)]">$${model.inputPrice.toFixed(2)}</td>
          <td class="py-2 px-4 text-right font-mono text-xs ${tokens > 0 ? 'text-[var(--color-accent)]' : 'text-[var(--color-text-muted)]'}">${visibleValue}</td>
          <td class="py-2 px-4 text-right font-mono text-xs text-[var(--color-text-secondary)] hidden sm:table-cell">${visibleBulkValue}</td>
        </tr>`;
      }).join('');

      const checksEl = document.getElementById('context-checks');
      checksEl.innerHTML = contextWindows.map((contextWindow) => {
        const fits = tokens <= contextWindow.tokens;
        const pct = tokens > 0 ? Math.min((tokens / contextWindow.tokens) * 100, 100) : 0;
        return `<div class="p-3 rounded-xl border ${fits ? 'bg-[var(--color-bg-card)] border-[var(--color-border)]' : 'bg-red-500/5 border-red-500/20'}">
          <p class="text-xs font-medium ${fits ? 'text-[var(--color-text-primary)]' : 'text-red-400'}">${contextWindow.name}</p>
          <p class="text-xs text-[var(--color-text-muted)]">${formatNumber(contextWindow.tokens)} tokens</p>
          <div class="mt-2 h-1.5 bg-[var(--color-bg-tertiary)] rounded-full overflow-hidden">
            <div class="h-full rounded-full transition-all" style="width: ${pct}%; background-color: ${fits ? 'var(--color-success)' : '#ef4444'}"></div>
          </div>
          <p class="text-[10px] mt-1 ${fits ? 'text-[var(--color-success)]' : 'text-red-400'}">${fits ? `Fits (${pct.toFixed(1)}% used)` : 'Exceeds limit'}</p>
        </div>`;
      }).join('');
    }

    document.getElementById('text-input').addEventListener('input', update);
    providerFilter?.addEventListener('change', update);
    modelSearch?.addEventListener('input', update);
    sortSelect?.addEventListener('change', update);
    update();
  </script>
</BaseLayout>
