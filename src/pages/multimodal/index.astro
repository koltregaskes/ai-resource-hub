---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SyntheticMethodologyNote from '../../components/leaderboards/SyntheticMethodologyNote.astro';
import { getSyntheticLeaderboardView } from '../../data/synthetic-leaderboards';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const view = getSyntheticLeaderboardView('multimodal', 250);
const ranked = view.rankedEntries;
const tracking = [...view.partialEntries, ...view.trackingEntries].slice(0, 12);
const supportsImage = ranked.filter((model) => model.modality.includes('image')).length;
const supportsAudio = ranked.filter((model) => model.modality.includes('audio')).length;
const supportsVideo = ranked.filter((model) => model.modality.includes('video')).length;
const modalityLabel: Record<string, string> = { text: 'Text', image: 'Vision', audio: 'Audio', video: 'Video', code: 'Code' };
const modalityColour: Record<string, string> = { text: 'bg-blue-500/20 text-blue-400', image: 'bg-purple-500/20 text-purple-400', audio: 'bg-green-500/20 text-green-400', video: 'bg-red-500/20 text-red-400', code: 'bg-amber-500/20 text-amber-400' };
---

<BaseLayout title="Multimodal AI Models - The AI Resource Hub" description="Synthetic ranking for multimodal models with explicit evidence thresholds.">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    <nav class="text-xs text-(--color-text-muted) mb-4" aria-label="Breadcrumb">
      <a href={base} class="hover:text-(--color-text-secondary) transition-colors">Home</a>
      <span class="mx-2">/</span>
      <a href={`${base}compare/llm/`} class="hover:text-(--color-text-secondary) transition-colors">LLMs</a>
      <span class="mx-2">/</span>
      <span class="text-(--color-text-secondary)">Multimodal Models</span>
    </nav>

    <div class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-extrabold text-(--color-text-primary) mb-3">Multimodal AI Models</h1>
      <p class="text-(--color-text-secondary) max-w-3xl">This view is now a synthetic multimodal ranking: models need enough benchmark evidence to rank, and modality breadth is layered on top rather than standing in for proof on its own.</p>
    </div>

    <SyntheticMethodologyNote body="Synthetic ranking. Requires 4+ relevant benchmark rows to rank. Multimodal breadth helps sort current capable models, but it does not replace real benchmark evidence." />

    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 my-8"><div class="p-4 rounded-xl bg-(--color-bg-card) border border-(--color-border) text-center"><p class="text-2xl font-bold text-purple-400">{supportsImage}</p><p class="text-xs text-(--color-text-muted)">Vision</p></div><div class="p-4 rounded-xl bg-(--color-bg-card) border border-(--color-border) text-center"><p class="text-2xl font-bold text-green-400">{supportsAudio}</p><p class="text-xs text-(--color-text-muted)">Audio</p></div><div class="p-4 rounded-xl bg-(--color-bg-card) border border-(--color-border) text-center"><p class="text-2xl font-bold text-red-400">{supportsVideo}</p><p class="text-xs text-(--color-text-muted)">Video</p></div><div class="p-4 rounded-xl bg-(--color-bg-card) border border-(--color-border) text-center"><p class="text-2xl font-bold text-(--color-accent)">{ranked.length}</p><p class="text-xs text-(--color-text-muted)">Ranked models</p></div></div>

    <div class="mb-10 rounded-xl border border-(--color-border) bg-(--color-bg-card) overflow-hidden">
      <table class="w-full text-sm">
        <thead><tr class="border-b border-(--color-border)"><th class="text-center py-3 px-2 text-(--color-text-muted) font-medium w-10">#</th><th class="text-left py-3 px-4 text-(--color-text-muted) font-medium">Model</th><th class="text-left py-3 px-4 text-(--color-text-muted) font-medium">Modalities</th><th class="text-right py-3 px-4 text-(--color-text-muted) font-medium">Multimodal score</th><th class="text-right py-3 px-4 text-(--color-text-muted) font-medium hidden sm:table-cell">Evidence</th></tr></thead>
        <tbody>{ranked.map((model, index) => <tr class={`border-b border-(--color-border)/50 hover:bg-(--color-bg-hover) transition-colors ${index < 3 ? 'bg-(--color-accent)/5' : ''}`}><td class="py-3 px-2 text-center text-sm font-bold text-(--color-text-muted)">{index + 1}</td><td class="py-3 px-4"><a href={`${base}models/${model.id}/`} class="flex items-center gap-2 text-(--color-text-primary) hover:text-(--color-accent) transition-colors"><span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${model.providerColour}`}></span><span class="font-medium">{model.name}</span></a><p class="text-[10px] text-(--color-text-muted)">{model.provider}</p></td><td class="py-3 px-4"><div class="flex flex-wrap gap-1">{model.modality.map((mod) => <span class={`text-[9px] px-1.5 py-0.5 rounded ${modalityColour[mod] ?? 'bg-(--color-bg-tertiary) text-(--color-text-muted)'}`}>{modalityLabel[mod] ?? mod}</span>)}</div></td><td class="py-3 px-4 text-right font-mono font-medium text-(--color-accent)">{model.score?.toFixed(1)}</td><td class="py-3 px-4 text-right hidden sm:table-cell text-xs text-(--color-text-muted)">{model.relevantBenchmarkCount} rows</td></tr>)}</tbody>
      </table>
    </div>

    {tracking.length > 0 && <div class="mb-8"><h2 class="text-xl font-bold text-(--color-text-primary) mb-4">Tracking / insufficient evidence</h2><div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">{tracking.map((model) => <a href={`${base}models/${model.id}/`} class="p-4 rounded-xl bg-(--color-bg-card) border border-(--color-border) hover:border-(--color-accent)/30 transition-colors group"><div class="flex items-center gap-2 mb-2"><span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${model.providerColour}`}></span><h3 class="font-medium text-(--color-text-primary) group-hover:text-(--color-accent) transition-colors text-sm">{model.name}</h3></div><p class="text-xs text-(--color-text-muted)">{model.provider}</p><p class="mt-2 text-[10px] uppercase tracking-[0.16em] text-(--color-accent)">{model.evidenceTier}</p><p class="mt-1 text-xs text-(--color-text-muted)">{model.reasonIfNotEligible}</p></a>)}</div></div>}
  </section>
</BaseLayout>
