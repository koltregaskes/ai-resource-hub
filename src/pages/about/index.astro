---
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  getBenchmarks,
  getGlossaryTerms,
  getModelsByCategory,
  getPeople,
  getProvidersWithCounts,
  getYouTubeCreators,
} from '../../db/queries';
import { filterAIYouTubeCreators, getRenderableGlossaryTerms } from '../../data/content-curation';
import { loadNewsItems } from '../../data/news-digests';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

const providers = getProvidersWithCounts();
const benchmarks = getBenchmarks();
const people = getPeople();
const glossary = getRenderableGlossaryTerms(getGlossaryTerms());
const news = loadNewsItems();
const ytCreators = filterAIYouTubeCreators(getYouTubeCreators());

const categories = ['llm', 'image', 'video', 'voice', 'speech', 'sound'];
let totalModels = 0;
for (const category of categories) {
  totalModels += getModelsByCategory(category).length;
}
---

<BaseLayout
  title="About - The AI Resource Hub"
  description="About The AI Resource Hub - an independent, comprehensive AI resource for comparing models, tracking pricing, and staying informed about AI."
>
  <section class="mx-auto max-w-4xl px-4 py-8 sm:px-6 sm:py-12 lg:px-8">
    <nav class="mb-4 text-xs text-(--color-text-muted)" aria-label="Breadcrumb">
      <a href={base} class="transition-colors hover:text-(--color-text-secondary)">Home</a>
      <span class="mx-2">/</span>
      <span class="text-(--color-text-secondary)">About</span>
    </nav>

    <div class="mb-8">
      <h1 class="mb-3 text-3xl font-extrabold text-(--color-text-primary) sm:text-4xl">
        About The AI Resource Hub
      </h1>
      <p class="max-w-2xl text-lg text-(--color-text-secondary)">
        An independent resource for comparing AI models, tracking pricing, and staying informed about the rapidly evolving AI landscape.
      </p>
    </div>

    <div class="mb-8 rounded-xl border border-(--color-accent)/20 bg-(--color-accent)/10 p-5">
      <h2 class="mb-2 text-sm font-semibold text-(--color-accent)">Our Mission</h2>
      <p class="text-sm text-(--color-text-secondary)">
        To provide the most accurate, comprehensive, and unbiased resource for understanding and comparing AI models. We believe transparent data helps developers, businesses, and researchers make better decisions in an increasingly complex AI landscape.
      </p>
    </div>

    <div class="mb-10">
      <h2 class="mb-4 text-xl font-bold text-(--color-text-primary)">What We Cover</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        <div class="rounded-xl border border-(--color-border) bg-(--color-bg-card) p-4">
          <h3 class="mb-2 font-semibold text-(--color-text-primary)">Model Comparisons</h3>
          <p class="text-sm text-(--color-text-secondary)">
            Side-by-side comparisons of {totalModels} AI models across 6 categories: language models, image generation, video generation, voice synthesis, speech recognition, and music or sound. Each model is scored on quality, value, and capabilities.
          </p>
        </div>
        <div class="rounded-xl border border-(--color-border) bg-(--color-bg-card) p-4">
          <h3 class="mb-2 font-semibold text-(--color-text-primary)">Pricing Data</h3>
          <p class="text-sm text-(--color-text-secondary)">
            Real-time API pricing from {providers.length} providers, refreshed twice daily from the OpenRouter API and cross-referenced with official documentation. Track price changes over time and calculate costs with our pricing calculator.
          </p>
        </div>
        <div class="rounded-xl border border-(--color-border) bg-(--color-bg-card) p-4">
          <h3 class="mb-2 font-semibold text-(--color-text-primary)">Benchmark Data</h3>
          <p class="text-sm text-(--color-text-secondary)">
            {benchmarks.length} industry benchmarks tracked across categories including general intelligence, coding, mathematics, reasoning, safety, and multilingual evaluation. See how models compare on the metrics that matter.
          </p>
        </div>
        <div class="rounded-xl border border-(--color-border) bg-(--color-bg-card) p-4">
          <h3 class="mb-2 font-semibold text-(--color-text-primary)">News and Analysis</h3>
          <p class="text-sm text-(--color-text-secondary)">
            A twice-daily AI news feed with {news.length}+ articles from public RSS feeds, official provider blogs, and archive fallback. Guides, blog posts, and a comprehensive AI glossary with {glossary.length} terms. Plus {ytCreators.length} curated YouTube channels and AI influencers on X/Twitter.
          </p>
        </div>
      </div>
    </div>

    <div class="mb-10">
      <h2 class="mb-4 text-xl font-bold text-(--color-text-primary)">By the Numbers</h2>
      <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
        <div class="rounded-xl border border-(--color-border) bg-(--color-bg-card) p-4 text-center">
          <p class="text-2xl font-bold text-(--color-accent)">{totalModels}</p>
          <p class="text-xs text-(--color-text-muted)">AI Models</p>
        </div>
        <div class="rounded-xl border border-(--color-border) bg-(--color-bg-card) p-4 text-center">
          <p class="text-2xl font-bold text-(--color-text-primary)">{providers.length}</p>
          <p class="text-xs text-(--color-text-muted)">AI Providers</p>
        </div>
        <div class="rounded-xl border border-(--color-border) bg-(--color-bg-card) p-4 text-center">
          <p class="text-2xl font-bold text-(--color-text-primary)">{benchmarks.length}</p>
          <p class="text-xs text-(--color-text-muted)">Benchmarks</p>
        </div>
        <div class="rounded-xl border border-(--color-border) bg-(--color-bg-card) p-4 text-center">
          <p class="text-2xl font-bold text-(--color-text-primary)">{people.length}</p>
          <p class="text-xs text-(--color-text-muted)">Key People</p>
        </div>
      </div>
    </div>

    <div class="mb-10">
      <h2 class="mb-4 text-xl font-bold text-(--color-text-primary)">How It's Built</h2>
      <div class="rounded-xl border border-(--color-border) bg-(--color-bg-card) p-5">
        <ul class="space-y-3 text-sm text-(--color-text-secondary)">
          <li><strong>Static site</strong> - Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="text-(--color-accent) hover:text-(--color-accent-hover)">Astro</a> for maximum performance. Every page is pre-rendered at build time.</li>
          <li><strong>Data pipeline</strong> - Collection runs through the local automation stack, normalises into the shared registry, and publishes a static JSON cache for fast build-time queries.</li>
          <li><strong>Automated updates</strong> - Twice-daily refreshes rebuild pricing, benchmarks, news, exports, and publish-readiness checks before a new site build is allowed through.</li>
          <li><strong>Open source</strong> - The entire codebase is <a href="https://github.com/koltregaskes/ai-resource-hub" target="_blank" rel="noopener noreferrer" class="text-(--color-accent) hover:text-(--color-accent-hover)">open source on GitHub</a>. Contributions welcome.</li>
          <li><strong>No tracking</strong> - No cookies, no analytics trackers, and no third-party scripts. Just fast, clean pages.</li>
        </ul>
      </div>
    </div>

    <div class="mb-10">
      <h2 class="mb-4 text-xl font-bold text-(--color-text-primary)">Independence</h2>
      <p class="mb-3 text-sm text-(--color-text-secondary)">
        The AI Resource Hub is completely independent. We are not affiliated with, sponsored by, or funded by any AI provider, cloud platform, or technology company. We do not accept payment for rankings, reviews, or placement.
      </p>
      <p class="text-sm text-(--color-text-secondary)">
        Our quality scores are based on publicly available benchmark data, official documentation, and transparent methodology. See our <a href={`${base}methodology/`} class="text-(--color-accent) hover:text-(--color-accent-hover)">methodology page</a> for full details.
      </p>
    </div>

    <div class="rounded-xl border border-(--color-border) bg-(--color-bg-card) p-5">
      <h2 class="mb-2 text-sm font-semibold text-(--color-accent)">Get in Touch</h2>
      <p class="text-sm text-(--color-text-secondary)">
        Found an error, want to suggest a model, or have feedback? Open an issue on our <a href="https://github.com/koltregaskes/ai-resource-hub" target="_blank" rel="noopener noreferrer" class="text-(--color-accent) hover:text-(--color-accent-hover)">GitHub repository</a>.
      </p>
    </div>
  </section>
</BaseLayout>
