---
import BaseLayout from '../../layouts/BaseLayout.astro';
import UnsupportedSyntheticSurface from '../../components/leaderboards/UnsupportedSyntheticSurface.astro';
import { getSyntheticLeaderboardView } from '../../data/synthetic-leaderboards';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

const view = getSyntheticLeaderboardView('math', 12);
---

<BaseLayout
  title="AI Math Models - The AI Resource Hub"
  description="Math model coverage is visible here, but the page stays in tracking mode until the benchmark set is broad enough to rank honestly."
>
  <UnsupportedSyntheticSurface
    base={base}
    title="AI Math Models"
    description="Math capability matters, but this page no longer fakes a ranked winner from two or three published rows. We track the benchmark set, the current model watchlist, and the evidence gaps openly until the canonical math coverage is deep enough to score fairly."
    view={view}
    benchmarkBlurbs={{
      'math-500': 'A modern mathematical reasoning benchmark used by frontier labs in model cards and evaluations.',
      'aime-2025': 'Competition-style math signal covering harder Olympiad-style reasoning tasks.',
      gsm8k: 'Widely used grade-school math benchmark; still tracked here even though the current canonical registry does not yet publish rows.',
      'aime-2024': 'Historical AIME-style benchmark slot for broader year-over-year math tracking.',
      'omni-math': 'Tracked placeholder for future broader math-eval coverage once canonical rows are available.',
    }}
    relatedLinks={[
      { href: `${base}leaderboard/`, label: 'Leaderboard desk' },
      { href: `${base}reasoning/`, label: 'Reasoning leaderboard' },
      { href: `${base}benchmarks/`, label: 'Benchmark index' },
      { href: `${base}compare/head-to-head/`, label: 'Head-to-head compare' },
    ]}
  />
</BaseLayout>
