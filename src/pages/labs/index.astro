---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProvidersWithCounts } from '../../db/queries';

const providers = getProvidersWithCounts();
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
---

<BaseLayout
  title="AI Labs & Providers - The AI Resource Hub"
  description="Tracked AI labs, product companies, and model providers, with fast links into each lab profile and official site."
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    <nav class="text-xs text-(--color-text-muted) mb-4" aria-label="Breadcrumb">
      <a href={base} class="hover:text-(--color-text-secondary) transition-colors">Home</a>
      <span class="mx-2">/</span>
      <span class="text-(--color-text-secondary)">Labs & Providers</span>
    </nav>

    <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_280px] mb-8">
      <div>
        <h1 class="text-3xl sm:text-4xl font-extrabold text-(--color-text-primary) mb-3">
          AI Labs & Providers
        </h1>
        <p class="text-(--color-text-secondary) max-w-3xl">
          {providers.length} tracked labs and product companies building the models on this site.
          This page is now a clean directory: one card per lab, quick scan stats, and separate links for the site profile versus the official website.
        </p>
      </div>

      <div class="rounded-2xl border border-(--color-border) bg-(--color-bg-card) p-5">
        <p class="text-xs uppercase tracking-[0.18em] text-(--color-text-muted)">Find a lab</p>
        <input
          id="provider-search"
          type="search"
          placeholder="Search provider, CEO, or location..."
          class="mt-3 w-full rounded-full border border-(--color-border) bg-(--color-bg-primary) px-4 py-3 text-sm text-(--color-text-primary) placeholder:text-(--color-text-muted) focus:outline-none focus:border-(--color-accent)"
        />
        <select
          id="provider-sort"
          class="mt-3 w-full rounded-full border border-(--color-border) bg-(--color-bg-primary) px-4 py-3 text-sm text-(--color-text-primary) focus:outline-none focus:border-(--color-accent)"
        >
          <option value="models">Most models</option>
          <option value="name">A to Z</option>
          <option value="newest">Newest founded</option>
          <option value="oldest">Oldest founded</option>
        </select>
        <p class="mt-3 text-xs text-(--color-text-muted)">
          Search by provider, CEO, or location, then reorder the directory if you want a different scan path.
        </p>
      </div>
    </div>

    <div id="provider-grid" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {providers.map((provider) => (
        <article
          class="rounded-2xl border border-(--color-border) bg-(--color-bg-card) p-5 transition-colors hover:border-(--color-border-hover)"
          data-provider-card
          data-provider-filter={`${provider.name} ${provider.ceo ?? ''} ${provider.headquarters ?? ''} ${provider.description ?? ''}`.toLowerCase()}
          data-provider-name={provider.name.toLowerCase()}
          data-provider-model-count={provider.modelCount}
          data-provider-founded={provider.founded ? new Date(provider.founded).getFullYear() : 0}
        >
          <div class="flex items-start gap-3">
            <div
              class="w-11 h-11 rounded-2xl flex items-center justify-center text-white font-bold text-sm shrink-0"
              style={`background-color: ${provider.colour}`}
            >
              {provider.name.slice(0, 2).toUpperCase()}
            </div>

            <div class="flex-1 min-w-0">
              <div class="flex items-center justify-between gap-3">
                <h2 class="text-lg font-semibold text-(--color-text-primary) leading-tight">{provider.name}</h2>
                <span class="text-xs px-2.5 py-1 rounded-full bg-(--color-bg-tertiary) text-(--color-text-muted) shrink-0">
                  {provider.modelCount} model{provider.modelCount === 1 ? '' : 's'}
                </span>
              </div>

              {provider.ceo && (
                <p class="text-xs text-(--color-text-muted) mt-1">
                  Led by {provider.ceo}
                </p>
              )}
            </div>
          </div>

          {provider.description && (
            <p class="text-sm text-(--color-text-secondary) mt-4 line-clamp-3">
              {provider.description}
            </p>
          )}

          <div class="grid grid-cols-2 gap-4 mt-4 text-xs">
            <div>
              <p class="text-(--color-text-muted)">Founded</p>
              <p class="text-(--color-text-secondary) font-medium mt-1">
                {provider.founded ? new Date(provider.founded).getFullYear() : 'Unknown'}
              </p>
            </div>
            <div>
              <p class="text-(--color-text-muted)">HQ</p>
              <p class="text-(--color-text-secondary) font-medium mt-1 truncate" title={provider.headquarters ?? 'Unknown'}>
                {provider.headquarters ?? 'Unknown'}
              </p>
            </div>
            <div>
              <p class="text-(--color-text-muted)">Funding</p>
              <p class="text-(--color-text-secondary) font-medium mt-1 truncate" title={provider.funding ?? 'Not listed'}>
                {provider.funding ?? 'Not listed'}
              </p>
            </div>
            <div>
              <p class="text-(--color-text-muted)">Profile</p>
              <a
                href={`${base}labs/${provider.id}/`}
                class="inline-flex mt-1 text-(--color-accent) hover:text-(--color-accent-hover) transition-colors font-medium"
              >
                Open lab page
              </a>
            </div>
          </div>

          <div class="mt-5 flex items-center justify-between gap-3">
            <a
              href={`${base}labs/${provider.id}/`}
              class="inline-flex text-sm font-semibold text-(--color-text-primary) hover:text-(--color-accent) transition-colors"
            >
              View details
            </a>
            {provider.website && (
              <a
                href={provider.website}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex text-sm font-semibold text-(--color-accent) hover:text-(--color-accent-hover) transition-colors"
              >
                Official site
              </a>
            )}
          </div>
        </article>
      ))}
    </div>

    <div id="provider-empty-state" class="hidden rounded-2xl border border-dashed border-(--color-border) bg-(--color-bg-card) p-8 text-center text-(--color-text-secondary)">
      No labs match the current search or sort. Clear the filters and try again.
    </div>
  </section>

  <script is:inline>
    (() => {
      const searchInput = document.getElementById('provider-search');
      const sortInput = document.getElementById('provider-sort');
      const grid = document.getElementById('provider-grid');
      const emptyState = document.getElementById('provider-empty-state');
      const cards = Array.from(document.querySelectorAll('[data-provider-card]'));

      function updateFilter() {
        const query = (searchInput instanceof HTMLInputElement ? searchInput.value : '').toLowerCase().trim();
        const sort = sortInput instanceof HTMLSelectElement ? sortInput.value : 'models';

        for (const card of cards) {
          const haystack = card.getAttribute('data-provider-filter') || '';
          const matches = !query || haystack.includes(query);
          card.classList.toggle('hidden', !matches);
        }

        const visibleCards = cards.filter((card) => !card.classList.contains('hidden'));
        const sortedCards = [...visibleCards].sort((a, b) => {
          if (sort === 'name') {
            return (a.getAttribute('data-provider-name') || '').localeCompare(b.getAttribute('data-provider-name') || '');
          }

          if (sort === 'newest') {
            return Number(b.getAttribute('data-provider-founded') || 0) - Number(a.getAttribute('data-provider-founded') || 0)
              || (a.getAttribute('data-provider-name') || '').localeCompare(b.getAttribute('data-provider-name') || '');
          }

          if (sort === 'oldest') {
            return Number(a.getAttribute('data-provider-founded') || 0) - Number(b.getAttribute('data-provider-founded') || 0)
              || (a.getAttribute('data-provider-name') || '').localeCompare(b.getAttribute('data-provider-name') || '');
          }

          return Number(b.getAttribute('data-provider-model-count') || 0) - Number(a.getAttribute('data-provider-model-count') || 0)
            || (a.getAttribute('data-provider-name') || '').localeCompare(b.getAttribute('data-provider-name') || '');
        });

        sortedCards.forEach((card) => grid?.appendChild(card));
        emptyState?.classList.toggle('hidden', visibleCards.length > 0);
      }

      searchInput?.addEventListener('input', updateFilter);
      sortInput?.addEventListener('change', updateFilter);
      updateFilter();
    })();
  </script>
</BaseLayout>
