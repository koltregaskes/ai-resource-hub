---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SyntheticMethodologyNote from '../../components/leaderboards/SyntheticMethodologyNote.astro';
import { getModelsByCategory } from '../../db/queries';
import { getFrontierNow } from '../../data/hub-dashboard';
import { getSyntheticLeaderboardView } from '../../data/synthetic-leaderboards';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

const frontierNow = getFrontierNow(18);
const evaluatedView = getSyntheticLeaderboardView('evaluated-composite', 250);
const rankedModels = evaluatedView.rankedEntries;
const trackingModels = [...evaluatedView.partialEntries, ...evaluatedView.trackingEntries].slice(0, 18);
const valueView = getSyntheticLeaderboardView('best-value', 24);
const topValue = valueView.rankedEntries.slice(0, 8);
const cheapest = getModelsByCategory('llm')
  .filter((model) => model.inputPrice > 0)
  .sort((a, b) => a.inputPrice - b.inputPrice || a.outputPrice - b.outputPrice)
  .slice(0, 8);

function formatContextWindow(tokens: number): string {
  if (tokens >= 1_000_000) return `${(tokens / 1_000_000).toFixed(1)}M`;
  return `${Math.round(tokens / 1_000)}K`;
}

function formatReleaseDate(value: string | null): string {
  if (!value) return 'Unknown';
  return new Date(value).toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
  });
}

function formatPricePair(inputPrice: number, outputPrice: number, openSource: boolean): string {
  if (inputPrice === 0 && outputPrice === 0) return openSource ? 'Open / free' : 'Included';
  return `$${inputPrice.toFixed(2)} / $${outputPrice.toFixed(2)}`;
}
---

<BaseLayout title="AI Leaderboard Desk - The AI Resource Hub" description="Frontier watchlist, evaluated synthetic rankings, and explicit tracking states for AI models.">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    <nav class="text-xs text-(--color-text-muted) mb-4" aria-label="Breadcrumb">
      <a href={base} class="hover:text-(--color-text-secondary) transition-colors">Home</a>
      <span class="mx-2">/</span>
      <span class="text-(--color-text-secondary)">Leaderboard</span>
    </nav>

    <div class="mb-8">
      <p class="text-[11px] font-semibold uppercase tracking-[0.28em] text-(--color-text-muted)">Ranking desk</p>
      <h1 class="mt-2 text-3xl sm:text-4xl font-extrabold text-(--color-text-primary)">AI Leaderboard Desk</h1>
      <p class="text-(--color-text-secondary) max-w-3xl mt-3 leading-7">This page now separates three different states clearly: the current frontier watchlist, the benchmark-backed evaluated composite, and the models that are still being tracked because the evidence is too thin to rank honestly.</p>
    </div>

    <div class="grid gap-3 sm:grid-cols-3 mb-8">
      <div class="p-4 rounded-xl bg-(--color-bg-card) border border-(--color-border)"><p class="text-2xl font-bold text-(--color-accent)">{frontierNow.length}</p><p class="text-xs text-(--color-text-muted)">Frontier watchlist</p></div>
      <div class="p-4 rounded-xl bg-(--color-bg-card) border border-(--color-border)"><p class="text-2xl font-bold text-(--color-text-primary)">{rankedModels.length}</p><p class="text-xs text-(--color-text-muted)">Evaluated models</p></div>
      <div class="p-4 rounded-xl bg-(--color-bg-card) border border-(--color-border)"><p class="text-2xl font-bold text-(--color-text-primary)">{trackingModels.length}</p><p class="text-xs text-(--color-text-muted)">Tracking / insufficient evidence</p></div>
    </div>

    <section class="mb-12">
      <div class="flex items-end justify-between gap-4 mb-4">
        <div>
          <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-(--color-accent)">Frontier now</p>
          <h2 class="text-2xl font-bold text-(--color-text-primary)">Current flagship and launch watchlist</h2>
        </div>
        <p class="text-sm text-(--color-text-secondary) max-w-xl">Not a synthetic score. This lane keeps the current major models visible even before benchmark coverage catches up.</p>
      </div>

      <div class="rounded-xl border border-(--color-border) bg-(--color-bg-card) overflow-hidden">
        <table class="w-full text-sm">
          <thead><tr class="border-b border-(--color-border)"><th class="text-left py-3 px-4 text-(--color-text-muted) font-medium">Model</th><th class="text-left py-3 px-4 text-(--color-text-muted) font-medium">State</th><th class="text-left py-3 px-4 text-(--color-text-muted) font-medium hidden md:table-cell">Released</th><th class="text-right py-3 px-4 text-(--color-text-muted) font-medium">Price</th></tr></thead>
          <tbody>{frontierNow.map((model) => <tr class="border-b border-(--color-border)/50 hover:bg-(--color-bg-hover) transition-colors"><td class="py-3 px-4"><a href={`${base}models/${model.id}/`} class="flex items-center gap-2 text-(--color-text-primary) hover:text-(--color-accent) transition-colors"><span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${model.providerColour}`}></span><span class="font-medium">{model.name}</span></a><p class="text-[10px] text-(--color-text-muted)">{model.provider} / {formatContextWindow(model.contextWindow)} context</p></td><td class="py-3 px-4 text-(--color-text-secondary)"><p class="text-xs uppercase tracking-[0.16em] text-(--color-accent)">{model.evidenceState}</p><p class="mt-1 text-xs text-(--color-text-muted)">{model.evidenceLabel}</p></td><td class="py-3 px-4 text-(--color-text-muted) hidden md:table-cell">{formatReleaseDate(model.released)}</td><td class="py-3 px-4 text-right font-mono text-xs text-(--color-text-secondary)">{formatPricePair(model.inputPrice, model.outputPrice, model.openSource)}</td></tr>)}</tbody>
        </table>
      </div>
    </section>

    <section class="mb-12">
      <div class="flex items-end justify-between gap-4 mb-4">
        <div>
          <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-(--color-accent)">Evaluated composite</p>
          <h2 class="text-2xl font-bold text-(--color-text-primary)">Best-evidenced current synthetic ranking</h2>
        </div>
        <p class="text-sm text-(--color-text-secondary) max-w-xl">This is the scored view. Models need at least four relevant benchmark rows to rank, and freshness still matters.</p>
      </div>

      <SyntheticMethodologyNote body="Synthetic ranking. Requires 4+ relevant benchmark rows to rank. Models with thinner evidence are shown separately instead of being folded into the numbered table." />

      <div class="mt-4 rounded-xl border border-(--color-border) bg-(--color-bg-card) overflow-hidden">
        <table class="w-full text-sm">
          <thead><tr class="border-b border-(--color-border)"><th class="text-center py-3 px-2 text-(--color-text-muted) font-medium w-10">#</th><th class="text-left py-3 px-4 text-(--color-text-muted) font-medium">Model</th><th class="text-right py-3 px-4 text-(--color-text-muted) font-medium">Composite</th><th class="text-right py-3 px-4 text-(--color-text-muted) font-medium hidden sm:table-cell">Bench</th><th class="text-right py-3 px-4 text-(--color-text-muted) font-medium hidden md:table-cell">Evidence</th><th class="text-right py-3 px-4 text-(--color-text-muted) font-medium">Price</th></tr></thead>
          <tbody>{rankedModels.slice(0, 24).map((model, index) => <tr class={`border-b border-(--color-border)/50 hover:bg-(--color-bg-hover) transition-colors ${index < 3 ? 'bg-(--color-accent)/5' : ''}`}><td class="py-3 px-2 text-center text-sm font-bold text-(--color-text-muted)">{index + 1}</td><td class="py-3 px-4"><a href={`${base}models/${model.id}/`} class="flex items-center gap-2 text-(--color-text-primary) hover:text-(--color-accent) transition-colors"><span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${model.providerColour}`}></span><span class="font-medium">{model.name}</span></a><p class="text-[10px] text-(--color-text-muted)">{model.provider} / {model.relevantBenchmarkCount} relevant rows / {formatContextWindow(model.contextWindow)} context</p></td><td class="py-3 px-4 text-right font-mono font-medium text-(--color-accent)">{model.score?.toFixed(1)}</td><td class="py-3 px-4 text-right hidden sm:table-cell font-mono text-xs text-(--color-text-secondary)">{model.benchmarkScore.toFixed(1)}</td><td class="py-3 px-4 text-right hidden md:table-cell text-xs text-(--color-text-muted)">{model.relevantBenchmarkCount} rows</td><td class="py-3 px-4 text-right font-mono text-xs text-(--color-text-secondary)">{formatPricePair(model.inputPrice, model.outputPrice, model.openSource)}</td></tr>)}</tbody>
        </table>
      </div>
    </section>

    <section class="mb-12">
      <div class="flex items-end justify-between gap-4 mb-4">
        <div>
          <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-(--color-accent)">Tracking / insufficient evidence</p>
          <h2 class="text-2xl font-bold text-(--color-text-primary)">Visible, but not yet rankable</h2>
        </div>
        <p class="text-sm text-(--color-text-secondary) max-w-xl">These models are tracked in public because they matter, but they do not enter the numbered table until the evidence threshold is met.</p>
      </div>

      <div class="rounded-xl border border-(--color-border) bg-(--color-bg-card) overflow-hidden">
        <table class="w-full text-sm">
          <thead><tr class="border-b border-(--color-border)"><th class="text-left py-3 px-4 text-(--color-text-muted) font-medium">Model</th><th class="text-left py-3 px-4 text-(--color-text-muted) font-medium">Evidence</th><th class="text-right py-3 px-4 text-(--color-text-muted) font-medium hidden md:table-cell">Freshness</th></tr></thead>
          <tbody>{trackingModels.map((model) => <tr class="border-b border-(--color-border)/50"><td class="py-3 px-4"><a href={`${base}models/${model.id}/`} class="flex items-center gap-2 text-(--color-text-primary) hover:text-(--color-accent) transition-colors"><span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${model.providerColour}`}></span><span class="font-medium">{model.name}</span></a><p class="text-[10px] text-(--color-text-muted)">{model.provider}</p></td><td class="py-3 px-4 text-(--color-text-secondary)"><p class="text-xs uppercase tracking-[0.16em] text-(--color-accent)">{model.evidenceTier}</p><p class="mt-1 text-xs text-(--color-text-muted)">{model.reasonIfNotEligible}</p></td><td class="py-3 px-4 text-right hidden md:table-cell font-mono text-xs text-(--color-text-secondary)">{model.freshness.toFixed(0)}</td></tr>)}</tbody>
        </table>
      </div>
    </section>

    <section class="grid gap-6 lg:grid-cols-2">
      <div class="rounded-xl border border-(--color-border) bg-(--color-bg-card) p-5">
        <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-(--color-accent)">Best value snapshot</p>
        <div class="mt-4 space-y-3">{topValue.map((model, index) => <a href={`${base}models/${model.id}/`} class="flex items-center justify-between gap-3 text-sm text-(--color-text-primary) hover:text-(--color-accent) transition-colors"><span>{index + 1}. {model.name}</span><span class="font-mono text-xs text-(--color-text-secondary)">{model.score?.toFixed(1)}</span></a>)}</div>
        <a href={`${base}best-value/`} class="inline-flex mt-4 text-sm text-(--color-accent) hover:text-(--color-accent-hover) transition-colors">Open value ranking &rarr;</a>
      </div>
      <div class="rounded-xl border border-(--color-border) bg-(--color-bg-card) p-5">
        <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-(--color-accent)">Cheapest factual view</p>
        <div class="mt-4 space-y-3">{cheapest.map((model, index) => <a href={`${base}models/${model.id}/`} class="flex items-center justify-between gap-3 text-sm text-(--color-text-primary) hover:text-(--color-accent) transition-colors"><span>{index + 1}. {model.name}</span><span class="font-mono text-xs text-(--color-text-secondary)">$${model.inputPrice.toFixed(2)}</span></a>)}</div>
        <a href={`${base}cheapest/`} class="inline-flex mt-4 text-sm text-(--color-accent) hover:text-(--color-accent-hover) transition-colors">Open cheapest models &rarr;</a>
      </div>
    </section>
  </section>
</BaseLayout>
