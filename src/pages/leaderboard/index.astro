---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getMetaLeaderboard } from '../../data/hub-dashboard';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

const rankedModels = getMetaLeaderboard(250);
const topMeta = rankedModels.slice(0, 24);
const topValue = [...rankedModels]
  .filter((model) => model.inputPrice > 0 && model.outputPrice > 0)
  .sort((a, b) => b.valueScore - a.valueScore)
  .slice(0, 24);
const topCheapest = [...rankedModels]
  .filter((model) => model.inputPrice > 0)
  .sort((a, b) => a.inputPrice - b.inputPrice || a.outputPrice - b.outputPrice)
  .slice(0, 24);

function formatCoverage(ratio: number): string {
  return `${Math.round(ratio * 100)}%`;
}

function formatContextWindow(tokens: number): string {
  if (tokens >= 1_000_000) return `${(tokens / 1_000_000).toFixed(1)}M`;
  return `${Math.round(tokens / 1_000)}K`;
}

function formatPricePair(inputPrice: number, outputPrice: number, openSource: boolean): string {
  if (inputPrice === 0 && outputPrice === 0) return openSource ? 'Open / free' : 'Included';
  return `$${inputPrice.toFixed(2)} / $${outputPrice.toFixed(2)}`;
}
---

<BaseLayout
  title="AI Meta Leaderboard - The AI Resource Hub"
  description="Benchmark-weighted leaderboard of AI models. Compare meta score, benchmark coverage, context, and price in one place."
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    <nav class="text-xs text-(--color-text-muted) mb-4" aria-label="Breadcrumb">
      <a href={base} class="hover:text-(--color-text-secondary) transition-colors">Home</a>
      <span class="mx-2">/</span>
      <span class="text-(--color-text-secondary)">Leaderboard</span>
    </nav>

    <div class="mb-8">
      <p class="text-[11px] font-semibold uppercase tracking-[0.28em] text-(--color-text-muted)">Weighted ranking</p>
      <h1 class="mt-2 text-3xl sm:text-4xl font-extrabold text-(--color-text-primary)">AI Meta Leaderboard</h1>
      <p class="text-(--color-text-secondary) max-w-3xl mt-3 leading-7">
        This page ranks LLMs using the same coverage-aware benchmark blend shown on the homepage. Meta score combines
        normalized benchmark results, benchmark coverage, and the existing quality layer, so newer models with thin
        published data do not leapfrog better-documented leaders on hype alone.
      </p>
    </div>

    <div class="flex flex-wrap gap-2 mb-6 border-b border-(--color-border) pb-2">
      <button class="leaderboard-tab active px-4 py-2 text-sm font-medium rounded-t-lg transition-colors" data-tab="meta">
        Meta score
      </button>
      <button class="leaderboard-tab px-4 py-2 text-sm font-medium rounded-t-lg transition-colors" data-tab="value">
        Best value
      </button>
      <button class="leaderboard-tab px-4 py-2 text-sm font-medium rounded-t-lg transition-colors" data-tab="cheapest">
        Cheapest
      </button>
    </div>

    <div class="leaderboard-panel" id="panel-meta">
      <div class="rounded-xl border border-(--color-border) bg-(--color-bg-card) overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-(--color-border)">
              <th class="text-center py-3 px-2 text-(--color-text-muted) font-medium w-10">#</th>
              <th class="text-left py-3 px-4 text-(--color-text-muted) font-medium">Model</th>
              <th class="text-right py-3 px-4 text-(--color-text-muted) font-medium">Meta</th>
              <th class="text-right py-3 px-4 text-(--color-text-muted) font-medium hidden sm:table-cell">Bench</th>
              <th class="text-right py-3 px-4 text-(--color-text-muted) font-medium hidden md:table-cell">Coverage</th>
              <th class="text-right py-3 px-4 text-(--color-text-muted) font-medium">Price</th>
            </tr>
          </thead>
          <tbody>
            {topMeta.map((model, index) => (
              <tr class={`border-b border-(--color-border)/50 hover:bg-(--color-bg-hover) transition-colors ${index < 3 ? 'bg-(--color-accent)/5' : ''}`}>
                <td class="py-3 px-2 text-center">
                  <span class={`text-sm font-bold ${index === 0 ? 'text-amber-400' : index === 1 ? 'text-gray-400' : index === 2 ? 'text-amber-600' : 'text-(--color-text-muted)'}`}>
                    {index + 1}
                  </span>
                </td>
                <td class="py-3 px-4">
                  <a href={`${base}models/${model.id}/`} class="flex items-center gap-2 text-(--color-text-primary) hover:text-(--color-accent) transition-colors">
                    <span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${model.providerColour}`}></span>
                    <span class="font-medium">{model.name}</span>
                  </a>
                  <span class="text-[10px] text-(--color-text-muted)">
                    {model.provider} / {model.bestFor} / {formatContextWindow(model.contextWindow)} context
                  </span>
                </td>
                <td class="py-3 px-4 text-right">
                  <span class="font-mono font-medium text-(--color-accent)">{model.metaScore.toFixed(1)}</span>
                </td>
                <td class="py-3 px-4 text-right hidden sm:table-cell">
                  <span class="text-xs text-(--color-text-muted)">{model.benchmarkScore.toFixed(1)} / {model.benchmarkCount}</span>
                </td>
                <td class="py-3 px-4 text-right hidden md:table-cell">
                  <span class="text-xs text-(--color-text-muted)">{formatCoverage(model.coverageRatio)}</span>
                </td>
                <td class="py-3 px-4 text-right font-mono text-xs text-(--color-text-secondary)">
                  {formatPricePair(model.inputPrice, model.outputPrice, model.openSource)}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <div class="leaderboard-panel hidden" id="panel-value">
      <div class="rounded-xl border border-(--color-border) bg-(--color-bg-card) overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-(--color-border)">
              <th class="text-center py-3 px-2 text-(--color-text-muted) font-medium w-10">#</th>
              <th class="text-left py-3 px-4 text-(--color-text-muted) font-medium">Model</th>
              <th class="text-right py-3 px-4 text-(--color-text-muted) font-medium">Value</th>
              <th class="text-right py-3 px-4 text-(--color-text-muted) font-medium hidden sm:table-cell">Meta</th>
              <th class="text-right py-3 px-4 text-(--color-text-muted) font-medium">Price</th>
            </tr>
          </thead>
          <tbody>
            {topValue.map((model, index) => (
              <tr class={`border-b border-(--color-border)/50 hover:bg-(--color-bg-hover) transition-colors ${index < 3 ? 'bg-(--color-accent)/5' : ''}`}>
                <td class="py-3 px-2 text-center">
                  <span class={`text-sm font-bold ${index === 0 ? 'text-amber-400' : index === 1 ? 'text-gray-400' : index === 2 ? 'text-amber-600' : 'text-(--color-text-muted)'}`}>
                    {index + 1}
                  </span>
                </td>
                <td class="py-3 px-4">
                  <a href={`${base}models/${model.id}/`} class="flex items-center gap-2 text-(--color-text-primary) hover:text-(--color-accent) transition-colors">
                    <span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${model.providerColour}`}></span>
                    <span class="font-medium">{model.name}</span>
                  </a>
                  <span class="text-[10px] text-(--color-text-muted)">{model.provider}</span>
                </td>
                <td class="py-3 px-4 text-right">
                  <span class="font-mono font-medium text-green-400">{model.valueScore.toFixed(1)}</span>
                </td>
                <td class="py-3 px-4 text-right hidden sm:table-cell">
                  <span class="font-mono text-xs text-(--color-text-secondary)">{model.metaScore.toFixed(1)}</span>
                </td>
                <td class="py-3 px-4 text-right font-mono text-xs text-(--color-text-secondary)">
                  ${model.inputPrice.toFixed(2)} / ${model.outputPrice.toFixed(2)}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <div class="leaderboard-panel hidden" id="panel-cheapest">
      <div class="rounded-xl border border-(--color-border) bg-(--color-bg-card) overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-(--color-border)">
              <th class="text-center py-3 px-2 text-(--color-text-muted) font-medium w-10">#</th>
              <th class="text-left py-3 px-4 text-(--color-text-muted) font-medium">Model</th>
              <th class="text-right py-3 px-4 text-(--color-text-muted) font-medium">Input</th>
              <th class="text-right py-3 px-4 text-(--color-text-muted) font-medium">Output</th>
              <th class="text-right py-3 px-4 text-(--color-text-muted) font-medium hidden sm:table-cell">Meta</th>
            </tr>
          </thead>
          <tbody>
            {topCheapest.map((model, index) => (
              <tr class={`border-b border-(--color-border)/50 hover:bg-(--color-bg-hover) transition-colors ${index < 3 ? 'bg-(--color-accent)/5' : ''}`}>
                <td class="py-3 px-2 text-center">
                  <span class={`text-sm font-bold ${index === 0 ? 'text-amber-400' : index === 1 ? 'text-gray-400' : index === 2 ? 'text-amber-600' : 'text-(--color-text-muted)'}`}>
                    {index + 1}
                  </span>
                </td>
                <td class="py-3 px-4">
                  <a href={`${base}models/${model.id}/`} class="flex items-center gap-2 text-(--color-text-primary) hover:text-(--color-accent) transition-colors">
                    <span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${model.providerColour}`}></span>
                    <span class="font-medium">{model.name}</span>
                  </a>
                  <span class="text-[10px] text-(--color-text-muted)">{model.provider}</span>
                </td>
                <td class="py-3 px-4 text-right font-mono text-sm font-medium text-green-400">
                  ${model.inputPrice.toFixed(3)}
                </td>
                <td class="py-3 px-4 text-right font-mono text-sm text-(--color-text-secondary)">
                  ${model.outputPrice.toFixed(3)}
                </td>
                <td class="py-3 px-4 text-right hidden sm:table-cell">
                  <span class="font-mono text-xs text-(--color-text-muted)">{model.metaScore.toFixed(1)}</span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <p class="mt-6 text-sm text-(--color-text-secondary) max-w-3xl">
      Meta score is coverage-aware by design. Models with thin public benchmark coverage can still appear here, but they are
      penalized until enough benchmark evidence exists to trust the ranking.
    </p>
  </section>

  <script is:inline>
    (() => {
      const tabs = document.querySelectorAll('.leaderboard-tab');
      const panels = document.querySelectorAll('.leaderboard-panel');

      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const target = tab.getAttribute('data-tab');

          tabs.forEach((node) => node.classList.remove('active', 'bg-(--color-accent)/20', 'text-(--color-accent)'));
          tab.classList.add('active', 'bg-(--color-accent)/20', 'text-(--color-accent)');

          panels.forEach((panel) => panel.classList.add('hidden'));
          document.getElementById(`panel-${target}`)?.classList.remove('hidden');
        });
      });

      tabs[0]?.classList.add('bg-(--color-accent)/20', 'text-(--color-accent)');
    })();
  </script>
</BaseLayout>
