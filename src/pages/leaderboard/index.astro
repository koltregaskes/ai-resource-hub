---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getMetaLeaderboard } from '../../data/hub-dashboard';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

const rankedModels = getMetaLeaderboard(250);
const topMeta = rankedModels.slice(0, 24);
const topValue = [...rankedModels]
  .filter((model) => model.inputPrice > 0 && model.outputPrice > 0)
  .sort((a, b) => b.valueScore - a.valueScore)
  .slice(0, 24);
const topCheapest = [...rankedModels]
  .filter((model) => model.inputPrice > 0)
  .sort((a, b) => a.inputPrice - b.inputPrice || a.outputPrice - b.outputPrice)
  .slice(0, 24);
const providerOptions = Array.from(new Set(rankedModels.map((model) => model.provider))).sort((a, b) => a.localeCompare(b));
const useCaseOptions = Array.from(new Set(rankedModels.map((model) => model.bestFor))).sort((a, b) => a.localeCompare(b));

function formatCoverage(ratio: number): string {
  return `${Math.round(ratio * 100)}%`;
}

function formatContextWindow(tokens: number): string {
  if (tokens >= 1_000_000) return `${(tokens / 1_000_000).toFixed(1)}M`;
  return `${Math.round(tokens / 1_000)}K`;
}

function formatPricePair(inputPrice: number, outputPrice: number, openSource: boolean): string {
  if (inputPrice === 0 && outputPrice === 0) return openSource ? 'Open / free' : 'Included';
  return `$${inputPrice.toFixed(2)} / $${outputPrice.toFixed(2)}`;
}

function formatReleaseDate(value: string | null): string {
  if (!value) return 'Unknown';
  return new Date(value).toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
  });
}
---

<BaseLayout
  title="AI Composite Leaderboard - The AI Resource Hub"
  description="Benchmark-weighted leaderboard of AI models. Compare composite score, benchmark coverage, context, and price in one place."
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    <nav class="text-xs text-(--color-text-muted) mb-4" aria-label="Breadcrumb">
      <a href={base} class="hover:text-(--color-text-secondary) transition-colors">Home</a>
      <span class="mx-2">/</span>
      <span class="text-(--color-text-secondary)">Leaderboard</span>
    </nav>

    <div class="mb-8">
      <p class="text-[11px] font-semibold uppercase tracking-[0.28em] text-(--color-text-muted)">Weighted ranking</p>
      <h1 class="mt-2 text-3xl sm:text-4xl font-extrabold text-(--color-text-primary)">AI Composite Leaderboard</h1>
      <p class="text-(--color-text-secondary) max-w-3xl mt-3 leading-7">
        This page ranks LLMs using the same coverage-aware benchmark blend shown on the homepage. Composite score combines
        normalized benchmark results, benchmark coverage, and the existing quality layer, so newer models with thin
        published data do not leapfrog better-documented leaders on hype alone.
      </p>
    </div>

    <div class="flex flex-wrap gap-2 mb-6 border-b border-(--color-border) pb-2">
      <button class="leaderboard-tab active px-4 py-2 text-sm font-medium rounded-t-lg transition-colors" data-tab="meta">
        Composite score
      </button>
      <button class="leaderboard-tab px-4 py-2 text-sm font-medium rounded-t-lg transition-colors" data-tab="value">
        Best value
      </button>
      <button class="leaderboard-tab px-4 py-2 text-sm font-medium rounded-t-lg transition-colors" data-tab="cheapest">
        Cheapest
      </button>
    </div>

    <div class="leaderboard-panel" id="panel-meta">
      <div class="rounded-xl border border-(--color-border) bg-(--color-bg-card) overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-(--color-border)">
              <th class="text-center py-3 px-2 text-(--color-text-muted) font-medium w-10">#</th>
              <th class="text-left py-3 px-4 text-(--color-text-muted) font-medium">Model</th>
              <th class="text-right py-3 px-4 text-(--color-text-muted) font-medium">Composite</th>
              <th class="text-right py-3 px-4 text-(--color-text-muted) font-medium hidden sm:table-cell">Bench</th>
              <th class="text-right py-3 px-4 text-(--color-text-muted) font-medium hidden md:table-cell">Coverage</th>
              <th class="text-right py-3 px-4 text-(--color-text-muted) font-medium">Price</th>
            </tr>
          </thead>
          <tbody>
            {topMeta.map((model, index) => (
              <tr class={`border-b border-(--color-border)/50 hover:bg-(--color-bg-hover) transition-colors ${index < 3 ? 'bg-(--color-accent)/5' : ''}`}>
                <td class="py-3 px-2 text-center">
                  <span class={`text-sm font-bold ${index === 0 ? 'text-amber-400' : index === 1 ? 'text-gray-400' : index === 2 ? 'text-amber-600' : 'text-(--color-text-muted)'}`}>
                    {index + 1}
                  </span>
                </td>
                <td class="py-3 px-4">
                  <a href={`${base}models/${model.id}/`} class="flex items-center gap-2 text-(--color-text-primary) hover:text-(--color-accent) transition-colors">
                    <span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${model.providerColour}`}></span>
                    <span class="font-medium">{model.name}</span>
                  </a>
                  <span class="text-[10px] text-(--color-text-muted)">
                    {model.provider} / {model.bestFor} / {formatContextWindow(model.contextWindow)} context
                  </span>
                </td>
                <td class="py-3 px-4 text-right">
                  <span class="font-mono font-medium text-(--color-accent)">{model.metaScore.toFixed(1)}</span>
                </td>
                <td class="py-3 px-4 text-right hidden sm:table-cell">
                  <span class="text-xs text-(--color-text-muted)">{model.benchmarkScore.toFixed(1)} / {model.benchmarkCount}</span>
                </td>
                <td class="py-3 px-4 text-right hidden md:table-cell">
                  <span class="text-xs text-(--color-text-muted)">{formatCoverage(model.coverageRatio)}</span>
                </td>
                <td class="py-3 px-4 text-right font-mono text-xs text-(--color-text-secondary)">
                  {formatPricePair(model.inputPrice, model.outputPrice, model.openSource)}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <div class="leaderboard-panel hidden" id="panel-value">
      <div class="rounded-xl border border-(--color-border) bg-(--color-bg-card) overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-(--color-border)">
              <th class="text-center py-3 px-2 text-(--color-text-muted) font-medium w-10">#</th>
              <th class="text-left py-3 px-4 text-(--color-text-muted) font-medium">Model</th>
              <th class="text-right py-3 px-4 text-(--color-text-muted) font-medium">Value</th>
              <th class="text-right py-3 px-4 text-(--color-text-muted) font-medium hidden sm:table-cell">Composite</th>
              <th class="text-right py-3 px-4 text-(--color-text-muted) font-medium">Price</th>
            </tr>
          </thead>
          <tbody>
            {topValue.map((model, index) => (
              <tr class={`border-b border-(--color-border)/50 hover:bg-(--color-bg-hover) transition-colors ${index < 3 ? 'bg-(--color-accent)/5' : ''}`}>
                <td class="py-3 px-2 text-center">
                  <span class={`text-sm font-bold ${index === 0 ? 'text-amber-400' : index === 1 ? 'text-gray-400' : index === 2 ? 'text-amber-600' : 'text-(--color-text-muted)'}`}>
                    {index + 1}
                  </span>
                </td>
                <td class="py-3 px-4">
                  <a href={`${base}models/${model.id}/`} class="flex items-center gap-2 text-(--color-text-primary) hover:text-(--color-accent) transition-colors">
                    <span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${model.providerColour}`}></span>
                    <span class="font-medium">{model.name}</span>
                  </a>
                  <span class="text-[10px] text-(--color-text-muted)">{model.provider}</span>
                </td>
                <td class="py-3 px-4 text-right">
                  <span class="font-mono font-medium text-green-400">{model.valueScore.toFixed(1)}</span>
                </td>
                <td class="py-3 px-4 text-right hidden sm:table-cell">
                  <span class="font-mono text-xs text-(--color-text-secondary)">{model.metaScore.toFixed(1)}</span>
                </td>
                <td class="py-3 px-4 text-right font-mono text-xs text-(--color-text-secondary)">
                  ${model.inputPrice.toFixed(2)} / ${model.outputPrice.toFixed(2)}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <div class="leaderboard-panel hidden" id="panel-cheapest">
      <div class="rounded-xl border border-(--color-border) bg-(--color-bg-card) overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-(--color-border)">
              <th class="text-center py-3 px-2 text-(--color-text-muted) font-medium w-10">#</th>
              <th class="text-left py-3 px-4 text-(--color-text-muted) font-medium">Model</th>
              <th class="text-right py-3 px-4 text-(--color-text-muted) font-medium">Input</th>
              <th class="text-right py-3 px-4 text-(--color-text-muted) font-medium">Output</th>
              <th class="text-right py-3 px-4 text-(--color-text-muted) font-medium hidden sm:table-cell">Composite</th>
            </tr>
          </thead>
          <tbody>
            {topCheapest.map((model, index) => (
              <tr class={`border-b border-(--color-border)/50 hover:bg-(--color-bg-hover) transition-colors ${index < 3 ? 'bg-(--color-accent)/5' : ''}`}>
                <td class="py-3 px-2 text-center">
                  <span class={`text-sm font-bold ${index === 0 ? 'text-amber-400' : index === 1 ? 'text-gray-400' : index === 2 ? 'text-amber-600' : 'text-(--color-text-muted)'}`}>
                    {index + 1}
                  </span>
                </td>
                <td class="py-3 px-4">
                  <a href={`${base}models/${model.id}/`} class="flex items-center gap-2 text-(--color-text-primary) hover:text-(--color-accent) transition-colors">
                    <span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${model.providerColour}`}></span>
                    <span class="font-medium">{model.name}</span>
                  </a>
                  <span class="text-[10px] text-(--color-text-muted)">{model.provider}</span>
                </td>
                <td class="py-3 px-4 text-right font-mono text-sm font-medium text-green-400">
                  ${model.inputPrice.toFixed(3)}
                </td>
                <td class="py-3 px-4 text-right font-mono text-sm text-(--color-text-secondary)">
                  ${model.outputPrice.toFixed(3)}
                </td>
                <td class="py-3 px-4 text-right hidden sm:table-cell">
                  <span class="font-mono text-xs text-(--color-text-muted)">{model.metaScore.toFixed(1)}</span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <p class="mt-6 text-sm text-(--color-text-secondary) max-w-3xl">
      Composite score is coverage-aware by design. Models with thin public benchmark coverage can still appear here, but they are
      penalized until enough benchmark evidence exists to trust the ranking.
    </p>

    <div class="mt-10 rounded-2xl border border-(--color-border) bg-(--color-bg-card) p-5 sm:p-6">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="text-[11px] font-semibold uppercase tracking-[0.28em] text-(--color-text-muted)">Explore the field</p>
          <h2 class="mt-2 text-2xl font-bold text-(--color-text-primary)">Search and filter the full ranked dataset</h2>
          <p class="mt-2 max-w-3xl text-sm leading-6 text-(--color-text-secondary)">
            The top tables are quick reads. This table is for actual decision-making when you want a specific lab, use case, release window, or pricing posture.
          </p>
        </div>
        <button
          type="button"
          id="leaderboard-reset"
          class="inline-flex rounded-full border border-(--color-border-strong) px-4 py-2 text-xs uppercase tracking-[0.16em] text-(--color-text-secondary) transition-colors hover:border-(--color-accent) hover:text-(--color-text-primary)"
        >
          Reset filters
        </button>
      </div>

      <div class="mt-5 grid gap-3 lg:grid-cols-5">
        <input
          id="leaderboard-search"
          type="search"
          placeholder="Search model or provider..."
          class="w-full rounded-full border border-(--color-border) bg-(--color-bg-primary) px-4 py-3 text-sm text-(--color-text-primary) placeholder:text-(--color-text-muted) focus:outline-none focus:border-(--color-accent)"
        />
        <select id="leaderboard-provider" class="w-full rounded-full border border-(--color-border) bg-(--color-bg-primary) px-4 py-3 text-sm text-(--color-text-primary) focus:outline-none focus:border-(--color-accent)">
          <option value="">All labs</option>
          {providerOptions.map((provider) => (
            <option value={provider}>{provider}</option>
          ))}
        </select>
        <select id="leaderboard-use-case" class="w-full rounded-full border border-(--color-border) bg-(--color-bg-primary) px-4 py-3 text-sm text-(--color-text-primary) focus:outline-none focus:border-(--color-accent)">
          <option value="">All use cases</option>
          {useCaseOptions.map((useCase) => (
            <option value={useCase}>{useCase}</option>
          ))}
        </select>
        <select id="leaderboard-signal" class="w-full rounded-full border border-(--color-border) bg-(--color-bg-primary) px-4 py-3 text-sm text-(--color-text-primary) focus:outline-none focus:border-(--color-accent)">
          <option value="">All signals</option>
          <option value="open">Open source only</option>
          <option value="api">API available</option>
          <option value="high-coverage">High coverage (60%+)</option>
          <option value="recent">Released in the last 180 days</option>
        </select>
        <select id="leaderboard-sort" class="w-full rounded-full border border-(--color-border) bg-(--color-bg-primary) px-4 py-3 text-sm text-(--color-text-primary) focus:outline-none focus:border-(--color-accent)">
          <option value="meta">Composite rank</option>
          <option value="value">Best value</option>
          <option value="cheap">Cheapest input</option>
          <option value="coverage">Highest coverage</option>
          <option value="recent">Newest release</option>
        </select>
      </div>

      <div class="mt-6 overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-(--color-border)">
              <th class="text-left py-3 px-3 text-(--color-text-muted) font-medium">Model</th>
              <th class="text-right py-3 px-3 text-(--color-text-muted) font-medium">Composite</th>
              <th class="text-right py-3 px-3 text-(--color-text-muted) font-medium">Coverage</th>
              <th class="text-left py-3 px-3 text-(--color-text-muted) font-medium">Best for</th>
              <th class="text-left py-3 px-3 text-(--color-text-muted) font-medium hidden md:table-cell">Released</th>
              <th class="text-right py-3 px-3 text-(--color-text-muted) font-medium">Price</th>
            </tr>
          </thead>
          <tbody id="leaderboard-explorer-body">
            {rankedModels.map((model) => (
              <tr
                class="border-b border-(--color-border)/50 hover:bg-(--color-bg-hover) transition-colors"
                data-leaderboard-row
                data-filter={`${model.name} ${model.provider} ${model.bestFor} ${model.modality.join(' ')}`.toLowerCase()}
                data-provider={model.provider}
                data-use-case={model.bestFor}
                data-open={model.openSource ? 'true' : 'false'}
                data-api={model.apiAvailable ? 'true' : 'false'}
                data-coverage={model.coverageRatio}
                data-meta={model.metaScore}
                data-value={model.valueScore}
                data-input={model.inputPrice}
                data-release={model.released ?? ''}
              >
                <td class="py-3 px-3">
                  <a href={`${base}models/${model.id}/`} class="flex items-center gap-2 text-(--color-text-primary) hover:text-(--color-accent) transition-colors">
                    <span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${model.providerColour}`}></span>
                    <span class="font-medium">{model.name}</span>
                  </a>
                  <p class="text-[10px] text-(--color-text-muted) mt-1">
                    {model.provider} / {formatContextWindow(model.contextWindow)} context
                  </p>
                </td>
                <td class="py-3 px-3 text-right">
                  <span class="font-mono font-medium text-(--color-accent)">{model.metaScore.toFixed(1)}</span>
                </td>
                <td class="py-3 px-3 text-right">
                  <span class="text-xs text-(--color-text-secondary)">{formatCoverage(model.coverageRatio)}</span>
                </td>
                <td class="py-3 px-3 text-(--color-text-secondary)">
                  <div>{model.bestFor}</div>
                  <div class="flex flex-wrap gap-1 mt-1">
                    {model.openSource ? <span class="badge badge-oss">Open</span> : null}
                    {model.apiAvailable ? <span class="badge">API</span> : null}
                  </div>
                </td>
                <td class="py-3 px-3 text-(--color-text-muted) hidden md:table-cell">
                  {formatReleaseDate(model.released)}
                </td>
                <td class="py-3 px-3 text-right font-mono text-xs text-(--color-text-secondary)">
                  {formatPricePair(model.inputPrice, model.outputPrice, model.openSource)}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div id="leaderboard-empty" class="hidden mt-4 rounded-xl border border-dashed border-(--color-border) bg-(--color-bg-primary) p-5 text-center text-sm text-(--color-text-secondary)">
        No models match the current filters. Reset them and widen the search.
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const tabs = document.querySelectorAll('.leaderboard-tab');
      const panels = document.querySelectorAll('.leaderboard-panel');
      const searchInput = document.getElementById('leaderboard-search');
      const providerInput = document.getElementById('leaderboard-provider');
      const useCaseInput = document.getElementById('leaderboard-use-case');
      const signalInput = document.getElementById('leaderboard-signal');
      const sortInput = document.getElementById('leaderboard-sort');
      const resetButton = document.getElementById('leaderboard-reset');
      const explorerBody = document.getElementById('leaderboard-explorer-body');
      const explorerRows = Array.from(document.querySelectorAll('[data-leaderboard-row]'));
      const emptyState = document.getElementById('leaderboard-empty');

      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const target = tab.getAttribute('data-tab');

          tabs.forEach((node) => node.classList.remove('active', 'bg-(--color-accent)/20', 'text-(--color-accent)'));
          tab.classList.add('active', 'bg-(--color-accent)/20', 'text-(--color-accent)');

          panels.forEach((panel) => panel.classList.add('hidden'));
          document.getElementById(`panel-${target}`)?.classList.remove('hidden');
        });
      });

      tabs[0]?.classList.add('bg-(--color-accent)/20', 'text-(--color-accent)');

      const applyExplorerFilters = () => {
        const query = (searchInput instanceof HTMLInputElement ? searchInput.value : '').toLowerCase().trim();
        const provider = providerInput instanceof HTMLSelectElement ? providerInput.value : '';
        const useCase = useCaseInput instanceof HTMLSelectElement ? useCaseInput.value : '';
        const signal = signalInput instanceof HTMLSelectElement ? signalInput.value : '';
        const sort = sortInput instanceof HTMLSelectElement ? sortInput.value : 'meta';
        const recentCutoff = new Date();
        recentCutoff.setDate(recentCutoff.getDate() - 180);

        for (const row of explorerRows) {
          const haystack = row.getAttribute('data-filter') || '';
          const matchesQuery = !query || haystack.includes(query);
          const matchesProvider = !provider || row.getAttribute('data-provider') === provider;
          const matchesUseCase = !useCase || row.getAttribute('data-use-case') === useCase;

          let matchesSignal = true;
          if (signal === 'open') matchesSignal = row.getAttribute('data-open') === 'true';
          if (signal === 'api') matchesSignal = row.getAttribute('data-api') === 'true';
          if (signal === 'high-coverage') matchesSignal = Number(row.getAttribute('data-coverage') || 0) >= 0.6;
          if (signal === 'recent') {
            const released = row.getAttribute('data-release') || '';
            matchesSignal = Boolean(released) && Date.parse(released) >= recentCutoff.getTime();
          }

          row.classList.toggle('hidden', !(matchesQuery && matchesProvider && matchesUseCase && matchesSignal));
        }

        const visibleRows = explorerRows.filter((row) => !row.classList.contains('hidden'));
        const sortedRows = [...visibleRows].sort((a, b) => {
          if (sort === 'value') {
            return Number(b.getAttribute('data-value') || 0) - Number(a.getAttribute('data-value') || 0);
          }
          if (sort === 'cheap') {
            return Number(a.getAttribute('data-input') || 0) - Number(b.getAttribute('data-input') || 0);
          }
          if (sort === 'coverage') {
            return Number(b.getAttribute('data-coverage') || 0) - Number(a.getAttribute('data-coverage') || 0);
          }
          if (sort === 'recent') {
            return Date.parse(b.getAttribute('data-release') || '') - Date.parse(a.getAttribute('data-release') || '');
          }
          return Number(b.getAttribute('data-meta') || 0) - Number(a.getAttribute('data-meta') || 0);
        });

        sortedRows.forEach((row) => explorerBody?.appendChild(row));
        emptyState?.classList.toggle('hidden', visibleRows.length > 0);
      };

      searchInput?.addEventListener('input', applyExplorerFilters);
      providerInput?.addEventListener('change', applyExplorerFilters);
      useCaseInput?.addEventListener('change', applyExplorerFilters);
      signalInput?.addEventListener('change', applyExplorerFilters);
      sortInput?.addEventListener('change', applyExplorerFilters);
      resetButton?.addEventListener('click', () => {
        if (searchInput instanceof HTMLInputElement) searchInput.value = '';
        if (providerInput instanceof HTMLSelectElement) providerInput.value = '';
        if (useCaseInput instanceof HTMLSelectElement) useCaseInput.value = '';
        if (signalInput instanceof HTMLSelectElement) signalInput.value = '';
        if (sortInput instanceof HTMLSelectElement) sortInput.value = 'meta';
        applyExplorerFilters();
      });

      applyExplorerFilters();
    })();
  </script>
</BaseLayout>
