---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

const lanes = [
  { href: `${base}academy/what-is-ai/`, title: '什么是 AI', note: '适合刚开始理解 AI 的读者，目前正文仍以英文为主。' },
  { href: `${base}academy/how-llms-work/`, title: '大语言模型如何工作', note: '理解 token、训练和 Transformer 的关键入口。' },
  { href: `${base}academy/what-is-a-harness/`, title: '什么是 harness', note: '和模型退化、工具链、代理质量直接相关。' },
];
---

<BaseLayout
  title="AI Academy 中文入口"
  description="AI Academy 的简体中文入口页，优先承载稳定的教育内容，并说明哪些内容仍以英文为准。"
  locale="zh-Hans"
  translationState="reviewed"
  translationNote="学院入口页已做中文审核，但许多深度课程暂时仍以英文正文为准。"
  alternateTranslations={{
    'en-GB': `${base}academy/`,
    es: `${base}es/academy/`,
    'pt-BR': `${base}pt-br/academy/`,
    'zh-Hans': `${base}zh-hans/academy/`,
  }}
  localeMenuLinks={{
    'en-GB': `${base}academy/`,
    es: `${base}es/academy/`,
    'pt-BR': `${base}pt-br/academy/`,
    'zh-Hans': `${base}zh-hans/academy/`,
  }}
>
  <section class="mx-auto max-w-5xl px-4 py-10 sm:px-6 lg:px-8">
    <nav class="mb-4 text-xs text-(--color-text-muted)" aria-label="Breadcrumb">
      <a href={`${base}zh-hans/`} class="hover:text-(--color-text-secondary) transition-colors">简体中文</a>
      <span class="mx-2">/</span>
      <span class="text-(--color-text-secondary)">AI 学院</span>
    </nav>
    <h1 class="text-4xl font-extrabold text-(--color-text-primary)">AI 学院</h1>
    <p class="mt-4 max-w-3xl text-lg text-(--color-text-secondary)">
      我们先把最值得长期保留的教育入口做出来，再逐步扩展到更多课程和参考页。这样既实用，也更容易长期维护。
    </p>
    <div class="mt-8 space-y-4">
      {lanes.map((lane) => (
        <a href={lane.href} class="glass-panel glass-panel-hover block rounded-[1.4rem] p-5">
          <h2 class="text-lg font-semibold text-(--color-text-primary)">{lane.title}</h2>
          <p class="mt-2 text-sm text-(--color-text-secondary)">{lane.note}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
