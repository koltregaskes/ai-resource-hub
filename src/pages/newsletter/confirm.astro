---
import BaseLayout from '../../layouts/BaseLayout.astro';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
---

<BaseLayout
  title="Newsletter Paused — The AI Resource Hub"
  description="The AI Resource Hub newsletter is currently paused. Use the live news page and RSS feed for updates."
>
  <section class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24 text-center">
    <div class="mb-6">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-(--color-warning)/20 mb-4">
        <svg class="w-8 h-8 text-(--color-warning)" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M4.93 19h14.14c1.54 0 2.5-1.67 1.73-3L13.73 4c-.77-1.33-2.69-1.33-3.46 0L3.2 16c-.77 1.33.19 3 1.73 3z" />
        </svg>
      </div>
      <h1 class="text-3xl sm:text-4xl font-extrabold text-(--color-text-primary) mb-3">
        Newsletter is paused
      </h1>
      <p class="text-(--color-text-secondary) text-lg mb-2">
        The site is live, but email signup is not part of the launch build.
      </p>
      <p class="text-(--color-text-muted) text-sm">
        For now, use the news page and RSS feed to follow updates as they land.
      </p>
    </div>

    <div class="mt-10 grid sm:grid-cols-3 gap-4">
      <a href={`${base}news/`} class="p-4 rounded-xl bg-(--color-bg-card) border border-(--color-border) hover:border-(--color-accent)/30 transition-colors group">
        <p class="text-sm font-semibold text-(--color-text-primary) group-hover:text-(--color-accent) transition-colors">News archive</p>
        <p class="text-xs text-(--color-text-muted) mt-1">Follow the public news stream</p>
      </a>
      <a href={`${base}rss.xml`} class="p-4 rounded-xl bg-(--color-bg-card) border border-(--color-border) hover:border-(--color-accent)/30 transition-colors group">
        <p class="text-sm font-semibold text-(--color-text-primary) group-hover:text-(--color-accent) transition-colors">RSS feed</p>
        <p class="text-xs text-(--color-text-muted) mt-1">Subscribe in your reader of choice</p>
      </a>
      <a href={`${base}leaderboard/`} class="p-4 rounded-xl bg-(--color-bg-card) border border-(--color-border) hover:border-(--color-accent)/30 transition-colors group">
        <p class="text-sm font-semibold text-(--color-text-primary) group-hover:text-(--color-accent) transition-colors">Leaderboard</p>
        <p class="text-xs text-(--color-text-muted) mt-1">Go straight to the data surfaces</p>
      </a>
    </div>

    <div class="mt-8">
      <a href={base} class="text-sm text-(--color-accent) hover:text-(--color-accent-hover) transition-colors">
        &larr; Back to homepage
      </a>
    </div>
  </section>
</BaseLayout>
