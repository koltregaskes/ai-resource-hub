---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { OFFICIAL_TOKEN_TOOLS } from '../../data/token-tools';
import { BENCHMARK_RESOURCES } from '../../data/benchmark-resources';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

interface AITool {
  name: string;
  url: string;
  category: string;
  description: string;
  pricing: string;
  tags: string[];
}

const siteUtilities = [
  {
    name: 'Pricing calculator',
    href: `${base}calculator/`,
    description: 'Estimate monthly API costs across tracked models.',
  },
  {
    name: 'Head-to-head compare',
    href: `${base}compare/head-to-head/`,
    description: 'Put several models side by side before choosing.',
  },
  {
    name: 'Tokenizer & token counter',
    href: `${base}tokenizer/`,
    description: 'Fast estimate plus official lab token-counting links.',
  },
  {
    name: 'Benchmark explorer',
    href: `${base}benchmarks/`,
    description: 'Browse the tests that power the ranking layer.',
  },
  {
    name: 'AI glossary',
    href: `${base}glossary/`,
    description: 'Look up jargon, abbreviations, and community terms.',
  },
];

const tokenTools = OFFICIAL_TOKEN_TOOLS;
const benchmarkResources = BENCHMARK_RESOURCES;

const tools: AITool[] = [
  { name: 'ChatGPT', url: 'https://chat.openai.com', category: 'chatbot', description: 'OpenAI chat product for writing, coding, browsing, and multimodal work.', pricing: 'Free / paid plans', tags: ['chat', 'coding', 'images'] },
  { name: 'Claude', url: 'https://claude.ai', category: 'chatbot', description: 'Anthropic assistant focused on reasoning, writing, analysis, and coding workflows.', pricing: 'Free / paid plans', tags: ['chat', 'coding', 'analysis'] },
  { name: 'Gemini', url: 'https://gemini.google.com', category: 'chatbot', description: 'Google assistant for chat, research, multimodal work, and workspace-adjacent tasks.', pricing: 'Free / paid plans', tags: ['chat', 'research', 'multimodal'] },
  { name: 'Grok', url: 'https://grok.x.ai', category: 'chatbot', description: 'xAI assistant with chat, search, and related consumer AI workflows.', pricing: 'Free / paid plans', tags: ['chat', 'real-time', 'images'] },
  { name: 'Perplexity', url: 'https://perplexity.ai', category: 'chatbot', description: 'AI search and research interface with citations and multiple model backends.', pricing: 'Free / paid plans', tags: ['search', 'research', 'citations'] },
  { name: 'Poe', url: 'https://poe.com', category: 'chatbot', description: 'Multi-model chat product that gives one interface for several labs and model families.', pricing: 'Free / paid plans', tags: ['chat', 'multi-model'] },
  { name: 'HuggingChat', url: 'https://huggingface.co/chat', category: 'chatbot', description: 'Open ecosystem chat product from Hugging Face with public and open-model focus.', pricing: 'Free', tags: ['chat', 'open-source'] },

  { name: 'GitHub Copilot', url: 'https://github.com/features/copilot', category: 'coding', description: 'AI pair programmer inside editors, pull requests, and related coding workflows.', pricing: 'Free / paid plans', tags: ['coding', 'IDE'] },
  { name: 'Cursor', url: 'https://cursor.com', category: 'coding', description: 'AI-first code editor focused on repo awareness, generation, and multi-file work.', pricing: 'Free / paid plans', tags: ['coding', 'IDE', 'editor'] },
  { name: 'Claude Code', url: 'https://docs.anthropic.com/en/docs/claude-code', category: 'coding', description: 'Terminal-native coding agent for repo changes, debugging, and long-running tasks.', pricing: 'API pricing', tags: ['coding', 'terminal', 'agents'] },
  { name: 'Windsurf', url: 'https://windsurf.com', category: 'coding', description: 'AI-powered editor and coding environment for prompt-driven app and feature work.', pricing: 'Free / paid plans', tags: ['coding', 'IDE'] },
  { name: 'Replit', url: 'https://replit.com', category: 'coding', description: 'Cloud IDE with AI assistance for building, iterating, and deploying apps.', pricing: 'Free / paid plans', tags: ['coding', 'deployment', 'cloud'] },
  { name: 'v0', url: 'https://v0.dev', category: 'coding', description: 'Prompt-to-UI product for React and frontend generation.', pricing: 'Free / paid plans', tags: ['coding', 'UI', 'React'] },
  { name: 'Bolt.new', url: 'https://bolt.new', category: 'coding', description: 'Browser-based product for generating and iterating on full-stack apps from prompts.', pricing: 'Free / paid plans', tags: ['coding', 'full-stack', 'deployment'] },
  { name: 'Lovable', url: 'https://lovable.dev', category: 'coding', description: 'Prompt-driven app builder for quickly shipping product prototypes and real apps.', pricing: 'Free / paid plans', tags: ['coding', 'apps', 'no-code'] },

  { name: 'LM Studio', url: 'https://lmstudio.ai', category: 'local', description: 'Desktop app for downloading, chatting with, and serving local models on your own machine.', pricing: 'Free', tags: ['local', 'gguf', 'desktop'] },
  { name: 'Ollama', url: 'https://ollama.com', category: 'local', description: 'Simple terminal-first way to pull and run local models with an API layer on top.', pricing: 'Free', tags: ['local', 'terminal', 'open-source'] },
  { name: 'llama.cpp', url: 'https://github.com/ggml-org/llama.cpp', category: 'local', description: 'Core open-source runtime behind much of the modern GGUF local-model ecosystem.', pricing: 'Free', tags: ['local', 'gguf', 'runtime'] },
  { name: 'Open WebUI', url: 'https://openwebui.com', category: 'local', description: 'Self-hostable web front end for local and private AI chat setups.', pricing: 'Free', tags: ['local', 'ui', 'self-hosted'] },
  { name: 'MLX', url: 'https://github.com/ml-explore/mlx', category: 'local', description: 'Apple Silicon-focused machine learning framework relevant for local model running and tuning on Macs.', pricing: 'Free', tags: ['local', 'apple', 'open-source'] },
  { name: 'Jan', url: 'https://jan.ai', category: 'local', description: 'Desktop product for local and remote model chat with an easy consumer-style interface.', pricing: 'Free', tags: ['local', 'desktop', 'chat'] },
  { name: 'KoboldCpp', url: 'https://github.com/LostRuins/koboldcpp', category: 'local', description: 'Single-binary local model runner popular for offline chat and lightweight GGUF serving.', pricing: 'Free', tags: ['local', 'offline', 'gguf'] },

  { name: 'Midjourney', url: 'https://midjourney.com', category: 'image', description: 'High-profile AI image product known for strong visual quality and artistic output.', pricing: 'Paid plans', tags: ['images', 'art'] },
  { name: 'DALL-E', url: 'https://openai.com/dall-e-3', category: 'image', description: 'OpenAI image-generation product family across ChatGPT and API surfaces.', pricing: 'Included / API pricing', tags: ['images', 'editing'] },
  { name: 'Stable Diffusion', url: 'https://stability.ai', category: 'image', description: 'Stable Diffusion image family, important both as a hosted option and a local/open model ecosystem.', pricing: 'Free (local) / API pricing', tags: ['images', 'open-source'] },
  { name: 'Ideogram', url: 'https://ideogram.ai', category: 'image', description: 'Image-generation product known for text rendering and design-style outputs.', pricing: 'Free / paid plans', tags: ['images', 'text-rendering'] },
  { name: 'Flux', url: 'https://blackforestlabs.ai', category: 'image', description: 'Black Forest Labs image model family used in both hosted and open workflows.', pricing: 'API / open model access', tags: ['images', 'open-source'] },
  { name: 'Leonardo AI', url: 'https://leonardo.ai', category: 'image', description: 'Image and asset creation product for design, iteration, and creative workflows.', pricing: 'Free / paid plans', tags: ['images', 'design'] },

  { name: 'Sora', url: 'https://sora.com', category: 'video', description: 'OpenAI video-generation product for cinematic text-to-video and creative scene generation.', pricing: 'Included / paid plans', tags: ['video', 'generation'] },
  { name: 'Runway', url: 'https://runwayml.com', category: 'video', description: 'AI video suite for generation, editing, motion controls, and production workflows.', pricing: 'Paid plans', tags: ['video', 'editing'] },
  { name: 'Pika', url: 'https://pika.art', category: 'video', description: 'Consumer-friendly AI video product for generation and stylised effects.', pricing: 'Free / paid plans', tags: ['video', 'effects'] },
  { name: 'Kling AI', url: 'https://klingai.com', category: 'video', description: 'AI video product focused on generation and motion control.', pricing: 'Free / paid plans', tags: ['video', 'generation'] },
  { name: 'Veo', url: 'https://deepmind.google/technologies/veo/', category: 'video', description: 'Google DeepMind video model family for cinematic generation workflows.', pricing: 'API pricing', tags: ['video', 'generation'] },
  { name: 'Luma Dream Machine', url: 'https://lumalabs.ai', category: 'video', description: 'Fast video-generation product with image-to-video and 3D-adjacent creative workflows.', pricing: 'Free / paid plans', tags: ['video', '3D'] },

  { name: 'ElevenLabs', url: 'https://elevenlabs.io', category: 'voice', description: 'Voice product for synthesis, cloning, dubbing, and speech generation.', pricing: 'Free / paid plans', tags: ['voice', 'tts', 'cloning'] },
  { name: 'Suno', url: 'https://suno.com', category: 'voice', description: 'Music-generation product for creating full songs from prompts.', pricing: 'Free / paid plans', tags: ['music', 'generation'] },
  { name: 'Udio', url: 'https://udio.com', category: 'voice', description: 'Music-creation product for text-to-song workflows across styles and genres.', pricing: 'Free / paid plans', tags: ['music', 'generation'] },
  { name: 'Descript', url: 'https://descript.com', category: 'voice', description: 'AI-powered editing environment for audio and video production.', pricing: 'Free / paid plans', tags: ['audio', 'editing', 'podcasts'] },

  { name: 'Jasper', url: 'https://jasper.ai', category: 'writing', description: 'Marketing-oriented writing and content automation platform.', pricing: 'Paid plans', tags: ['writing', 'marketing'] },
  { name: 'Copy.ai', url: 'https://copy.ai', category: 'writing', description: 'AI copywriting and workflow product for sales, marketing, and operations use cases.', pricing: 'Free / paid plans', tags: ['writing', 'marketing'] },
  { name: 'Grammarly', url: 'https://grammarly.com', category: 'writing', description: 'Writing assistant for grammar, tone, and clarity with AI-enhanced drafting support.', pricing: 'Free / paid plans', tags: ['writing', 'grammar'] },
  { name: 'NotebookLM', url: 'https://notebooklm.google.com', category: 'writing', description: 'Source-grounded research and note product with summary and audio-overview workflows.', pricing: 'Free', tags: ['research', 'notes', 'podcasts'] },
  { name: 'Notion AI', url: 'https://notion.so/product/ai', category: 'writing', description: 'Workspace-native AI features inside Notion for writing, summarising, and organising.', pricing: 'Paid add-on', tags: ['writing', 'productivity'] },

  { name: 'Elicit', url: 'https://elicit.com', category: 'research', description: 'AI research assistant for academic literature, extraction, and synthesis.', pricing: 'Free / paid plans', tags: ['research', 'academic'] },
  { name: 'Consensus', url: 'https://consensus.app', category: 'research', description: 'Research search product focused on evidence-backed answers from the literature.', pricing: 'Free / paid plans', tags: ['research', 'academic'] },
  { name: 'Semantic Scholar', url: 'https://semanticscholar.org', category: 'research', description: 'Academic search platform with ML-assisted discovery and paper summaries.', pricing: 'Free', tags: ['research', 'academic'] },

  { name: 'OpenRouter', url: 'https://openrouter.ai', category: 'devtools', description: 'Unified API for many model providers with routing, fallbacks, and cost tracking.', pricing: 'Pay per use', tags: ['api', 'multi-model'] },
  { name: 'LangChain', url: 'https://langchain.com', category: 'devtools', description: 'Framework for building LLM applications, chains, agents, and RAG workflows.', pricing: 'Free / paid cloud', tags: ['framework', 'agents'] },
  { name: 'LlamaIndex', url: 'https://llamaindex.ai', category: 'devtools', description: 'Data and retrieval framework for connecting LLMs to your own content.', pricing: 'Free / paid cloud', tags: ['framework', 'rag'] },
  { name: 'Hugging Face', url: 'https://huggingface.co', category: 'devtools', description: 'Open model hub for models, datasets, Spaces, and wider ML tooling.', pricing: 'Free / paid plans', tags: ['models', 'datasets', 'open-source'] },
  { name: 'Replicate', url: 'https://replicate.com', category: 'devtools', description: 'Hosted platform for running open models via API and serverless compute.', pricing: 'Pay per use', tags: ['api', 'deployment'] },
  { name: 'Together AI', url: 'https://together.ai', category: 'devtools', description: 'Inference platform focused on open models, fine-tuning, and serverless endpoints.', pricing: 'Pay per use', tags: ['api', 'open-source', 'fine-tuning'] },
  { name: 'Fireworks AI', url: 'https://fireworks.ai', category: 'devtools', description: 'High-performance inference platform for model APIs and compound systems.', pricing: 'Pay per use', tags: ['api', 'inference'] },
  { name: 'Groq', url: 'https://groq.com', category: 'devtools', description: 'Inference platform known for low-latency hosted model access.', pricing: 'Free / pay per use', tags: ['api', 'speed', 'hardware'] },

  { name: 'Microsoft Copilot', url: 'https://copilot.microsoft.com', category: 'productivity', description: 'AI assistant layer across Microsoft productivity products and enterprise workflows.', pricing: 'Paid plans', tags: ['productivity', 'office'] },
  { name: 'Google Workspace AI', url: 'https://workspace.google.com/solutions/ai/', category: 'productivity', description: 'Gemini-powered features across Docs, Sheets, Slides, Gmail, and related tools.', pricing: 'Included / paid plans', tags: ['productivity', 'office'] },
  { name: 'Zapier AI', url: 'https://zapier.com/ai', category: 'productivity', description: 'Automation product with AI-assisted workflow generation and orchestration.', pricing: 'Free / paid plans', tags: ['automation', 'workflows'] },
  { name: 'Otter.ai', url: 'https://otter.ai', category: 'productivity', description: 'Meeting transcription and note product for calls, summaries, and action items.', pricing: 'Free / paid plans', tags: ['transcription', 'meetings'] },
];

const categoryConfig: Record<string, { label: string }> = {
  chatbot: { label: 'Chatbots & AI Assistants' },
  coding: { label: 'Coding Assistants & IDEs' },
  local: { label: 'Local AI & Open Source' },
  image: { label: 'Image Generation' },
  video: { label: 'Video Generation' },
  voice: { label: 'Voice, Music & Audio' },
  writing: { label: 'Writing & Content' },
  research: { label: 'Research & Analysis' },
  devtools: { label: 'Developer Tools & APIs' },
  productivity: { label: 'Productivity & Business' },
};

const categoryOrder = ['chatbot', 'coding', 'local', 'image', 'video', 'voice', 'writing', 'research', 'devtools', 'productivity'];
const grouped = categoryOrder.map((category) => ({
  category,
  config: categoryConfig[category],
  tools: tools.filter((tool) => tool.category === category),
}));
---

<BaseLayout
  title="AI Tools Directory - The AI Resource Hub"
  description="Curated directory of important AI tools across chat, coding, local models, media generation, research, developer workflows, and official token counting resources."
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    <nav class="text-xs text-(--color-text-muted) mb-4" aria-label="Breadcrumb">
      <a href={base} class="hover:text-(--color-text-secondary) transition-colors">Home</a>
      <span class="mx-2">/</span>
      <span class="text-(--color-text-secondary)">AI Tools</span>
    </nav>

    <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_360px] mb-8">
      <div class="rounded-[2rem] border border-(--color-border) bg-(--color-bg-secondary) p-6 sm:p-8">
        <p class="text-[11px] font-semibold uppercase tracking-[0.28em] text-(--color-text-muted)">Tool stack</p>
        <h1 class="mt-3 text-4xl font-black font-display text-(--color-text-primary)">
          Built-in utilities plus a curated map of the wider AI tool market.
        </h1>
        <p class="mt-4 max-w-2xl text-(--color-text-secondary)">
          Use this page for three things: the working tools already built into this site, the official tokenizer and token-counting resources from major labs, and a curated shortlist of important external AI products.
        </p>
      </div>

      <div class="rounded-[2rem] border border-(--color-border) bg-(--color-bg-card) p-6">
        <p class="text-[11px] font-semibold uppercase tracking-[0.28em] text-(--color-text-muted)">Use this site first</p>
        <div class="mt-4 space-y-3">
          {siteUtilities.map((tool) => (
            <a href={tool.href} class="block rounded-2xl border border-(--color-border) bg-(--color-bg-primary)/70 p-4 transition-colors hover:border-(--color-border-hover) hover:bg-(--color-bg-tertiary)">
              <p class="text-sm font-semibold text-(--color-text-primary)">{tool.name}</p>
              <p class="mt-1 text-xs text-(--color-text-secondary)">{tool.description}</p>
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="rounded-[1.75rem] border border-(--color-border) bg-(--color-bg-secondary) p-5 sm:p-6 mb-8">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="text-sm font-semibold text-(--color-text-primary)">Official tokenizer and token-counting resources</p>
          <p class="text-xs text-(--color-text-muted) mt-1">
            Verified links for model-specific counting. Some are interactive tools, while others are API endpoints or docs-backed workflows.
          </p>
        </div>
        <a href={`${base}tokenizer/`} class="text-xs text-(--color-accent) hover:text-(--color-accent-hover)">Open the tokenizer page</a>
      </div>
      <div class="grid gap-3 mt-5 md:grid-cols-2 xl:grid-cols-3">
        {tokenTools.map((tool) => (
          <a
            href={tool.url}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-2xl border border-(--color-border) bg-(--color-bg-card) p-4 transition-colors hover:border-(--color-border-hover) hover:bg-(--color-bg-tertiary)"
          >
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-(--color-text-muted)">{tool.lab}</p>
                <p class="mt-2 text-sm font-semibold text-(--color-text-primary)">{tool.name}</p>
              </div>
              <span class="rounded-full bg-(--color-bg-primary) px-2 py-1 text-[10px] text-(--color-text-muted)">{tool.access}</span>
            </div>
            <p class="mt-3 text-xs text-(--color-text-secondary)">{tool.description}</p>
            {tool.notes && <p class="mt-3 text-[11px] text-(--color-text-muted)">{tool.notes}</p>}
          </a>
        ))}
      </div>
    </div>

    <div class="rounded-[1.75rem] border border-(--color-border) bg-(--color-bg-secondary) p-5 sm:p-6 mb-8">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="text-sm font-semibold text-(--color-text-primary)">Benchmark trackers and eval resources</p>
          <p class="text-xs text-(--color-text-muted) mt-1">
            External sources worth checking when you want deeper benchmark explorers, repeated agent measurements, and degradation tracking.
          </p>
        </div>
        <a href={`${base}benchmarks/`} class="text-xs text-(--color-accent) hover:text-(--color-accent-hover)">Open benchmark desk</a>
      </div>
      <div class="grid gap-3 mt-5 lg:grid-cols-2">
        {benchmarkResources.map((resource) => (
          <article class="rounded-2xl border border-(--color-border) bg-(--color-bg-card) p-5">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div>
                <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-(--color-text-muted)">{resource.category}</p>
                <h2 class="mt-2 text-base font-semibold text-(--color-text-primary)">{resource.name}</h2>
              </div>
              <span class="rounded-full bg-(--color-bg-primary) px-2 py-1 text-[10px] text-(--color-text-muted)">{resource.access}</span>
            </div>
            <p class="mt-3 text-sm text-(--color-text-secondary)">{resource.description}</p>
            {resource.notes && <p class="mt-3 text-[11px] text-(--color-text-muted)">{resource.notes}</p>}
            <ul class="mt-4 space-y-2 text-xs text-(--color-text-secondary)">
              {resource.highlights.map((highlight) => (
                <li class="flex gap-2">
                  <span class="mt-[0.35rem] h-1.5 w-1.5 shrink-0 rounded-full bg-(--color-accent)"></span>
                  <span>{highlight}</span>
                </li>
              ))}
            </ul>
            <div class="mt-4 flex flex-wrap gap-2">
              {resource.links.map((link) => (
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-xs px-3 py-1.5 rounded-full font-medium bg-(--color-bg-tertiary) text-(--color-text-secondary) hover:bg-(--color-accent)/20 hover:text-(--color-accent) transition-colors"
                >
                  {link.label}
                </a>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>

    <div class="rounded-[1.75rem] border border-(--color-border) bg-(--color-bg-secondary) p-5 sm:p-6 mb-8">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
        <div>
          <p class="text-sm font-semibold text-(--color-text-primary)">Filter the external tool list</p>
          <p class="text-xs text-(--color-text-muted) mt-1">Search by name, category, or tag. Category chips jump you straight to the section.</p>
        </div>
        <div class="grid gap-3 w-full lg:w-auto lg:grid-cols-[minmax(0,320px)_220px]">
          <input
            id="tool-search"
            type="search"
            placeholder="Search tools, tags, or categories..."
            class="w-full rounded-full border border-(--color-border) bg-(--color-bg-primary) px-4 py-3 text-sm text-(--color-text-primary) placeholder:text-(--color-text-muted) focus:outline-none focus:border-(--color-border-hover)"
          />
          <select
            id="tool-category-filter"
            class="w-full rounded-full border border-(--color-border) bg-(--color-bg-primary) px-4 py-3 text-sm text-(--color-text-primary) focus:outline-none focus:border-(--color-border-hover)"
          >
            <option value="">All tool types</option>
            {grouped.map((group) => (
              <option value={group.category}>{group.config.label}</option>
            ))}
          </select>
        </div>
      </div>

      <div class="flex flex-wrap gap-2 mt-5">
        {grouped.map((group) => (
          <a href={`#${group.category}`} class="text-xs px-3 py-1.5 rounded-full font-medium bg-(--color-bg-tertiary) text-(--color-text-secondary) hover:bg-(--color-accent)/20 hover:text-(--color-accent) transition-colors">
            {group.config.label} ({group.tools.length})
          </a>
        ))}
      </div>
    </div>

    {grouped.map((group) => (
      <div class="mb-10" id={group.category} data-tool-group>
        <h2 class="text-lg font-bold text-(--color-text-primary) mb-4">
          {group.config.label}
        </h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {group.tools.map((tool) => (
            <a
              href={tool.url}
              target="_blank"
              rel="noopener noreferrer"
              class="p-4 rounded-xl bg-(--color-bg-card) border border-(--color-border) hover:border-(--color-border-hover) transition-colors group"
              data-tool-card
              data-tool-category={tool.category}
              data-tool-filter={`${tool.name} ${tool.category} ${tool.description} ${tool.tags.join(' ')}`.toLowerCase()}
            >
              <div class="flex items-start justify-between gap-2 mb-2">
                <h3 class="font-semibold text-(--color-text-primary) group-hover:text-(--color-accent) transition-colors">
                  {tool.name}
                </h3>
                <svg class="w-4 h-4 text-(--color-text-muted) group-hover:text-(--color-accent) transition-colors shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </div>
              <p class="text-xs text-(--color-text-secondary) mb-3 line-clamp-2">
                {tool.description}
              </p>
              <div class="flex items-center justify-between">
                <span class="text-xs font-medium text-(--color-accent)">
                  {tool.pricing}
                </span>
                <div class="flex gap-1">
                  {tool.tags.slice(0, 2).map((tag) => (
                    <span class="text-[10px] px-1.5 py-0.5 rounded bg-(--color-bg-tertiary) text-(--color-text-muted)">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    ))}

    <div class="p-5 rounded-xl bg-(--color-bg-card) border border-(--color-border)">
      <h2 class="text-sm font-semibold text-(--color-accent) mb-2">Choosing the right tool</h2>
      <ul class="text-sm text-(--color-text-secondary) space-y-1 list-disc list-inside">
        <li>Most AI chatbots offer free tiers, so it is worth trying several before paying for one default.</li>
        <li>For coding, Cursor and Claude Code are strong starting points if you want fast repo-aware assistance.</li>
        <li>For local models, start with LM Studio or Ollama before moving to lower-level runtimes like llama.cpp or MLX.</li>
        <li>Use official token-counting tools when prompt cost or context fit really matters.</li>
        <li>Check our <a href={`${base}compare/llm/`} class="text-(--color-accent) hover:text-(--color-accent-hover)">LLM comparison</a> for detailed pricing and benchmark data.</li>
      </ul>
    </div>
  </section>

  <script>
    const searchInput = document.getElementById('tool-search');
    const categoryFilter = document.getElementById('tool-category-filter');
    const cards = Array.from(document.querySelectorAll('[data-tool-card]'));
    const groups = Array.from(document.querySelectorAll('[data-tool-group]'));

    function updateToolFilter() {
      const query = searchInput instanceof HTMLInputElement ? searchInput.value.toLowerCase().trim() : '';
      const category = categoryFilter instanceof HTMLSelectElement ? categoryFilter.value : '';

      cards.forEach((card) => {
        const haystack = card.getAttribute('data-tool-filter') || '';
        const matchesQuery = !query || haystack.includes(query);
        const matchesCategory = !category || card.getAttribute('data-tool-category') === category;
        const matches = matchesQuery && matchesCategory;
        card.classList.toggle('hidden', !matches);
      });

      groups.forEach((group) => {
        const visibleCards = group.querySelectorAll('[data-tool-card]:not(.hidden)');
        group.classList.toggle('hidden', visibleCards.length === 0);
      });
    }

    searchInput?.addEventListener('input', updateToolFilter);
    categoryFilter?.addEventListener('change', updateToolFilter);
  </script>
</BaseLayout>
