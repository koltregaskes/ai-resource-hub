---
import BaseLayout from '../../layouts/BaseLayout.astro';
import UnsupportedSyntheticSurface from '../../components/leaderboards/UnsupportedSyntheticSurface.astro';
import { getSyntheticLeaderboardView } from '../../data/synthetic-leaderboards';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const view = getSyntheticLeaderboardView('creative-writing', 12);
const benchmarkBlurbs = {
  'creative-writing-bench': 'Creative-writing benchmark family for storytelling, style control, and long-form generation quality.',
  'wildbench-creative': 'Prompt-heavy creative evaluation lane focused on originality, coherence, and prose quality.',
};
---

<BaseLayout title="Best AI Models for Creative Writing - The AI Resource Hub" description="Tracking creative-writing benchmark coverage honestly until the canonical evidence layer is ready.">
  <UnsupportedSyntheticSurface
    base={base}
    title="Best AI Models for Creative Writing"
    description="Creative-writing model recommendations need stronger canonical evidence than we currently have. This page now tracks the benchmark set and the models we are watching instead of implying a ranked winner list."
    view={view}
    benchmarkBlurbs={benchmarkBlurbs}
    relatedLinks={[
      { href: `${base}leaderboard/`, label: 'Leaderboard desk' },
      { href: `${base}open-source/`, label: 'Open source models' },
      { href: `${base}compare/head-to-head/`, label: 'Compare head-to-head' },
    ]}
  />
</BaseLayout>
