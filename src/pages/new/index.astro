---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { modelReleaseDesk } from '../../data/model-release-desk.generated';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

const releases = [...modelReleaseDesk.releases];
const readyForEditor = releases.filter((release) => release.draftStatus === 'ready_for_editor');
const openSourceReleases = releases.filter((release) => release.openSource);

const priorityMeta = {
  high: {
    label: 'High priority',
    classes: 'border-rose-500/35 bg-rose-500/12 text-rose-100',
  },
  watch: {
    label: 'Watch',
    classes: 'border-amber-500/35 bg-amber-500/12 text-amber-100',
  },
  backfill: {
    label: 'Backfill',
    classes: 'border-slate-500/35 bg-slate-500/12 text-slate-200',
  },
} as const;

const draftStatusMeta = {
  ready_for_editor: {
    label: 'Ready for editor',
    classes: 'border-emerald-500/35 bg-emerald-500/12 text-emerald-100',
  },
  needs_research: {
    label: 'Needs research',
    classes: 'border-sky-500/35 bg-sky-500/12 text-sky-100',
  },
  watch_only: {
    label: 'Watch only',
    classes: 'border-slate-500/35 bg-slate-500/12 text-slate-200',
  },
} as const;

function formatTokens(tokens: number): string {
  if (!tokens) return 'N/A';
  if (tokens >= 1_000_000) return `${(tokens / 1_000_000).toFixed(tokens % 1_000_000 === 0 ? 0 : 1)}M`;
  if (tokens >= 1_000) return `${(tokens / 1_000).toFixed(tokens % 1_000 === 0 ? 0 : 1)}K`;
  return String(tokens);
}

function formatPrice(inputPrice: number, outputPrice: number): string {
  if (inputPrice <= 0 && outputPrice <= 0) return 'Pricing not tracked yet';
  return `$${inputPrice.toFixed(2)} in / $${outputPrice.toFixed(2)} out per 1M`;
}

function formatDate(date: string | null): string {
  if (!date) return 'Unknown release date';
  return new Date(date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}

function formatCountLabel(value: number, singular: string, pluralForm = `${singular}s`): string {
  return `${value} ${value === 1 ? singular : pluralForm}`;
}
---

<BaseLayout
  title="Model Release Desk - The AI Resource Hub"
  description="Tracked model launches, editor-ready release briefs, and source-first coverage for the latest AI model releases."
>
  <section class="max-w-[1450px] mx-auto px-4 py-8 sm:px-6 sm:py-12 lg:px-8">
    <nav class="mb-4 text-xs text-(--color-text-muted)" aria-label="Breadcrumb">
      <a href={base} class="transition-colors hover:text-(--color-text-secondary)">Home</a>
      <span class="mx-2">/</span>
      <span class="text-(--color-text-secondary)">Model Release Desk</span>
    </nav>

    <div class="relative overflow-hidden rounded-[34px] border border-(--color-border-strong) bg-(--color-bg-secondary) shadow-[0_24px_64px_rgba(0,0,0,0.16)] mb-10">
      <div class="hero-ruling opacity-35"></div>
      <div class="editorial-burst editorial-burst-left"></div>
      <div class="editorial-burst editorial-burst-right"></div>
      <div class="relative grid gap-8 px-6 py-8 sm:px-8 lg:grid-cols-[minmax(0,1.45fr)_minmax(19rem,0.92fr)] lg:items-end lg:px-10 lg:py-10">
        <div class="max-w-3xl">
          <p class="mb-3 text-[11px] uppercase tracking-[0.3em] text-(--color-accent-muted)">Release Coverage Desk</p>
          <h1 class="max-w-3xl text-3xl font-black leading-[1.02] text-(--color-text-primary) sm:text-4xl lg:text-5xl">
            Track launches, prep editor-ready briefs, and keep the release narrative honest.
          </h1>
          <p class="mt-4 max-w-2xl text-sm leading-relaxed text-(--color-text-secondary) sm:text-base">
            This desk exists so we can react quickly when a new model lands. Every entry starts with the official source, folds in benchmark signal and outside coverage, then pushes an editor-ready brief into the queue before anything is turned into a published post.
            The brief format is designed to turn into a clean launch post or thread, not just a pile of notes.
          </p>
          <div class="mt-5 flex flex-wrap gap-3 text-xs text-(--color-text-muted)">
            <span class="badge">Generated {new Date(modelReleaseDesk.generatedAt).toLocaleString('en-GB', { dateStyle: 'medium', timeStyle: 'short' })}</span>
            <span class="badge">{modelReleaseDesk.releaseWindowDays}-day release window</span>
            <span class="badge">{modelReleaseDesk.relatedStoryWindowDays}-day story lookback</span>
          </div>
        </div>

        <div class="glass-panel rounded-[28px] p-5">
          <p class="text-[11px] uppercase tracking-[0.26em] text-(--color-text-muted)">Workflow</p>
          <div class="mt-4 space-y-3 text-sm leading-relaxed text-(--color-text-secondary)">
            <p><span class="font-semibold text-(--color-text-primary)">1.</span> Detect new releases from the canonical model catalog and current registry.</p>
            <p><span class="font-semibold text-(--color-text-primary)">2.</span> Pull official URLs, benchmark evidence, and routed technical coverage into one brief.</p>
            <p><span class="font-semibold text-(--color-text-primary)">3.</span> Generate a draft file for editor review before anything goes live.</p>
            <p><span class="font-semibold text-(--color-text-primary)">4.</span> Publish only after the brief has been checked against official sources and outside evidence.</p>
          </div>
        </div>
      </div>
    </div>

    <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4 mb-10">
      <div class="glass-panel rounded-[24px] p-5">
        <p class="text-[11px] uppercase tracking-[0.24em] text-(--color-text-muted)">Tracked releases</p>
        <div class="mt-3 text-3xl font-black text-(--color-text-primary)">{modelReleaseDesk.stats.totalReleases}</div>
        <p class="mt-2 text-xs text-(--color-text-muted)">LLM releases in the current editorial window.</p>
      </div>
      <div class="glass-panel rounded-[24px] p-5">
        <p class="text-[11px] uppercase tracking-[0.24em] text-(--color-text-muted)">High priority</p>
        <div class="mt-3 text-3xl font-black text-(--color-text-primary)">{modelReleaseDesk.stats.highPriority}</div>
        <p class="mt-2 text-xs text-(--color-text-muted)">Recent or especially urgent launches that deserve quick coverage.</p>
      </div>
      <div class="glass-panel rounded-[24px] p-5">
        <p class="text-[11px] uppercase tracking-[0.24em] text-(--color-text-muted)">Ready for editor</p>
        <div class="mt-3 text-3xl font-black text-(--color-text-primary)">{modelReleaseDesk.stats.readyForEditor}</div>
        <p class="mt-2 text-xs text-(--color-text-muted)">Briefs with enough source signal to hand over immediately.</p>
      </div>
      <div class="glass-panel rounded-[24px] p-5">
        <p class="text-[11px] uppercase tracking-[0.24em] text-(--color-text-muted)">Open / local angle</p>
        <div class="mt-3 text-3xl font-black text-(--color-text-primary)">{modelReleaseDesk.stats.openSource}</div>
        <p class="mt-2 text-xs text-(--color-text-muted)">Tracked releases that matter for open-weight or local-model coverage.</p>
      </div>
    </div>

    <div class="grid gap-4 xl:grid-cols-[minmax(0,1.55fr)_minmax(18rem,0.95fr)] mb-12">
      <div class="rounded-[28px] border border-(--color-border) bg-(--color-bg-card) p-6">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between mb-5">
          <div>
            <p class="text-[11px] uppercase tracking-[0.28em] text-(--color-text-muted)">Editor Queue</p>
            <h2 class="mt-2 text-2xl font-black text-(--color-text-primary)">Briefs that are ready to turn into posts</h2>
          </div>
          <span class="badge">{readyForEditor.length} ready now</span>
        </div>

        <div class="space-y-4">
          {readyForEditor.slice(0, 8).map((release) => (
            <article class="rounded-[24px] border border-(--color-border) bg-(--color-bg-tertiary) p-5">
              <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                <div class="min-w-0 flex-1">
                  <div class="flex flex-wrap items-center gap-2">
                    <span class={`rounded-full border px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] ${priorityMeta[release.priority].classes}`}>
                      {priorityMeta[release.priority].label}
                    </span>
                    <span class={`rounded-full border px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] ${draftStatusMeta[release.draftStatus].classes}`}>
                      {draftStatusMeta[release.draftStatus].label}
                    </span>
                    <span class="badge">{release.releaseDateLabel}</span>
                  </div>

                  <div class="mt-3 flex items-center gap-2">
                    <span class="h-3 w-3 rounded-full shrink-0" style={`background-color: ${release.providerColour}`}></span>
                    <h3 class="text-xl font-bold text-(--color-text-primary)">{release.modelName}</h3>
                  </div>
                  <p class="mt-1 text-sm text-(--color-text-muted)">{release.providerName} / {formatCountLabel(Number(release.ageDays), 'day')} ago</p>
                  <p class="mt-3 max-w-3xl text-sm leading-relaxed text-(--color-text-secondary)">{release.summary}</p>

                  <div class="mt-4 flex flex-wrap gap-2">
                    {release.benchmarkHighlights.slice(0, 3).map((benchmark) => (
                      <span class="rounded-full border border-(--color-border) bg-(--color-bg-primary)/70 px-3 py-1 text-[11px] text-(--color-text-secondary)">
                        {benchmark.benchmark_name}: {benchmark.score}{benchmark.scale_max > 0 ? `/${benchmark.scale_max}` : ''}
                      </span>
                    ))}
                    {release.openSource && (
                      <span class="rounded-full border border-emerald-500/25 bg-emerald-500/10 px-3 py-1 text-[11px] text-emerald-100">Open / local angle</span>
                    )}
                    {!release.apiAvailable && (
                      <span class="rounded-full border border-amber-500/25 bg-amber-500/10 px-3 py-1 text-[11px] text-amber-100">Limited access</span>
                    )}
                  </div>
                </div>

                <div class="w-full rounded-[22px] border border-(--color-border) bg-(--color-bg-primary)/70 p-4 lg:max-w-[18rem]">
                  <p class="text-[11px] uppercase tracking-[0.22em] text-(--color-text-muted)">Draft handoff</p>
                  <div class="mt-3 space-y-2 text-sm text-(--color-text-secondary)">
                    <p>{formatCountLabel(Number(release.storyCount), 'related story', 'related stories')} routed in</p>
                    <p>{formatCountLabel(Number(release.benchmarkCount), 'benchmark signal')} tracked</p>
                    <p>{formatCountLabel(Number(release.sourceCount), 'source')} attached</p>
                  </div>
                  <div class="mt-4 rounded-2xl border border-(--color-border) bg-(--color-bg-card) px-3 py-2">
                    <p class="text-[11px] uppercase tracking-[0.18em] text-(--color-text-muted)">Draft file</p>
                    <p class="mt-1 break-all font-mono text-[11px] text-(--color-text-secondary)">{release.draftPath}</p>
                  </div>
                </div>
              </div>

              <div class="mt-5 flex flex-wrap gap-3 text-sm">
                <a href={`${base}models/${release.id}/`} class="text-(--color-accent) transition-colors hover:text-(--color-accent-hover)">Model page</a>
                {release.officialUrl && (
                  <a href={release.officialUrl} target="_blank" rel="noopener noreferrer" class="text-(--color-accent) transition-colors hover:text-(--color-accent-hover)">Official source</a>
                )}
                {release.providerDocsUrl && (
                  <a href={release.providerDocsUrl} target="_blank" rel="noopener noreferrer" class="text-(--color-accent) transition-colors hover:text-(--color-accent-hover)">Provider docs</a>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>

      <div class="rounded-[28px] border border-(--color-border-accent) bg-(--color-accent-glow) p-6">
        <p class="text-[11px] uppercase tracking-[0.28em] text-(--color-accent)">Coverage rules</p>
        <h2 class="mt-2 text-xl font-black text-(--color-text-primary)">How we keep release posts clean</h2>
        <div class="mt-4 space-y-3 text-sm leading-relaxed text-(--color-text-secondary)">
          <p>Official launch posts and provider docs come first. If we cannot point to the primary source, it should not be treated as a finished release brief.</p>
          <p>Benchmarks are separated from launch claims. If the evals are sparse or clearly internal, the draft should say that plainly.</p>
          <p>Community reaction is a second layer, not the first layer. The brief should stay useful even before social chatter is folded in.</p>
          <p>Open-weight and local releases should explicitly mention LM Studio, Ollama, GGUF, MLX, or phone/edge relevance where appropriate.</p>
        </div>

        <div class="mt-6 rounded-[22px] border border-(--color-border) bg-(--color-bg-primary)/65 p-4">
          <p class="text-[11px] uppercase tracking-[0.18em] text-(--color-text-muted)">Good launch post checklist</p>
          <ul class="mt-3 space-y-2 text-sm text-(--color-text-secondary)">
            <li>Explain what actually launched, not just the marketing line.</li>
            <li>State what changed versus the previous model family.</li>
            <li>Separate official claims, measured evidence, and outside reaction.</li>
            <li>Say who should care: API buyers, local users, coders, or open-source builders.</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="rounded-[28px] border border-(--color-border) bg-(--color-bg-card) p-6 mb-10">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between mb-5">
        <div>
          <p class="text-[11px] uppercase tracking-[0.28em] text-(--color-text-muted)">Release Radar</p>
          <h2 class="mt-2 text-2xl font-black text-(--color-text-primary)">Everything currently in the release window</h2>
        </div>
        <span class="badge">{releases.length} total</span>
      </div>

      <div class="space-y-4">
        {releases.map((release) => (
          <article class="rounded-[24px] border border-(--color-border) bg-(--color-bg-tertiary) p-5">
            <div class="flex flex-col gap-4 xl:flex-row xl:items-start xl:justify-between">
              <div class="min-w-0 flex-1">
                <div class="flex flex-wrap items-center gap-2">
                  <span class={`rounded-full border px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] ${priorityMeta[release.priority].classes}`}>
                    {priorityMeta[release.priority].label}
                  </span>
                  <span class={`rounded-full border px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] ${draftStatusMeta[release.draftStatus].classes}`}>
                    {draftStatusMeta[release.draftStatus].label}
                  </span>
                  <span class="badge">{formatDate(release.releaseDate)}</span>
                </div>

                <div class="mt-3 flex items-center gap-2">
                  <span class="h-3 w-3 rounded-full shrink-0" style={`background-color: ${release.providerColour}`}></span>
                  <h3 class="text-lg font-bold text-(--color-text-primary)">{release.modelName}</h3>
                </div>
                <p class="mt-1 text-sm text-(--color-text-muted)">{release.providerName}</p>
                <p class="mt-3 text-sm leading-relaxed text-(--color-text-secondary)">{release.dek}</p>

                <div class="mt-4 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
                  <div class="rounded-2xl border border-(--color-border) bg-(--color-bg-primary)/70 px-3 py-3">
                    <p class="text-[11px] uppercase tracking-[0.16em] text-(--color-text-muted)">Context</p>
                    <p class="mt-2 text-sm font-semibold text-(--color-text-primary)">{formatTokens(release.contextWindow)}</p>
                  </div>
                  <div class="rounded-2xl border border-(--color-border) bg-(--color-bg-primary)/70 px-3 py-3">
                    <p class="text-[11px] uppercase tracking-[0.16em] text-(--color-text-muted)">Pricing</p>
                    <p class="mt-2 text-sm font-semibold text-(--color-text-primary)">{formatPrice(release.inputPrice, release.outputPrice)}</p>
                  </div>
                  <div class="rounded-2xl border border-(--color-border) bg-(--color-bg-primary)/70 px-3 py-3">
                    <p class="text-[11px] uppercase tracking-[0.16em] text-(--color-text-muted)">Benchmarks</p>
                    <p class="mt-2 text-sm font-semibold text-(--color-text-primary)">{release.benchmarkCount}</p>
                  </div>
                  <div class="rounded-2xl border border-(--color-border) bg-(--color-bg-primary)/70 px-3 py-3">
                    <p class="text-[11px] uppercase tracking-[0.16em] text-(--color-text-muted)">Coverage</p>
                    <p class="mt-2 text-sm font-semibold text-(--color-text-primary)">{formatCountLabel(Number(release.storyCount), 'story', 'stories')}</p>
                  </div>
                </div>

                {release.relatedStories.length > 0 && (
                  <div class="mt-4 flex flex-wrap gap-2">
                    {release.relatedStories.slice(0, 4).map((story) => (
                      <a
                        href={story.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="rounded-full border border-(--color-border) bg-(--color-bg-card) px-3 py-1 text-[11px] text-(--color-text-secondary) transition-colors hover:text-(--color-text-primary)"
                      >
                        {story.source}
                      </a>
                    ))}
                  </div>
                )}
              </div>

              <div class="w-full rounded-[22px] border border-(--color-border) bg-(--color-bg-primary)/65 p-4 xl:max-w-[20rem]">
                <p class="text-[11px] uppercase tracking-[0.18em] text-(--color-text-muted)">What to cover</p>
                <ul class="mt-3 space-y-2 text-sm text-(--color-text-secondary)">
                  {release.checklist.slice(0, 4).map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>

    <div class="grid gap-4 lg:grid-cols-2">
      <div class="rounded-[28px] border border-(--color-border) bg-(--color-bg-card) p-6">
        <p class="text-[11px] uppercase tracking-[0.28em] text-(--color-text-muted)">Open / Local Radar</p>
        <h2 class="mt-2 text-xl font-black text-(--color-text-primary)">Releases that matter for local model guides</h2>
        <div class="mt-4 space-y-3">
          {openSourceReleases.slice(0, 6).map((release) => (
            <div class="rounded-[20px] border border-(--color-border) bg-(--color-bg-tertiary) p-4">
              <div class="flex items-center gap-2">
                <span class="h-3 w-3 rounded-full shrink-0" style={`background-color: ${release.providerColour}`}></span>
                <a href={`${base}models/${release.id}/`} class="font-semibold text-(--color-text-primary) transition-colors hover:text-(--color-accent)">{release.modelName}</a>
              </div>
              <p class="mt-2 text-sm text-(--color-text-secondary)">{release.summary}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="rounded-[28px] border border-(--color-border) bg-(--color-bg-card) p-6">
        <p class="text-[11px] uppercase tracking-[0.28em] text-(--color-text-muted)">Next step</p>
        <h2 class="mt-2 text-xl font-black text-(--color-text-primary)">Turn the best briefs into public posts</h2>
        <p class="mt-4 text-sm leading-relaxed text-(--color-text-secondary)">
          The release desk is the intake layer. Once a brief is editor-ready, the next move is to turn it into a proper blog post with a clear angle: what launched, how the evidence looks so far, and why people should care.
        </p>
        <div class="mt-5 flex flex-wrap gap-3 text-sm">
          <a href={`${base}blog/`} class="text-(--color-accent) transition-colors hover:text-(--color-accent-hover)">Open blog</a>
          <a href={`${base}news/`} class="text-(--color-accent) transition-colors hover:text-(--color-accent-hover)">Open AI news</a>
          <a href={`${base}leaderboard/`} class="text-(--color-accent) transition-colors hover:text-(--color-accent-hover)">Open leaderboard</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
