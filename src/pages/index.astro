---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getNews } from '../db/queries';
import {
  getDataPulse,
  getLatestActivities,
  getLatestDigest,
  getMetaLeaderboard,
  normaliseDateTime,
} from '../data/hub-dashboard';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

type HeadlineNewsItem = ReturnType<typeof getNews>[number] & {
  discovered_at?: string | null;
};

type HomeRow = {
  id: string;
  rank: number;
  name: string;
  provider: string;
  providerKey: string;
  providerColour: string;
  status: string;
  href: string;
  composite: number;
  realWorld: number;
  benchmarkScore: number;
  qualityScore: number;
  valueScore: number;
  inputPrice: number;
  outputPrice: number;
  blendedPrice: number;
  speed: number;
  contextWindow: number;
  released: string | null;
  releasedLabel: string;
  releasedDays: number | null;
  openSource: boolean;
  apiAvailable: boolean;
  modality: string[];
  bestFor: string;
  benchmarkCount: number;
  coverageRatio: number;
  typeKeys: string[];
  licenceKey: 'open' | 'closed';
  tags: string[];
  trendKind: 'new' | 'flat' | 'pending';
  trendLabel: string;
};

const metaLeaderboardAll = getMetaLeaderboard(250);
const dataPulse = getDataPulse(base);
const activities = getLatestActivities(14, base);
const latestDigest = getLatestDigest();
const digestEntries = latestDigest?.entries.slice(0, 5) ?? [];
const headlineNews = (getNews() as HeadlineNewsItem[])
  .map((item) => ({
    ...item,
    headlineDate: normaliseDateTime(item.published_at ?? item.discovered_at ?? null),
  }))
  .sort((a, b) => Date.parse(b.headlineDate ?? '') - Date.parse(a.headlineDate ?? ''))
  .slice(0, 6);

function slug(value: string): string {
  return value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '') || 'unknown';
}

function formatDateLabel(value: string | null | undefined): string {
  const normalised = normaliseDateTime(value);
  if (!normalised) return 'Awaiting refresh';
  return new Date(normalised).toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
  });
}

function formatRelativeTime(value: string | null | undefined): string {
  const normalised = normaliseDateTime(value);
  if (!normalised) return 'awaiting refresh';
  const diffMinutes = Math.max(0, Math.round((Date.now() - Date.parse(normalised)) / 60000));
  if (diffMinutes < 1) return 'just now';
  if (diffMinutes < 60) return `${diffMinutes}m ago`;
  const diffHours = Math.round(diffMinutes / 60);
  if (diffHours < 48) return `${diffHours}h ago`;
  return `${Math.round(diffHours / 24)}d ago`;
}

function daysSince(value: string | null | undefined): number | null {
  const normalised = normaliseDateTime(value);
  if (!normalised) return null;
  const diff = Math.floor((Date.now() - Date.parse(normalised)) / 86400000);
  return Number.isFinite(diff) ? Math.max(0, diff) : null;
}

function formatContextWindow(tokens: number): string {
  if (tokens >= 1_000_000) return `${(tokens / 1_000_000).toFixed(tokens % 1_000_000 === 0 ? 0 : 1)}M`;
  if (tokens >= 1_000) return `${Math.round(tokens / 1_000)}K`;
  return tokens > 0 ? `${tokens}` : 'n/a';
}

function formatPricePair(inputPrice: number, outputPrice: number, openSource: boolean): string {
  if (inputPrice === 0 && outputPrice === 0) return openSource ? 'Open / free' : 'Included';
  return `$${inputPrice.toFixed(2)} / $${outputPrice.toFixed(2)}`;
}

function formatScore(value: number): string {
  return value > 0 ? value.toFixed(1) : 'pending';
}

function scoreWidth(value: number): string {
  return `${Math.max(4, Math.min(100, value))}%`;
}

function getTypeKeys(model: { name: string; bestFor: string; modality: string[] }): string[] {
  const haystack = `${model.name} ${model.bestFor} ${model.modality.join(' ')}`.toLowerCase();
  const keys = new Set(['general']);
  if (/reason|math|logic|o\d\b/.test(haystack)) keys.add('reasoning');
  if (/vision|image|audio|video|multimodal/.test(haystack)) keys.add('multimodal');
  if (/coding|code|software|developer|swe/.test(haystack)) keys.add('coding');
  return Array.from(keys);
}

function getTags(model: {
  name: string;
  bestFor: string;
  modality: string[];
  openSource: boolean;
  apiAvailable: boolean;
  speed: number;
  releasedDays: number | null;
}): string[] {
  const haystack = `${model.name} ${model.bestFor} ${model.modality.join(' ')}`.toLowerCase();
  const tags = new Set<string>();
  if (model.openSource) tags.add('open');
  if (/reason|math|logic|o\d\b/.test(haystack)) tags.add('reasoning');
  if (/vision|image|audio|video|multimodal/.test(haystack)) tags.add('multimodal');
  if (model.speed >= 100) tags.add('fast');
  if (model.releasedDays !== null && model.releasedDays <= 14) tags.add('new');
  if (model.apiAvailable && !model.openSource) tags.add('api');
  return Array.from(tags);
}

const rows: HomeRow[] = metaLeaderboardAll.map((model, index) => {
  const providerKey = slug(model.provider);
  const releasedDays = daysSince(model.released);
  const blendedPrice = (model.inputPrice + 3 * model.outputPrice) / 4;
  const typeKeys = getTypeKeys(model);
  const realWorld = model.qualityScore;
  const trendKind: HomeRow['trendKind'] = releasedDays !== null && releasedDays <= 14
    ? 'new'
    : model.benchmarkCount > 0
      ? 'flat'
      : 'pending';
  const trendLabel = trendKind === 'new' ? 'new' : trendKind === 'flat' ? 'flat' : 'pending';

  const row = {
    id: model.id,
    rank: index + 1,
    name: model.name,
    provider: model.provider,
    providerKey,
    providerColour: model.providerColour || '#847360',
    status: model.status,
    href: `${base}models/${model.id}/`,
    composite: model.metaScore,
    realWorld,
    benchmarkScore: model.benchmarkScore,
    qualityScore: model.qualityScore,
    valueScore: model.valueScore,
    inputPrice: model.inputPrice,
    outputPrice: model.outputPrice,
    blendedPrice,
    speed: model.speed,
    contextWindow: model.contextWindow,
    released: normaliseDateTime(model.released),
    releasedLabel: formatDateLabel(model.released),
    releasedDays,
    openSource: model.openSource,
    apiAvailable: model.apiAvailable,
    modality: model.modality,
    bestFor: model.bestFor,
    benchmarkCount: model.benchmarkCount,
    coverageRatio: model.coverageRatio,
    typeKeys,
    licenceKey: (model.openSource ? 'open' : 'closed') as HomeRow['licenceKey'],
    tags: [] as string[],
    trendKind,
    trendLabel,
  };

  row.tags = getTags(row);
  return row;
});

const providerOptions = Array.from(
  rows.reduce((map, row) => {
    const entry = map.get(row.providerKey) ?? {
      key: row.providerKey,
      label: row.provider,
      colour: row.providerColour,
      count: 0,
    };
    entry.count += 1;
    map.set(row.providerKey, entry);
    return map;
  }, new Map<string, { key: string; label: string; colour: string; count: number }>())
    .values(),
).sort((a, b) => b.count - a.count || a.label.localeCompare(b.label));

const typeOptions = [
  { key: 'general', label: 'General', count: rows.filter((row) => row.typeKeys.includes('general')).length },
  { key: 'reasoning', label: 'Reasoning', count: rows.filter((row) => row.typeKeys.includes('reasoning')).length },
  { key: 'multimodal', label: 'Multimodal', count: rows.filter((row) => row.typeKeys.includes('multimodal')).length },
  { key: 'coding', label: 'Coding-tuned', count: rows.filter((row) => row.typeKeys.includes('coding')).length },
  { key: 'embedding', label: 'Embedding', count: 0 },
  { key: 'speech', label: 'Speech', count: 0 },
];

const licenceOptions = [
  { key: 'open', label: 'Open weights', count: rows.filter((row) => row.openSource).length },
  { key: 'closed', label: 'Closed / API', count: rows.filter((row) => !row.openSource).length },
];

const releaseOptions = [
  { key: '7', label: '7d' },
  { key: '30', label: '30d' },
  { key: '90', label: '90d' },
  { key: '365', label: '1y' },
  { key: 'all', label: 'all' },
];

const contextOptions = [
  { key: '32000', label: '>= 32K' },
  { key: '128000', label: '>= 128K' },
  { key: '1000000', label: '>= 1M' },
];

const viewCounts = {
  frontier: rows.length,
  cheapest: rows.filter((row) => row.blendedPrice > 0).length,
  fastest: rows.filter((row) => row.speed > 0).length,
  open: rows.filter((row) => row.openSource).length,
  value: rows.filter((row) => row.valueScore > 0).length,
};

const latestTimestamp = [
  ...dataPulse.map((item) => item.updatedAt),
  ...activities.map((item) => item.date),
  latestDigest ? normaliseDateTime(latestDigest.digestDate) : null,
]
  .filter((value): value is string => Boolean(value))
  .sort((a, b) => Date.parse(b) - Date.parse(a))[0] ?? null;

const nextRefreshLabel = latestTimestamp
  ? new Date(Date.parse(latestTimestamp) + 60 * 60 * 1000).toLocaleString('en-GB', {
    day: 'numeric',
    month: 'short',
    hour: '2-digit',
    minute: '2-digit',
    timeZoneName: 'short',
  })
  : 'next scheduled hourly run';

const tickerItems = [
  ...activities.slice(0, 8).map((entry) => ({
    time: formatRelativeTime(entry.date),
    label: entry.title,
    detail: entry.detail,
    href: entry.href ?? `${base}changelog/`,
    type: entry.category,
  })),
  ...headlineNews.slice(0, 4).map((entry) => ({
    time: formatRelativeTime(entry.headlineDate),
    label: entry.title,
    detail: entry.source,
    href: entry.url,
    type: 'news',
  })),
].slice(0, 10);

const duplicatedTickerItems = [...tickerItems, ...tickerItems];
const initialRows = rows.slice(0, 12);
const openRows = rows.filter((row) => row.openSource);
const speedRows = rows.filter((row) => row.speed > 0);
const latestRows = rows.filter((row) => row.releasedDays !== null && row.releasedDays <= 30);
const topValue = [...rows].filter((row) => row.valueScore > 0).sort((a, b) => b.valueScore - a.valueScore)[0] ?? null;

const tableLinks = [
  { href: `${base}cheapest/`, label: 'Cheapest credible (>= 70)' },
  { href: `${base}fastest/`, label: 'Fastest by tokens/sec' },
  { href: `${base}open-source/`, label: 'Open weights only' },
  { href: `${base}multimodal/`, label: 'Multimodal' },
  { href: `${base}context-window/`, label: 'Longest context' },
  { href: `${base}reasoning/`, label: 'Reasoning models' },
];

const homepagePayload = JSON.stringify({
  rows,
  tickerItems,
  base,
  latestTimestamp,
  nextRefreshLabel,
  viewCounts,
}).replace(/</g, '\\u003c');
---

<BaseLayout
  title="AI Resource Hub - Live Model Leaderboard, Pricing, Benchmarks, and AI News"
  description="A dense, hourly refreshed reference desk for AI models, prices, benchmark-backed rankings, releases, and live AI updates."
  compactChrome
>
  <div class="airh-home" data-airh-home>
    <section class="airh-layout-panel" data-airh-layout-panel="spreadsheet">
      <div class="airh-ticker" aria-label="Latest changes on the hub">
        <div class="airh-ticker-inner">
          <a href={`${base}updates/`} class="airh-ticker-stamp" data-airh-tip="Changes on the hub: releases, model rows, price data, source snapshots, and news. Refreshes hourly.">
            <span class="airh-pulse-dot"></span>
            <span>What's new</span>
          </a>
          <div class="airh-ticker-window">
            <div class="airh-ticker-stream">
              {duplicatedTickerItems.map((item) => (
                <a href={item.href} class="airh-ticker-item">
                  <span class="airh-ticker-time">{item.time}</span>
                  <strong>{item.label}</strong>
                  <span>{item.detail}</span>
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>

      <div class="airh-spreadsheet-wrap">
        <div class="airh-view-row">
          <div class="airh-view-tabs" role="tablist" aria-label="Leaderboard views">
            <button type="button" class="airh-view-tab is-active" role="tab" aria-selected="true" data-airh-view="frontier" data-airh-tip="Headline AIRH composite, sorted by current evidence-backed score.">
              Frontier <span>{viewCounts.frontier}</span>
            </button>
            <button type="button" class="airh-view-tab" role="tab" aria-selected="false" data-airh-view="cheapest" data-airh-tip="Paid models sorted by blended input/output price.">
              Cheapest <span>{viewCounts.cheapest}</span>
            </button>
            <button type="button" class="airh-view-tab" role="tab" aria-selected="false" data-airh-view="fastest" data-airh-tip="Models with speed data, sorted by tokens per second.">
              Fastest <span>{viewCounts.fastest}</span>
            </button>
            <button type="button" class="airh-view-tab" role="tab" aria-selected="false" data-airh-view="open" data-airh-tip="Open-weight rows only.">
              Open source <span>{viewCounts.open}</span>
            </button>
            <button type="button" class="airh-view-tab" role="tab" aria-selected="false" data-airh-view="value" data-airh-tip="Quality-per-cost view using the existing AIRH value score.">
              Best value <span>{viewCounts.value}</span>
            </button>
          </div>

          <span
            class="airh-refresh-stamp"
            id="airh-refresh-stamp"
            data-airh-tip={`Latest source snapshot: ${latestTimestamp ? formatDateLabel(latestTimestamp) : 'awaiting refresh'}. Next expected refresh: ${nextRefreshLabel}.`}
          >
            <span></span>
            Refreshed {formatRelativeTime(latestTimestamp)}
          </span>
        </div>

        <div class="airh-data-grid">
          <aside class="airh-filter-rail" aria-label="Filters">
            <div class="airh-filter-title">
              <span>Filters</span>
              <span class="airh-active-filter-count" data-airh-active-filters hidden>0 active</span>
            </div>

            <div class="airh-filter-group">
              <h2>Provider</h2>
              {providerOptions.slice(0, 10).map((option) => (
                <label class="airh-check">
                  <input type="checkbox" checked data-filter-provider={option.key} />
                  <span class="airh-provider-swatch" style={`background:${option.colour}`}></span>
                  <span>{option.label}</span>
                  <em>{option.count}</em>
                </label>
              ))}
            </div>

            <div class="airh-filter-group">
              <h2>Type</h2>
              {typeOptions.map((option) => (
                <label class="airh-check">
                  <input type="checkbox" checked data-filter-type={option.key} />
                  <span>{option.label}</span>
                  <em>{option.count}</em>
                </label>
              ))}
            </div>

            <div class="airh-filter-group">
              <h2>Licence</h2>
              {licenceOptions.map((option) => (
                <label class="airh-check">
                  <input type="checkbox" checked data-filter-licence={option.key} />
                  <span>{option.label}</span>
                  <em>{option.count}</em>
                </label>
              ))}
            </div>

            <div class="airh-filter-group">
              <h2>Released</h2>
              <div class="airh-pill-row" data-filter-release-group>
                {releaseOptions.map((option) => (
                  <button type="button" aria-pressed={option.key === 'all' ? 'true' : 'false'} data-filter-release={option.key}>{option.label}</button>
                ))}
              </div>
            </div>

            <div class="airh-filter-group">
              <h2>Context window</h2>
              <div class="airh-pill-row" data-filter-context-group>
                {contextOptions.map((option) => (
                  <button type="button" aria-pressed="false" data-filter-context={option.key}>{option.label}</button>
                ))}
              </div>
            </div>

            <button type="button" class="airh-filter-clear" data-airh-reset-filters>Clear all filters</button>
          </aside>

          <section class="airh-table-card" aria-labelledby="airh-table-title">
            <div class="airh-table-card-head">
              <h1 id="airh-table-title">Frontier - composite leaderboard</h1>
              <span class="airh-table-meta" data-airh-table-count data-airh-tip={`Tracked table rows from ${rows.length} current public LLM entries.`}>{Math.min(12, rows.length)} of {rows.length}</span>
              <div class="airh-density" role="group" aria-label="Table density">
                <button type="button" data-density="compact" aria-pressed="false">Compact</button>
                <button type="button" data-density="comfortable" aria-pressed="true">Comfy</button>
                <button type="button" data-density="spacious" aria-pressed="false">Spacious</button>
              </div>
            </div>

            <div class="airh-table-scroll">
              <table class="airh-leaderboard-table comfortable" data-airh-table>
                <thead>
                  <tr>
                    <th data-airh-tip="Rank inside the current view after filters and sorting.">#</th>
                    <th data-airh-tip="Model page, provider, release label, and evidence tags.">Model</th>
                    <th data-airh-tip="Provider or lab. Hover a provider for a quick provider summary.">Provider</th>
                    <th class="num sort" data-airh-tip="AIRH Composite: weighted blend of benchmark coverage, quality layer, freshness, and evidence penalties. Methodology page has the detail.">AIRH Composite</th>
                    <th class="num" data-airh-tip="AIRH Real-World: currently backed by the existing AIRH quality layer until the dedicated real-world harness is published.">AIRH Real-World</th>
                    <th class="num" data-airh-tip="AIRH Value: quality divided by blended token price when pricing is available.">AIRH Value</th>
                    <th class="num" data-airh-tip="No historical 7-day score series exists in the current cache, so this cell truthfully marks new, flat, or pending.">Delta 7d / Trend</th>
                    <th class="num" data-airh-tip="Input / output price per 1M tokens, USD where available.">$ in / out</th>
                    <th class="num" data-airh-tip="Tracked tokens per second. Blank data stays pending rather than guessed.">Speed</th>
                    <th class="num" data-airh-tip="Maximum context window in tokens.">Ctx</th>
                    <th data-airh-tip="Tags are derived from source fields: open weights, modality, speed, release date, and evidence type.">Tags</th>
                  </tr>
                </thead>
                <tbody data-airh-table-body>
                  {initialRows.map((row, index) => (
                    <tr data-row-id={row.id}>
                      <td class="rank">{index + 1}</td>
                      <td class="model-cell">
                        <a href={row.href} data-airh-rich="model" data-airh-model-id={row.id}>
                          {row.name}
                          <span>{row.id}</span>
                        </a>
                      </td>
                      <td>
                        <span class="airh-provider-chip" data-airh-rich="provider" data-airh-provider-key={row.providerKey}>
                          <span style={`background:${row.providerColour}`}></span>
                          {row.provider}
                        </span>
                      </td>
                      <td class="num score">
                        <span class="score-bar accent"><span style={`width:${scoreWidth(row.composite)}`}></span></span>
                        <b>{formatScore(row.composite)}</b>
                      </td>
                      <td class="num score">
                        <span class="score-bar"><span style={`width:${scoreWidth(row.realWorld)}`}></span></span>
                        <b>{formatScore(row.realWorld)}</b>
                      </td>
                      <td class="num">{row.valueScore > 0 ? row.valueScore.toLocaleString('en-GB') : 'pending'}</td>
                      <td class="num">
                        <span class={`airh-delta is-${row.trendKind}`}>{row.trendLabel}</span>
                        <span class="airh-flatline" aria-hidden="true"></span>
                      </td>
                      <td class="num">{formatPricePair(row.inputPrice, row.outputPrice, row.openSource)}</td>
                      <td class="num">{row.speed > 0 ? row.speed : 'pending'}</td>
                      <td class="num">{formatContextWindow(row.contextWindow)}</td>
                      <td>
                        {row.tags.map((tag) => (
                          <span class={`airh-tag is-${tag}`} data-airh-rich="tag" data-airh-tag={tag}>{tag}</span>
                        ))}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>

            <div class="airh-empty-state" data-airh-empty-state hidden>
              <p>No rows match those filters.</p>
              <button type="button" data-airh-reset-filters>Reset filters</button>
            </div>

            <div class="airh-table-foot">
              <span data-airh-table-summary>Showing {Math.min(12, rows.length)} of {rows.length} - sorted by AIRH Composite</span>
              <a href={`${base}leaderboard/`}>Open full leaderboard &rarr;</a>
            </div>
          </section>
        </div>

        <section class="airh-bottom-strip" aria-label="More AI Resource Hub signals">
          <div class="airh-strip-card">
            <h2>Today on the hub</h2>
            <ul>
              <li><span>{latestRows.length}</span><a href={`${base}new/`}>models released in the last 30 days</a></li>
              <li><span>{dataPulse.length}</span><a href={`${base}updates/`}>freshness lanes reporting</a></li>
              <li><span>{digestEntries.length}</span><a href={`${base}news/`}>digest stories surfaced</a></li>
              <li><span>{headlineNews.length}</span><a href={`${base}news/`}>headline items captured</a></li>
            </ul>
          </div>

          <div class="airh-strip-card">
            <h2>Pulse - current table</h2>
            <p class="airh-pulse-row"><strong>{rows.length}</strong><span>ranked public LLM rows</span></p>
            <p class="airh-pulse-row"><strong>{openRows.length}</strong><span>open-weight rows</span></p>
            <p class="airh-pulse-row"><strong>{speedRows.length}</strong><span>rows with speed data</span></p>
            <p class="airh-strip-note">
              {topValue ? `Value leader: ${topValue.name}` : 'Value leaders appear when price data is present.'}
            </p>
          </div>

          <div class="airh-strip-card">
            <h2>More tables</h2>
            {tableLinks.map((link) => (
              <a href={link.href} class="airh-table-link">{link.label}<span>&rarr;</span></a>
            ))}
          </div>
        </section>
      </div>
    </section>

    <section class="airh-layout-panel airh-terminal-panel is-hidden" data-airh-layout-panel="terminal" aria-label="AI Resource Hub terminal view">
      <div class="airh-terminal-shell">
        <header class="airh-terminal-head">
          <div>
            <p>AI Resource Hub / terminal</p>
            <h1>Type the table.</h1>
          </div>
          <div>
            <span>Refreshed {formatRelativeTime(latestTimestamp)}</span>
            <span>{rows.length} models</span>
            <span>{dataPulse.length} lanes</span>
          </div>
        </header>

        <div class="airh-terminal-log" data-airh-terminal-log aria-live="polite"></div>

        <form class="airh-terminal-form" data-airh-terminal-form>
          <label for="airh-terminal-input">airh &gt;</label>
          <input id="airh-terminal-input" data-airh-terminal-input autocomplete="off" spellcheck="false" placeholder="top 10, compare gpt claude, news --today, price sonnet, visual" />
          <button type="submit">Run</button>
        </form>

        <div class="airh-terminal-hints">
          <span>since-last-visit</span>
          <span>top 10</span>
          <span>compare A B</span>
          <span>news --today</span>
          <span>price MODEL</span>
          <span>visual</span>
        </div>
      </div>
    </section>

    <div class="airh-tip-card" data-airh-simple-tip role="tooltip" hidden></div>
    <div class="airh-rich-tip" data-airh-rich-tip role="tooltip" hidden></div>
  </div>

  <script is:inline type="application/json" id="airh-home-data" set:html={homepagePayload}></script>

  <script is:inline>
    (() => {
      const payload = document.getElementById('airh-home-data');
      if (!payload) return;

      const data = JSON.parse(payload.textContent || '{}');
      const rows = data.rows || [];
      const tickerItems = data.tickerItems || [];
      const base = data.base || '/';

      const table = document.querySelector('[data-airh-table]');
      const tbody = document.querySelector('[data-airh-table-body]');
      const emptyState = document.querySelector('[data-airh-empty-state]');
      const tableTitle = document.getElementById('airh-table-title');
      const tableCount = document.querySelector('[data-airh-table-count]');
      const tableSummary = document.querySelector('[data-airh-table-summary]');
      const activeFilterCount = document.querySelector('[data-airh-active-filters]');
      const providerInputs = Array.from(document.querySelectorAll('[data-filter-provider]'));
      const typeInputs = Array.from(document.querySelectorAll('[data-filter-type]'));
      const licenceInputs = Array.from(document.querySelectorAll('[data-filter-licence]'));
      const releaseButtons = Array.from(document.querySelectorAll('[data-filter-release]'));
      const contextButtons = Array.from(document.querySelectorAll('[data-filter-context]'));
      const viewButtons = Array.from(document.querySelectorAll('[data-airh-view]'));
      const densityButtons = Array.from(document.querySelectorAll('[data-density]'));

      const viewConfigs = {
        frontier: {
          title: 'Frontier - composite leaderboard',
          sortLabel: 'AIRH Composite',
          filter: () => true,
          sort: (a, b) => b.composite - a.composite || b.qualityScore - a.qualityScore || a.name.localeCompare(b.name),
        },
        cheapest: {
          title: 'Cheapest - credible paid rows',
          sortLabel: 'blended token price',
          filter: (row) => row.blendedPrice > 0,
          sort: (a, b) => a.blendedPrice - b.blendedPrice || b.composite - a.composite,
        },
        fastest: {
          title: 'Fastest - tokens per second',
          sortLabel: 'speed',
          filter: (row) => row.speed > 0,
          sort: (a, b) => b.speed - a.speed || b.composite - a.composite,
        },
        open: {
          title: 'Open source - open-weight rows',
          sortLabel: 'AIRH Composite',
          filter: (row) => row.openSource,
          sort: (a, b) => b.composite - a.composite || b.valueScore - a.valueScore,
        },
        value: {
          title: 'Best value - quality per cost',
          sortLabel: 'AIRH Value',
          filter: (row) => row.valueScore > 0,
          sort: (a, b) => b.valueScore - a.valueScore || b.composite - a.composite,
        },
      };

      const state = {
        view: 'frontier',
        release: 'all',
        context: null,
        density: localStorage.getItem('airh:density') || 'comfortable',
      };

      const escapeHtml = (value) => String(value ?? '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');

      const selectedValues = (inputs) => new Set(inputs.filter((input) => input.checked).map((input) => input.getAttribute(input.dataset.filterProvider !== undefined ? 'data-filter-provider' : input.dataset.filterType !== undefined ? 'data-filter-type' : 'data-filter-licence')));

      const formatScore = (value) => value > 0 ? Number(value).toFixed(1) : 'pending';
      const formatContext = (tokens) => {
        if (tokens >= 1000000) return `${Number(tokens / 1000000).toFixed(tokens % 1000000 === 0 ? 0 : 1)}M`;
        if (tokens >= 1000) return `${Math.round(tokens / 1000)}K`;
        return tokens > 0 ? String(tokens) : 'n/a';
      };
      const formatPrice = (row) => {
        if (row.inputPrice === 0 && row.outputPrice === 0) return row.openSource ? 'Open / free' : 'Included';
        return `$${Number(row.inputPrice).toFixed(2)} <span class="muted">/</span> $${Number(row.outputPrice).toFixed(2)}`;
      };
      const scoreWidth = (value) => `${Math.max(4, Math.min(100, Number(value) || 0))}%`;

      function passesFilters(row) {
        const providers = selectedValues(providerInputs);
        const types = selectedValues(typeInputs);
        const licences = selectedValues(licenceInputs);
        if (!providers.has(row.providerKey)) return false;
        if (!row.typeKeys.some((key) => types.has(key))) return false;
        if (!licences.has(row.licenceKey)) return false;
        if (state.release !== 'all') {
          const maxDays = Number(state.release);
          if (row.releasedDays === null || row.releasedDays > maxDays) return false;
        }
        if (state.context !== null && row.contextWindow < state.context) return false;
        return true;
      }

      function getCurrentRows() {
        const config = viewConfigs[state.view] || viewConfigs.frontier;
        return rows
          .filter((row) => config.filter(row))
          .filter(passesFilters)
          .sort(config.sort);
      }

      function renderTags(row) {
        if (!row.tags.length) return '<span class="airh-tag is-muted">tracked</span>';
        return row.tags.map((tag) => `<span class="airh-tag is-${escapeHtml(tag)}" data-airh-rich="tag" data-airh-tag="${escapeHtml(tag)}">${escapeHtml(tag)}</span>`).join('');
      }

      function renderRow(row, index) {
        return `
          <tr data-row-id="${escapeHtml(row.id)}">
            <td class="rank">${index + 1}</td>
            <td class="model-cell">
              <a href="${escapeHtml(row.href)}" data-airh-rich="model" data-airh-model-id="${escapeHtml(row.id)}">
                ${escapeHtml(row.name)}
                <span>${escapeHtml(row.id)}</span>
              </a>
            </td>
            <td>
              <span class="airh-provider-chip" data-airh-rich="provider" data-airh-provider-key="${escapeHtml(row.providerKey)}">
                <span style="background:${escapeHtml(row.providerColour)}"></span>
                ${escapeHtml(row.provider)}
              </span>
            </td>
            <td class="num score"><span class="score-bar accent"><span style="width:${scoreWidth(row.composite)}"></span></span><b>${formatScore(row.composite)}</b></td>
            <td class="num score"><span class="score-bar"><span style="width:${scoreWidth(row.realWorld)}"></span></span><b>${formatScore(row.realWorld)}</b></td>
            <td class="num">${row.valueScore > 0 ? Number(row.valueScore).toLocaleString('en-GB') : 'pending'}</td>
            <td class="num"><span class="airh-delta is-${escapeHtml(row.trendKind)}">${escapeHtml(row.trendLabel)}</span><span class="airh-flatline" aria-hidden="true"></span></td>
            <td class="num">${formatPrice(row)}</td>
            <td class="num">${row.speed > 0 ? escapeHtml(row.speed) : 'pending'}</td>
            <td class="num">${escapeHtml(formatContext(row.contextWindow))}</td>
            <td>${renderTags(row)}</td>
          </tr>
        `;
      }

      function countFilterDeviations() {
        let count = 0;
        if (providerInputs.some((input) => !input.checked)) count += 1;
        if (typeInputs.some((input) => !input.checked)) count += 1;
        if (licenceInputs.some((input) => !input.checked)) count += 1;
        if (state.release !== 'all') count += 1;
        if (state.context !== null) count += 1;
        return count;
      }

      function syncFilterUi() {
        releaseButtons.forEach((button) => {
          button.setAttribute('aria-pressed', String(button.getAttribute('data-filter-release') === state.release));
        });
        contextButtons.forEach((button) => {
          button.setAttribute('aria-pressed', String(Number(button.getAttribute('data-filter-context')) === state.context));
        });
        viewButtons.forEach((button) => {
          const active = button.getAttribute('data-airh-view') === state.view;
          button.classList.toggle('is-active', active);
          button.setAttribute('aria-selected', String(active));
        });
        densityButtons.forEach((button) => {
          button.setAttribute('aria-pressed', String(button.getAttribute('data-density') === state.density));
        });
        table?.classList.remove('compact', 'comfortable', 'spacious');
        table?.classList.add(state.density);

        const deviations = countFilterDeviations();
        if (activeFilterCount) {
          activeFilterCount.hidden = deviations === 0;
          activeFilterCount.textContent = `${deviations} active`;
        }
      }

      function renderTable() {
        if (!tbody) return;
        const config = viewConfigs[state.view] || viewConfigs.frontier;
        const currentRows = getCurrentRows();
        const visibleRows = currentRows.slice(0, 12);
        tbody.innerHTML = visibleRows.map(renderRow).join('');
        if (tableTitle) tableTitle.textContent = config.title;
        if (tableCount) tableCount.textContent = `${visibleRows.length} of ${currentRows.length}`;
        if (tableSummary) tableSummary.textContent = `Showing ${visibleRows.length} of ${currentRows.length} - sorted by ${config.sortLabel}`;
        if (emptyState) emptyState.hidden = currentRows.length !== 0;
        syncFilterUi();
      }

      function resetFilters() {
        [...providerInputs, ...typeInputs, ...licenceInputs].forEach((input) => { input.checked = true; });
        state.release = 'all';
        state.context = null;
        renderTable();
      }

      [...providerInputs, ...typeInputs, ...licenceInputs].forEach((input) => input.addEventListener('change', renderTable));
      releaseButtons.forEach((button) => {
        button.addEventListener('click', () => {
          state.release = button.getAttribute('data-filter-release') || 'all';
          renderTable();
        });
      });
      contextButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const value = Number(button.getAttribute('data-filter-context'));
          state.context = state.context === value ? null : value;
          renderTable();
        });
      });
      viewButtons.forEach((button) => {
        button.addEventListener('click', () => {
          state.view = button.getAttribute('data-airh-view') || 'frontier';
          renderTable();
        });
      });
      densityButtons.forEach((button) => {
        button.addEventListener('click', () => {
          state.density = button.getAttribute('data-density') || 'comfortable';
          localStorage.setItem('airh:density', state.density);
          renderTable();
        });
      });
      document.querySelectorAll('[data-airh-reset-filters]').forEach((button) => button.addEventListener('click', resetFilters));

      renderTable();

      const simpleTip = document.querySelector('[data-airh-simple-tip]');
      const richTip = document.querySelector('[data-airh-rich-tip]');
      let simpleTimer = 0;
      let richTimer = 0;
      let activeTipTarget = null;

      function placeTip(target, tip, width) {
        const rect = target.getBoundingClientRect();
        const tipHeight = tip.offsetHeight || 120;
        let left = rect.left;
        let top = rect.bottom + 8;
        if (left + width > window.innerWidth - 10) left = window.innerWidth - width - 10;
        if (top + tipHeight > window.innerHeight - 10) top = rect.top - tipHeight - 8;
        tip.style.left = `${Math.max(10, left)}px`;
        tip.style.top = `${Math.max(10, top)}px`;
      }

      function hideTips() {
        window.clearTimeout(simpleTimer);
        window.clearTimeout(richTimer);
        activeTipTarget = null;
        if (simpleTip) {
          simpleTip.hidden = true;
          simpleTip.classList.remove('is-visible');
        }
        if (richTip) {
          richTip.hidden = true;
          richTip.classList.remove('is-visible');
        }
      }

      function showSimpleTip(target) {
        const text = target.getAttribute('data-airh-tip');
        if (!text || !simpleTip) return;
        window.clearTimeout(simpleTimer);
        simpleTimer = window.setTimeout(() => {
          simpleTip.innerHTML = `<span>${escapeHtml(text)}</span>`;
          simpleTip.hidden = false;
          placeTip(target, simpleTip, 280);
          simpleTip.classList.add('is-visible');
        }, 220);
      }

      const tagDescriptions = {
        open: 'Open weights: downloadable or self-hostable depending on the licence and provider.',
        reasoning: 'Reasoning-oriented row, inferred from source fields and benchmark/use-case labels.',
        multimodal: 'Accepts more than text, such as image, audio, or video fields in the source cache.',
        fast: 'Speed field is at or above 100 tokens/sec in the current cache.',
        new: 'Released within the last 14 days in the current source cache.',
        api: 'Closed/API-hosted row with API availability marked in the cache.',
        tracked: 'Tracked row without a stronger derived tag.',
      };

      function richModelHtml(row) {
        return `
          <div class="scribble">${escapeHtml(row.bestFor || 'Tracked model')}</div>
          <h2>${escapeHtml(row.name)}</h2>
          <p class="sub">${escapeHtml(row.id)} - ${escapeHtml(row.releasedLabel)}</p>
          <dl>
            <dt>Provider</dt><dd>${escapeHtml(row.provider)}</dd>
            <dt>AIRH Composite</dt><dd>${formatScore(row.composite)}</dd>
            <dt>AIRH Quality</dt><dd>${formatScore(row.qualityScore)}</dd>
            <dt>Price</dt><dd>${formatPrice(row)}</dd>
            <dt>Speed</dt><dd>${row.speed > 0 ? `${escapeHtml(row.speed)} t/s` : 'pending'}</dd>
            <dt>Context</dt><dd>${escapeHtml(formatContext(row.contextWindow))}</dd>
          </dl>
          <div class="footer">
            <a href="${escapeHtml(row.href)}">Open page</a>
            <a href="${base}compare/head-to-head/">Compare</a>
            <span>Watchlist soon</span>
          </div>
        `;
      }

      function richProviderHtml(providerKey) {
        const providerRows = rows.filter((row) => row.providerKey === providerKey).sort((a, b) => b.composite - a.composite);
        const first = providerRows[0];
        if (!first) return '';
        return `
          <div class="scribble">${providerRows.length} tracked row${providerRows.length === 1 ? '' : 's'}</div>
          <h2><span class="provider-dot" style="background:${escapeHtml(first.providerColour)}"></span>${escapeHtml(first.provider)}</h2>
          <p class="sub">Top rows on AIRH Composite</p>
          <dl>
            ${providerRows.slice(0, 3).map((row) => `<dt>${escapeHtml(row.name)}</dt><dd>${formatScore(row.composite)}</dd>`).join('')}
          </dl>
          <div class="footer">
            <a href="${base}labs/">Provider pages</a>
            <a href="${base}compare/providers/">Compare providers</a>
          </div>
        `;
      }

      function richTagHtml(tag) {
        return `
          <div class="scribble">tag</div>
          <h2>${escapeHtml(tag)}</h2>
          <p class="sub">${escapeHtml(tagDescriptions[tag] || 'Derived from the current source cache.')}</p>
          <div class="footer"><span>Use the filters to narrow rows</span></div>
        `;
      }

      function showRichTip(target) {
        if (!richTip) return;
        const type = target.getAttribute('data-airh-rich');
        let html = '';
        if (type === 'model') {
          const row = rows.find((item) => item.id === target.getAttribute('data-airh-model-id'));
          if (row) html = richModelHtml(row);
        } else if (type === 'provider') {
          html = richProviderHtml(target.getAttribute('data-airh-provider-key'));
        } else if (type === 'tag') {
          html = richTagHtml(target.getAttribute('data-airh-tag'));
        }
        if (!html) return;
        window.clearTimeout(richTimer);
        richTimer = window.setTimeout(() => {
          richTip.innerHTML = html;
          richTip.hidden = false;
          placeTip(target, richTip, 330);
          richTip.classList.add('is-visible');
        }, 260);
      }

      function handleTipIntent(event) {
        const richTarget = event.target.closest?.('[data-airh-rich]');
        if (richTarget) {
          if (activeTipTarget === richTarget) return;
          if (activeTipTarget) hideTips();
          activeTipTarget = richTarget;
          showRichTip(richTarget);
          return;
        }
        const simpleTarget = event.target.closest?.('[data-airh-tip]');
        if (simpleTarget) {
          if (activeTipTarget === simpleTarget) return;
          if (activeTipTarget) hideTips();
          activeTipTarget = simpleTarget;
          showSimpleTip(simpleTarget);
        }
      }

      document.body.addEventListener('mouseover', handleTipIntent);
      document.body.addEventListener('mousemove', handleTipIntent);
      document.body.addEventListener('focusin', handleTipIntent);
      document.body.addEventListener('mouseout', (event) => {
        if (event.target.closest?.('[data-airh-rich], [data-airh-tip]')) hideTips();
      });
      document.body.addEventListener('focusout', (event) => {
        if (event.target.closest?.('[data-airh-rich], [data-airh-tip]')) hideTips();
      });
      window.addEventListener('scroll', hideTips, { passive: true });
      window.addEventListener('resize', hideTips);

      const layoutKey = 'airh:home-layout';
      const panels = Array.from(document.querySelectorAll('[data-airh-layout-panel]'));
      const layoutButtons = Array.from(document.querySelectorAll('[data-airh-layout-switch]'));
      const terminalInput = document.querySelector('[data-airh-terminal-input]');
      const terminalLog = document.querySelector('[data-airh-terminal-log]');
      const terminalForm = document.querySelector('[data-airh-terminal-form]');

      function setLayout(layout) {
        const safeLayout = layout === 'terminal' ? 'terminal' : 'spreadsheet';
        panels.forEach((panel) => {
          panel.classList.toggle('is-hidden', panel.getAttribute('data-airh-layout-panel') !== safeLayout);
        });
        layoutButtons.forEach((button) => {
          button.classList.toggle('is-active', button.getAttribute('data-airh-layout-switch') === safeLayout);
        });
        localStorage.setItem(layoutKey, safeLayout);
        if (safeLayout === 'terminal') window.setTimeout(() => terminalInput?.focus(), 50);
      }

      function appendTerminal(kind, html) {
        if (!terminalLog) return;
        const block = document.createElement('div');
        block.className = `airh-terminal-block is-${kind}`;
        block.innerHTML = html;
        terminalLog.appendChild(block);
        terminalLog.scrollTop = terminalLog.scrollHeight;
      }

      function findRow(query) {
        const q = String(query || '').trim().toLowerCase();
        if (!q) return null;
        return rows.find((row) => row.id.toLowerCase() === q)
          || rows.find((row) => row.name.toLowerCase() === q)
          || rows.find((row) => row.id.toLowerCase().includes(q) || row.name.toLowerCase().includes(q));
      }

      function runTerminal(command, echo = true) {
        const raw = String(command || '').trim();
        const lower = raw.toLowerCase();
        if (!raw) return;
        if (echo) appendTerminal('command', `<span>airh &gt;</span> ${escapeHtml(raw)}`);

        if (lower === 'visual' || lower === 'spreadsheet') {
          appendTerminal('ok', 'Returning to spreadsheet view.');
          setLayout('spreadsheet');
          return;
        }

        if (lower === 'help' || lower === '?') {
          appendTerminal('result', '<strong>Commands</strong><br>since-last-visit<br>top 10<br>compare A B<br>news --today<br>price MODEL<br>visual');
          return;
        }

        if (lower === 'since-last-visit') {
          const items = tickerItems.slice(0, 8).map((item) => `<li><span>${escapeHtml(item.time)}</span>${escapeHtml(item.label)}</li>`).join('');
          appendTerminal('result', `<strong>Since last visit</strong><ul>${items}</ul>`);
          return;
        }

        if (/^top\s+\d+/.test(lower)) {
          const limit = Math.max(1, Math.min(20, Number(lower.match(/\d+/)?.[0] || 10)));
          const topRows = [...rows].sort((a, b) => b.composite - a.composite).slice(0, limit);
          appendTerminal('result', `<strong>Top ${limit}</strong><ol>${topRows.map((row) => `<li>${escapeHtml(row.name)} <span>${formatScore(row.composite)}</span></li>`).join('')}</ol>`);
          return;
        }

        if (lower.startsWith('compare ')) {
          const terms = raw.slice(8).split(/\s+/).filter(Boolean);
          const midpoint = Math.ceil(terms.length / 2);
          const a = findRow(terms.slice(0, midpoint).join(' '));
          const b = findRow(terms.slice(midpoint).join(' '));
          if (!a || !b) {
            appendTerminal('warn', 'Could not find both models. Try a shorter model name.');
            return;
          }
          appendTerminal('result', `<strong>${escapeHtml(a.name)} vs ${escapeHtml(b.name)}</strong><dl><dt>Composite</dt><dd>${formatScore(a.composite)} / ${formatScore(b.composite)}</dd><dt>Price</dt><dd>${formatPrice(a)} / ${formatPrice(b)}</dd><dt>Speed</dt><dd>${a.speed || 'pending'} / ${b.speed || 'pending'}</dd><dt>Context</dt><dd>${formatContext(a.contextWindow)} / ${formatContext(b.contextWindow)}</dd></dl>`);
          return;
        }

        if (lower === 'news --today' || lower === 'news') {
          const items = tickerItems.slice(0, 8).map((item) => `<li>${escapeHtml(item.label)} <span>${escapeHtml(item.time)}</span></li>`).join('');
          appendTerminal('result', `<strong>News and activity</strong><ul>${items}</ul>`);
          return;
        }

        if (lower.startsWith('price ')) {
          const row = findRow(raw.slice(6));
          if (!row) {
            appendTerminal('warn', 'Model not found.');
            return;
          }
          appendTerminal('result', `<strong>${escapeHtml(row.name)}</strong><br>${formatPrice(row)} per 1M tokens<br>Blended: ${row.blendedPrice > 0 ? `$${Number(row.blendedPrice).toFixed(2)}` : 'not priced'}`);
          return;
        }

        appendTerminal('warn', 'Unknown command. Type help for the short list.');
      }

      layoutButtons.forEach((button) => {
        button.addEventListener('click', () => {
          if (button.getAttribute('aria-disabled') === 'true') return;
          setLayout(button.getAttribute('data-airh-layout-switch') || 'spreadsheet');
        });
      });

      function submitTerminalCommand() {
        const command = terminalInput?.value || '';
        if (terminalInput) terminalInput.value = '';
        runTerminal(command);
      }

      terminalForm?.addEventListener('submit', (event) => {
        event.preventDefault();
        submitTerminalCommand();
      });
      terminalInput?.addEventListener('keydown', (event) => {
        if (event.key !== 'Enter') return;
        event.preventDefault();
        submitTerminalCommand();
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && localStorage.getItem(layoutKey) === 'terminal') {
          setLayout('spreadsheet');
        }
      });

      appendTerminal('intro', '<span># welcome back - running since-last-visit</span>');
      runTerminal('since-last-visit', false);
      setLayout(localStorage.getItem(layoutKey) === 'terminal' ? 'terminal' : 'spreadsheet');
    })();
  </script>
</BaseLayout>
