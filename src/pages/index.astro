---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getNews } from '../db/queries';
import {
  getDataPulse,
  getLatestActivities,
  getLatestDigest,
  getMetaLeaderboard,
  normaliseDateTime,
} from '../data/hub-dashboard';
import {
  getMetaBenchmarkOverview,
  type MetaBenchmarkLeaderboardEntry,
} from '../data/internal-meta-benchmarks';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

type HeadlineNewsItem = ReturnType<typeof getNews>[number] & {
  discovered_at?: string | null;
};

type HomeRow = {
  id: string;
  rank: number;
  name: string;
  provider: string;
  providerKey: string;
  providerColour: string;
  status: string;
  href: string;
  composite: number;
  realWorld: number;
  benchmarkScore: number;
  qualityScore: number;
  valueScore: number;
  inputPrice: number;
  outputPrice: number;
  blendedPrice: number;
  speed: number;
  contextWindow: number;
  released: string | null;
  releasedLabel: string;
  releasedDays: number | null;
  openSource: boolean;
  apiAvailable: boolean;
  modality: string[];
  bestFor: string;
  benchmarkCount: number;
  coverageRatio: number;
  typeKeys: string[];
  licenceKey: 'open' | 'closed';
  tags: string[];
  trendKind: 'new' | 'flat' | 'pending';
  trendLabel: string;
};

const metaLeaderboardAll = getMetaLeaderboard(250);

// Meta Benchmark Hub promotion (KOL-4165): the homepage leaderboard is the
// internal meta benchmark, not the AIRH composite. The composite still powers
// the dossier/monitor/terminal panels and the /leaderboard/ page.
const metaOverview = getMetaBenchmarkOverview();
const metaRanked = metaOverview.leaderboard.filter((entry) => entry.rankStatus === 'ranked');
const metaPartialCount = metaOverview.leaderboard.length - metaRanked.length;
const CONFIDENCE_TIP =
  'Confidence describes how strong the evidence is for this provisional score. It is not another model grade.';
const DEEPSWE_URL = 'https://deepswe.datacurve.ai/';

type MetaLane = {
  id: string;
  label: string;
  tip: string;
  scoreLabel: string;
  scoreOf: (entry: MetaBenchmarkLeaderboardEntry) => number;
};

const metaLanes: MetaLane[] = [
  {
    id: 'floor',
    label: 'Floor Capability',
    tip: 'Dependable everyday capability: accuracy, instruction discipline, honesty, reasoning floor, agent/coding, operating envelope. 0-100 saturation scale; 100 means routine failures have effectively disappeared.',
    scoreLabel: 'Floor score',
    scoreOf: (entry) => entry.metaScores.floorCapability,
  },
  {
    id: 'operating',
    label: 'Operating Envelope',
    tip: 'Cost, time, output tokens, speed, and operational friction. 0-100 saturation scale.',
    scoreLabel: 'Ops score',
    scoreOf: (entry) => entry.metaScores.operatingEnvelope,
  },
  {
    id: 'frontier',
    label: 'Frontier Reality',
    tip: 'Peak capability on the hardest current evidence. 0-100 saturation scale.',
    scoreLabel: 'Frontier score',
    scoreOf: (entry) => entry.metaScores.frontierReality,
  },
  {
    id: 'research',
    label: 'Research Trust',
    tip: 'How far the evidence trail can be trusted for research-grade use. 0-100 saturation scale.',
    scoreLabel: 'Research score',
    scoreOf: (entry) => entry.metaScores.researchTrust,
  },
];

const metaLaneRows = metaLanes.map((lane) => ({
  lane,
  rows: [...metaRanked].sort((a, b) => lane.scoreOf(b) - lane.scoreOf(a)),
}));

function dsweCompact(entry: MetaBenchmarkLeaderboardEntry): string {
  const dswe = entry.dsweMetrics;
  if (!dswe) return 'pending';
  return `${dswe.passAt1Pct}% · $${dswe.averageCostUsd.toFixed(2)} · ${dswe.averageTimeMinutes}m · ${dswe.outputTokensK}k`;
}

const dataPulse = getDataPulse(base);
const activities = getLatestActivities(14, base);
const latestDigest = getLatestDigest();
const digestEntries = latestDigest?.entries.slice(0, 5) ?? [];
const headlineNews = (getNews() as HeadlineNewsItem[])
  .map((item) => ({
    ...item,
    headlineDate: normaliseDateTime(item.published_at ?? item.discovered_at ?? null),
  }))
  .sort((a, b) => Date.parse(b.headlineDate ?? '') - Date.parse(a.headlineDate ?? ''))
  .slice(0, 6);

function slug(value: string): string {
  return value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '') || 'unknown';
}

function formatDateLabel(value: string | null | undefined): string {
  const normalised = normaliseDateTime(value);
  if (!normalised) return 'Awaiting refresh';
  return new Date(normalised).toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
  });
}

function formatRelativeTime(value: string | null | undefined): string {
  const normalised = normaliseDateTime(value);
  if (!normalised) return 'awaiting refresh';
  const diffMinutes = Math.max(0, Math.round((Date.now() - Date.parse(normalised)) / 60000));
  if (diffMinutes < 1) return 'just now';
  if (diffMinutes < 60) return `${diffMinutes}m ago`;
  const diffHours = Math.round(diffMinutes / 60);
  if (diffHours < 48) return `${diffHours}h ago`;
  return `${Math.round(diffHours / 24)}d ago`;
}

function daysSince(value: string | null | undefined): number | null {
  const normalised = normaliseDateTime(value);
  if (!normalised) return null;
  const diff = Math.floor((Date.now() - Date.parse(normalised)) / 86400000);
  return Number.isFinite(diff) ? Math.max(0, diff) : null;
}

function formatContextWindow(tokens: number): string {
  if (tokens >= 1_000_000) return `${(tokens / 1_000_000).toFixed(tokens % 1_000_000 === 0 ? 0 : 1)}M`;
  if (tokens >= 1_000) return `${Math.round(tokens / 1_000)}K`;
  return tokens > 0 ? `${tokens}` : 'n/a';
}

function formatPricePair(inputPrice: number, outputPrice: number, openSource: boolean): string {
  if (inputPrice === 0 && outputPrice === 0) return openSource ? 'Open / free' : 'Included';
  return `$${inputPrice.toFixed(2)} / $${outputPrice.toFixed(2)}`;
}

function formatScore(value: number): string {
  return value > 0 ? value.toFixed(1) : 'pending';
}

function scoreWidth(value: number): string {
  return `${Math.max(4, Math.min(100, value))}%`;
}

function getTypeKeys(model: { name: string; bestFor: string; modality: string[] }): string[] {
  const haystack = `${model.name} ${model.bestFor} ${model.modality.join(' ')}`.toLowerCase();
  const keys = new Set(['general']);
  if (/reason|math|logic|o\d\b/.test(haystack)) keys.add('reasoning');
  if (/vision|image|audio|video|multimodal/.test(haystack)) keys.add('multimodal');
  if (/coding|code|software|developer|swe/.test(haystack)) keys.add('coding');
  return Array.from(keys);
}

function getTags(model: {
  name: string;
  bestFor: string;
  modality: string[];
  openSource: boolean;
  apiAvailable: boolean;
  speed: number;
  releasedDays: number | null;
}): string[] {
  const haystack = `${model.name} ${model.bestFor} ${model.modality.join(' ')}`.toLowerCase();
  const tags = new Set<string>();
  if (model.openSource) tags.add('open');
  if (/reason|math|logic|o\d\b/.test(haystack)) tags.add('reasoning');
  if (/vision|image|audio|video|multimodal/.test(haystack)) tags.add('multimodal');
  if (model.speed >= 100) tags.add('fast');
  if (model.releasedDays !== null && model.releasedDays <= 14) tags.add('new');
  if (model.apiAvailable && !model.openSource) tags.add('api');
  return Array.from(tags);
}

const rows: HomeRow[] = metaLeaderboardAll.map((model, index) => {
  const providerKey = slug(model.provider);
  const releasedDays = daysSince(model.released);
  const blendedPrice = (model.inputPrice + 3 * model.outputPrice) / 4;
  const typeKeys = getTypeKeys(model);
  const realWorld = model.qualityScore;
  const trendKind: HomeRow['trendKind'] = releasedDays !== null && releasedDays <= 14
    ? 'new'
    : model.benchmarkCount > 0
      ? 'flat'
      : 'pending';
  const trendLabel = trendKind === 'new' ? 'new' : trendKind === 'flat' ? 'flat' : 'pending';

  const row = {
    id: model.id,
    rank: index + 1,
    name: model.name,
    provider: model.provider,
    providerKey,
    providerColour: model.providerColour || '#847360',
    status: model.status,
    href: `${base}models/${model.id}/`,
    composite: model.metaScore,
    realWorld,
    benchmarkScore: model.benchmarkScore,
    qualityScore: model.qualityScore,
    valueScore: model.valueScore,
    inputPrice: model.inputPrice,
    outputPrice: model.outputPrice,
    blendedPrice,
    speed: model.speed,
    contextWindow: model.contextWindow,
    released: normaliseDateTime(model.released),
    releasedLabel: formatDateLabel(model.released),
    releasedDays,
    openSource: model.openSource,
    apiAvailable: model.apiAvailable,
    modality: model.modality,
    bestFor: model.bestFor,
    benchmarkCount: model.benchmarkCount,
    coverageRatio: model.coverageRatio,
    typeKeys,
    licenceKey: (model.openSource ? 'open' : 'closed') as HomeRow['licenceKey'],
    tags: [] as string[],
    trendKind,
    trendLabel,
  };

  row.tags = getTags(row);
  return row;
});

const providerOptions = Array.from(
  rows.reduce((map, row) => {
    const entry = map.get(row.providerKey) ?? {
      key: row.providerKey,
      label: row.provider,
      colour: row.providerColour,
      count: 0,
    };
    entry.count += 1;
    map.set(row.providerKey, entry);
    return map;
  }, new Map<string, { key: string; label: string; colour: string; count: number }>())
    .values(),
).sort((a, b) => b.count - a.count || a.label.localeCompare(b.label));

const typeOptions = [
  { key: 'general', label: 'General', count: rows.filter((row) => row.typeKeys.includes('general')).length },
  { key: 'reasoning', label: 'Reasoning', count: rows.filter((row) => row.typeKeys.includes('reasoning')).length },
  { key: 'multimodal', label: 'Multimodal', count: rows.filter((row) => row.typeKeys.includes('multimodal')).length },
  { key: 'coding', label: 'Coding-tuned', count: rows.filter((row) => row.typeKeys.includes('coding')).length },
  { key: 'embedding', label: 'Embedding', count: 0 },
  { key: 'speech', label: 'Speech', count: 0 },
];

const licenceOptions = [
  { key: 'open', label: 'Open weights', count: rows.filter((row) => row.openSource).length },
  { key: 'closed', label: 'Closed / API', count: rows.filter((row) => !row.openSource).length },
];

const releaseOptions = [
  { key: '7', label: '7d' },
  { key: '30', label: '30d' },
  { key: '90', label: '90d' },
  { key: '365', label: '1y' },
  { key: 'all', label: 'all' },
];

const contextOptions = [
  { key: '32000', label: '>= 32K' },
  { key: '128000', label: '>= 128K' },
  { key: '1000000', label: '>= 1M' },
];

const viewCounts = {
  frontier: rows.length,
  cheapest: rows.filter((row) => row.blendedPrice > 0).length,
  fastest: rows.filter((row) => row.speed > 0).length,
  open: rows.filter((row) => row.openSource).length,
  value: rows.filter((row) => row.valueScore > 0).length,
};

const latestTimestamp = [
  ...dataPulse.map((item) => item.updatedAt),
  ...activities.map((item) => item.date),
  latestDigest ? normaliseDateTime(latestDigest.digestDate) : null,
]
  .filter((value): value is string => Boolean(value))
  .sort((a, b) => Date.parse(b) - Date.parse(a))[0] ?? null;

const nextRefreshLabel = latestTimestamp
  ? new Date(Date.parse(latestTimestamp) + 60 * 60 * 1000).toLocaleString('en-GB', {
    day: 'numeric',
    month: 'short',
    hour: '2-digit',
    minute: '2-digit',
    timeZoneName: 'short',
  })
  : 'next scheduled hourly run';

const tickerItems = [
  ...activities.slice(0, 8).map((entry) => ({
    time: formatRelativeTime(entry.date),
    label: entry.title,
    detail: entry.detail,
    href: entry.href ?? `${base}changelog/`,
    type: entry.category,
  })),
].slice(0, 10);

const duplicatedTickerItems = [...tickerItems, ...tickerItems];
const initialRows = rows.slice(0, 12);
const openRows = rows.filter((row) => row.openSource);
const speedRows = rows.filter((row) => row.speed > 0);
const fastestRows = [...speedRows].sort((a, b) => b.speed - a.speed || b.composite - a.composite);
const latestRows = rows.filter((row) => row.releasedDays !== null && row.releasedDays <= 30);
const dossierLeaderRows = rows.slice(0, 5);
const dossierWireItems = [...tickerItems, ...headlineNews.map((entry) => ({
  time: formatRelativeTime(entry.headlineDate),
  label: entry.title,
  detail: entry.source,
  href: entry.url,
  type: 'news',
}))].slice(0, 7);
const cheapestCredibleRows = [...rows]
  .filter((row) => row.composite >= 70 && row.blendedPrice > 0)
  .sort((a, b) => a.blendedPrice - b.blendedPrice || b.composite - a.composite)
  .slice(0, 4);
const monitorPriceRows = [...rows]
  .filter((row) => row.inputPrice > 0 || row.outputPrice > 0)
  .sort((a, b) => a.blendedPrice - b.blendedPrice || b.valueScore - a.valueScore)
  .slice(0, 5);
const monitorWatchRows = (() => {
  const seen = new Set<string>();
  return [
    ...rows.filter((row) => row.tags.includes('new')).slice(0, 2),
    ...rows.filter((row) => row.tags.includes('open')).slice(0, 2),
    ...rows.filter((row) => row.tags.includes('reasoning')).slice(0, 2),
  ].filter((row) => {
    if (seen.has(row.id)) return false;
    seen.add(row.id);
    return true;
  }).slice(0, 4);
})();
const topValue = [...rows].filter((row) => row.valueScore > 0).sort((a, b) => b.valueScore - a.valueScore)[0] ?? null;

const tableLinks = [
  { href: `${base}cheapest/`, label: 'Cheapest credible (>= 70)' },
  { href: `${base}fastest/`, label: 'Fastest by tokens/sec' },
  { href: `${base}open-source/`, label: 'Open weights only' },
  { href: `${base}multimodal/`, label: 'Multimodal' },
  { href: `${base}context-window/`, label: 'Longest context' },
  { href: `${base}reasoning/`, label: 'Reasoning models' },
];

---

<BaseLayout
  title="AI Resource Hub - Live Model Leaderboard, Pricing, Benchmarks, and AI News"
  description="A dense, hourly refreshed reference desk for AI models, prices, benchmark-backed rankings, releases, and live AI updates."
  compactChrome
>
  <div class="airh-home" data-airh-home>
    <!-- Single content tree for every display mode. It must NOT carry
         data-airh-layout-panel: BaseLayout's applyDisplayMode hides any panel
         whose attribute != active mode, which blanked the homepage in
         Dossier/Monitor/Terminal once the alternate panels were removed
         (KOL-4211 regression fix). Display modes restyle this via CSS. -->
    <section class="airh-home-content">
      <div class="airh-ticker" aria-label="Latest changes on the hub">
        <div class="airh-ticker-inner">
          <a href={`${base}updates/`} class="airh-ticker-stamp" data-airh-tip="Changes on the hub: releases, model rows, price data, source snapshots, and news. Refreshes hourly.">
            <span class="airh-pulse-dot"></span>
            <span>What's new</span>
          </a>
          <div class="airh-ticker-window">
            <div class="airh-ticker-stream">
              {duplicatedTickerItems.map((item) => (
                <a href={item.href} class="airh-ticker-item">
                  <span class="airh-ticker-time">{item.time}</span>
                  <strong>{item.label}</strong>
                  <span>{item.detail}</span>
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>

      <div class="airh-spreadsheet-wrap">
        <div class="airh-view-row">
          <div class="airh-view-tabs" role="tablist" aria-label="Meta benchmark leaderboards">
            {metaLanes.map((lane, index) => (
              <button
                type="button"
                class={`airh-view-tab${index === 0 ? ' is-active' : ''}`}
                role="tab"
                aria-selected={index === 0 ? 'true' : 'false'}
                data-airh-meta-lane={lane.id}
                data-airh-tip={lane.tip}
              >
                {lane.label} <span>{metaRanked.length}</span>
              </button>
            ))}
          </div>

          <span
            class="airh-refresh-stamp"
            id="airh-refresh-stamp"
            data-airh-tip={`Latest source snapshot: ${latestTimestamp ? formatDateLabel(latestTimestamp) : 'awaiting refresh'}. Next expected refresh: ${nextRefreshLabel}.`}
          >
            <span></span>
            Refreshed {formatRelativeTime(latestTimestamp)}
          </span>
        </div>

        <div class="airh-data-grid airh-meta-grid">
          <section class="airh-table-card" aria-labelledby="airh-meta-table-title">
            <div class="airh-table-card-head">
              <h1 id="airh-meta-table-title" data-airh-meta-title>Floor Capability - meta benchmark leaderboard</h1>
              <span class="airh-table-meta" data-airh-tip={`Internal meta benchmark: ${metaRanked.length} ranked models. ${metaPartialCount} partial-evidence rows live on the full hub until their sources fill in.`}>{metaRanked.length} ranked</span>
              <a class="airh-meta-method-link" href={`${base}benchmarks/meta/`} data-airh-tip="Method, lane weightings, full citations, and partial-evidence rows.">How these scores work &rarr;</a>
            </div>

            {metaLaneRows.map(({ lane, rows: laneRows }, laneIndex) => (
              <div class="airh-table-scroll" data-airh-meta-panel={lane.id} hidden={laneIndex !== 0}>
                <table class="airh-leaderboard-table compact">
                  <thead>
                    <tr>
                      <th data-airh-tip={`Rank inside the ${lane.label} leaderboard.`}>#</th>
                      <th data-airh-tip="Model detail page with full sources, score components, and operating metrics.">Model</th>
                      <th class="num" data-airh-tip="0-100 saturation scale. 100 means this lane is complete for the model: routine failures have effectively disappeared. If every model reaches 100, the lane is retired or made harder.">{lane.scoreLabel}</th>
                      <th class="num" data-airh-tip="DeepSWE (Datacurve): long-horizon agentic coding. Pass@1, average cost, average time, and output tokens where reported.">DSWE</th>
                      <th class="num" data-airh-tip="Evidence completeness behind the score - source coverage, not model quality.">Evidence %</th>
                    </tr>
                  </thead>
                  <tbody>
                    {laneRows.map((entry, index) => (
                      <tr>
                        <td class="rank">{index + 1}</td>
                        <td class="model-cell">
                          <a href={`${base}benchmarks/meta/${entry.modelId}/`}>
                            <span class="airh-provider-swatch" style={`background:${entry.providerColour}`}></span>
                            {entry.modelName}
                            <span>{entry.providerName}</span>
                          </a>
                        </td>
                        <td class="num score">
                          <span class="score-bar accent"><span style={`width:${scoreWidth(lane.scoreOf(entry))}`}></span></span>
                          <b>{lane.scoreOf(entry)}</b>
                          <button type="button" class="airh-conf-mark" data-airh-tip={`Confidence: ${entry.scoreConfidence}. ${CONFIDENCE_TIP}`} aria-label={`Score confidence for ${entry.modelName}: ${entry.scoreConfidence}`}>?</button>
                        </td>
                        <td class="num">
                          {entry.dsweMetrics
                            ? <a href={DEEPSWE_URL} target="_blank" rel="noopener" data-airh-tip="DeepSWE Pass@1, average cost, average time, output tokens. Opens DeepSWE.">{dsweCompact(entry)}</a>
                            : <span data-airh-tip="No DeepSWE row reported for this model yet.">pending</span>}
                        </td>
                        <td class="num">{entry.coverage}%</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            ))}

            <div class="airh-meta-guide" aria-label="How to read the meta benchmark leaderboard">
              <article>
                <strong>Score</strong>
                <p>0-100 saturation. 100 = the lane is complete for that model; a saturated lane gets retired or hardened.</p>
              </article>
              <article>
                <strong>Evidence %</strong>
                <p>Source coverage behind the score, not model quality.</p>
              </article>
              <article>
                <strong>DSWE</strong>
                <p>Agentic coding with cost, time, and output tokens, from <a href={DEEPSWE_URL} target="_blank" rel="noopener">DeepSWE</a>.</p>
              </article>
              <article>
                <strong>Confidence</strong>
                <p>Evidence strength, on the <span class="airh-conf-mark" data-airh-tip={CONFIDENCE_TIP}>?</span> beside each score. Never another model grade.</p>
              </article>
            </div>

            <div class="airh-table-foot">
              <span data-airh-meta-summary>{metaRanked.length} ranked models - sorted by Floor Capability</span>
              <a href={`${base}benchmarks/meta/`}>Open the full Meta Benchmark Hub &rarr;</a>
            </div>
          </section>
        </div>

        <section class="airh-bottom-strip" aria-label="More AI Resource Hub signals">
          <div class="airh-strip-card">
            <h2>Today on the hub</h2>
            <ul>
              <li><span>{latestRows.length}</span><a href={`${base}new/`}>models released in the last 30 days</a></li>
              <li><span>{dataPulse.length}</span><a href={`${base}updates/`}>freshness lanes reporting</a></li>
              <li><span>{digestEntries.length}</span><a href={`${base}news/`}>digest stories surfaced</a></li>
              <li><span>{headlineNews.length}</span><a href={`${base}news/`}>headline items captured</a></li>
            </ul>
          </div>

          <div class="airh-strip-card">
            <h2>Pulse - current table</h2>
            <p class="airh-pulse-row"><strong>{rows.length}</strong><span>ranked public LLM rows</span></p>
            <p class="airh-pulse-row"><strong>{openRows.length}</strong><span>open-weight rows</span></p>
            <p class="airh-pulse-row"><strong>{speedRows.length}</strong><span>rows with speed data</span></p>
            <p class="airh-strip-note">
              {topValue ? `Value leader: ${topValue.name}` : 'Value leaders appear when price data is present.'}
            </p>
          </div>

          <div class="airh-strip-card">
            <h2>More tables</h2>
            {tableLinks.map((link) => (
              <a href={link.href} class="airh-table-link">{link.label}<span>&rarr;</span></a>
            ))}
          </div>
        </section>
      </div>
    </section>

    <div class="airh-tip-card" data-airh-simple-tip role="tooltip" hidden></div>
  </div>


  <script is:inline>
    (() => {
      // Hover/focus tooltips for any [data-airh-tip] element on the page.
      // This is all that remains of the old homepage script: display modes
      // are owned by BaseLayout and restyle the SAME content via CSS, and the
      // leaderboard is fully server-rendered (KOL-4211).
      const simpleTip = document.querySelector('[data-airh-simple-tip]');
      if (!simpleTip) return;
      let timer = 0;
      let activeTarget = null;

      function escapeHtml(value) {
        return String(value).replace(/[&<>"']/g, (ch) => (
          { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[ch]
        ));
      }

      function placeTip(target, tip, width) {
        const rect = target.getBoundingClientRect();
        const tipHeight = tip.offsetHeight || 120;
        let left = rect.left;
        let top = rect.bottom + 8;
        if (left + width > window.innerWidth - 10) left = window.innerWidth - width - 10;
        if (top + tipHeight > window.innerHeight - 10) top = rect.top - tipHeight - 8;
        tip.style.left = `${Math.max(10, left)}px`;
        tip.style.top = `${Math.max(10, top)}px`;
      }

      function hideTip() {
        window.clearTimeout(timer);
        activeTarget = null;
        simpleTip.hidden = true;
        simpleTip.classList.remove('is-visible');
      }

      function showTip(target) {
        const text = target.getAttribute('data-airh-tip');
        if (!text) return;
        window.clearTimeout(timer);
        timer = window.setTimeout(() => {
          simpleTip.innerHTML = `<span>${escapeHtml(text)}</span>`;
          simpleTip.hidden = false;
          placeTip(target, simpleTip, 280);
          simpleTip.classList.add('is-visible');
        }, 220);
      }

      function handleIntent(event) {
        const target = event.target.closest?.('[data-airh-tip]');
        if (!target) return;
        if (activeTarget === target) return;
        if (activeTarget) hideTip();
        activeTarget = target;
        showTip(target);
      }

      document.body.addEventListener('mouseover', handleIntent);
      document.body.addEventListener('focusin', handleIntent);
      document.body.addEventListener('mouseout', (event) => {
        if (event.target.closest?.('[data-airh-tip]')) hideTip();
      });
      document.body.addEventListener('focusout', (event) => {
        if (event.target.closest?.('[data-airh-tip]')) hideTip();
      });
      window.addEventListener('scroll', hideTip, { passive: true });
      window.addEventListener('resize', hideTip);
    })();
  </script>

  <script is:inline>
    (() => {
      const laneButtons = Array.from(document.querySelectorAll('[data-airh-meta-lane]'));
      if (!laneButtons.length) return;
      const panels = Array.from(document.querySelectorAll('[data-airh-meta-panel]'));
      const title = document.querySelector('[data-airh-meta-title]');
      const summary = document.querySelector('[data-airh-meta-summary]');
      const rankedCount = panels.length
        ? panels[0].querySelectorAll('tbody tr').length
        : 0;

      laneButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const lane = button.getAttribute('data-airh-meta-lane');
          const label = button.textContent.replace(/\d+\s*$/, '').trim();
          laneButtons.forEach((other) => {
            const active = other === button;
            other.classList.toggle('is-active', active);
            other.setAttribute('aria-selected', String(active));
          });
          panels.forEach((panel) => {
            panel.hidden = panel.getAttribute('data-airh-meta-panel') !== lane;
          });
          if (title) title.textContent = `${label} - meta benchmark leaderboard`;
          if (summary) summary.textContent = `${rankedCount} ranked models - sorted by ${label}`;
        });
      });
    })();
  </script>

  <style>
    /* Meta benchmark leaderboard (KOL-4165): single-column grid now that the
       composite filter rail is gone, plus the confidence marker + quick guide. */
    .airh-meta-grid {
      grid-template-columns: 1fr;
    }

    .airh-meta-method-link {
      margin-left: auto;
      font-size: 0.78rem;
      white-space: nowrap;
      text-decoration: none;
    }

    .airh-meta-method-link:hover {
      text-decoration: underline;
    }

    .airh-conf-mark {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 15px;
      height: 15px;
      margin-left: 6px;
      padding: 0;
      border: 1px solid currentColor;
      border-radius: 50%;
      background: transparent;
      color: inherit;
      opacity: 0.55;
      font-size: 0.62rem;
      font-weight: 700;
      line-height: 1;
      cursor: help;
      vertical-align: middle;
    }

    .airh-conf-mark:hover,
    .airh-conf-mark:focus-visible {
      opacity: 1;
    }

    .airh-meta-guide {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 10px;
      padding: 10px 14px;
      border-top: 1px solid rgba(132, 115, 96, 0.25);
    }

    .airh-meta-guide article strong {
      display: block;
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      opacity: 0.75;
      margin-bottom: 2px;
    }

    .airh-meta-guide article p {
      margin: 0;
      font-size: 0.76rem;
      opacity: 0.85;
    }
  </style>
</BaseLayout>
