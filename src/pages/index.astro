---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import TopModelsPreview from '../components/TopModelsPreview.astro';
import {
  getBenchmarkMatrix,
  getLLMModelsFromDB,
  getModelsByCategory,
  getPeople,
  getProvidersWithCounts,
  getRecentModels,
  getYouTubeCreators,
} from '../db/queries';
import { loadNewsItems } from '../data/news-digests';

const llmModels = getLLMModelsFromDB();
const imageModels = getModelsByCategory('image');
const videoModels = getModelsByCategory('video');
const speechModels = getModelsByCategory('speech');
const voiceModels = getModelsByCategory('voice');
const soundModels = getModelsByCategory('sound');
const providers = getProvidersWithCounts();
const benchmarkMatrix = getBenchmarkMatrix();
const recentModels = getRecentModels(6);
const people = getPeople();
const youtubeCreators = getYouTubeCreators();
const latestNews = loadNewsItems().slice(0, 4);

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const lastUpdated = new Date().toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});

const totalTracked =
  llmModels.length +
  imageModels.length +
  videoModels.length +
  speechModels.length +
  voiceModels.length +
  soundModels.length;

const launchCards = [
  {
    title: 'Compare models properly',
    description: 'Start with pricing, context, speed, quality, and value on one surface instead of bouncing between provider pages.',
    href: `${base}compare/llm/`,
    meta: `${llmModels.length} LLMs tracked`,
  },
  {
    title: 'Read the market with context',
    description: 'Use the news stream, benchmark library, and provider view together so each headline has somewhere to land.',
    href: `${base}news/`,
    meta: latestNews[0] ? `Latest note dated ${latestNews[0].date}` : 'News desk ready',
  },
  {
    title: 'Use the built-in tools',
    description: 'Estimate spend, compare models head to head, and work out token costs without leaving the site.',
    href: `${base}tools/`,
    meta: 'Calculator, counter, and shortlists',
  },
];

const coreSections = [
  {
    title: 'LLM comparison',
    href: `${base}compare/llm/`,
    stat: `${llmModels.length} models`,
    note: 'Pricing, speed, context, quality, and value in one place.',
  },
  {
    title: 'Benchmarks',
    href: `${base}benchmarks/`,
    stat: `${benchmarkMatrix.benchmarks.length} tracked`,
    note: 'MMLU, GPQA, HumanEval, SWE-bench, and the rest of the useful scoreboard.',
  },
  {
    title: 'Labs and providers',
    href: `${base}labs/`,
    stat: `${providers.length} organisations`,
    note: 'See who is building what and how their models fit together.',
  },
  {
    title: 'AI news',
    href: `${base}news/`,
    stat: latestNews.length > 0 ? `${latestNews.length} fresh items` : 'Live feed',
    note: 'Launches, benchmarks, regulation, platform changes, and market movement.',
  },
  {
    title: 'Tools and calculators',
    href: `${base}tools/`,
    stat: 'Built in',
    note: 'Pricing calculator, token counter, and quick routes into the practical stuff.',
  },
  {
    title: 'Guides and glossary',
    href: `${base}guides/`,
    stat: `${people.length + youtubeCreators.length} references`,
    note: 'Learning paths, key people, and plain-English explanations for the jargon.',
  },
];

const fieldNotes = [
  { value: totalTracked, label: 'Models tracked across text, image, video, speech, voice, and sound' },
  { value: benchmarkMatrix.models.length, label: 'Models linked to benchmark coverage and comparison tooling' },
  { value: providers.length, label: 'Labs and providers represented in the database' },
  { value: `${people.length}/${youtubeCreators.length}`, label: 'People and creators available in the learning layer' },
];
---

<BaseLayout title="The AI Resource Hub - Independent AI Comparison and News">
  <HeroSection modelCount={llmModels.length} lastUpdated={lastUpdated} />

  <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="editorial-band">
      <div>
        <p class="section-kicker">Why this homepage exists</p>
        <h2 class="section-heading max-w-2xl">Three clear routes into the hub, depending on whether you need answers, context, or working tools.</h2>
      </div>
      <div class="editorial-grid mt-8">
        {launchCards.map((card, index) => (
          <a href={card.href} class={`entry-card entry-card-${index + 1}`}>
            <span class="entry-card-number">{String(index + 1).padStart(2, '0')}</span>
            <div>
              <h3 class="entry-card-title">{card.title}</h3>
              <p class="entry-card-copy">{card.description}</p>
              <p class="entry-card-meta">{card.meta}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[minmax(0,1.05fr)_minmax(320px,0.95fr)]">
      <div class="paper-panel paper-panel-large">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="section-kicker">Reference board</p>
            <h2 class="section-heading">The part of the site that behaves like a working desk, not a brochure.</h2>
          </div>
          <a href={`${base}about/`} class="editorial-link">How the hub works</a>
        </div>

        <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
          {coreSections.map((section, index) => (
            <a href={section.href} class={`coverage-card coverage-card-${(index % 3) + 1}`}>
              <p class="coverage-card-stat">{section.stat}</p>
              <h3 class="coverage-card-title">{section.title}</h3>
              <p class="coverage-card-copy">{section.note}</p>
            </a>
          ))}
        </div>
      </div>

      <div class="stacked-aside">
        <div class="paper-panel">
          <p class="section-kicker">Field notes</p>
          <h2 class="section-heading section-heading-compact">The coverage footprint at a glance.</h2>
          <div class="mt-6 space-y-4">
            {fieldNotes.map((note) => (
              <div class="note-row">
                <span class="note-value">{note.value}</span>
                <p class="note-copy">{note.label}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="paper-panel note-manifesto">
          <p class="section-kicker">Editorial stance</p>
          <p class="manifesto-copy">
            This is built for readers who want independent signal, not just launch-day excitement. The goal is to
            make the AI landscape easier to compare, easier to read, and easier to revisit.
          </p>
        </div>
      </div>
    </div>
  </section>

  <TopModelsPreview models={llmModels} />

  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[minmax(0,1.1fr)_minmax(320px,0.9fr)]">
      <div class="paper-panel paper-panel-large">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="section-kicker">Signal board</p>
            <h2 class="section-heading">News worth reading, styled like a desk of clipped notes instead of a generic feed.</h2>
          </div>
          <a href={`${base}news/`} class="editorial-link">Open the full news desk</a>
        </div>

        <div class="mt-8 space-y-4">
          {latestNews.length > 0 ? latestNews.map((item, index) => (
            <a href={item.url} target="_blank" rel="noopener noreferrer" class={`headline-strip headline-strip-${(index % 3) + 1}`}>
              <div class="headline-strip-meta">
                <span>{item.source}</span>
                <span>/</span>
                <span>{item.date}</span>
                <span>/</span>
                <span>{item.category}</span>
              </div>
              <h3 class="headline-strip-title">{item.title}</h3>
              {item.summary && <p class="headline-strip-copy">{item.summary}</p>}
            </a>
          )) : (
            <div class="empty-surface">
              The news surface is wired, but no current items are loaded yet.
            </div>
          )}
        </div>
      </div>

      <div class="stacked-aside">
        <div class="paper-panel">
          <p class="section-kicker">Fresh entries</p>
          <h2 class="section-heading section-heading-compact">Recently added to the database.</h2>
          <div class="mt-6 space-y-3">
            {recentModels.map((model) => (
              <a href={`${base}models/${model.id}/`} class="recent-model-row">
                <div>
                  <div class="flex items-center gap-2">
                    <span class="model-dot" style={`background-color: ${model.providerColour}`}></span>
                    <p class="text-sm font-semibold text-(--color-text-primary)">{model.name}</p>
                  </div>
                  <p class="mt-1 text-xs uppercase tracking-[0.18em] text-(--color-text-muted)">{model.provider}</p>
                </div>
                <span class="recent-model-score">{model.qualityScore}/100</span>
              </a>
            ))}
          </div>
        </div>

        <div class="paper-panel">
          <p class="section-kicker">Useful starting points</p>
          <div class="mt-5 space-y-3">
            <a href={`${base}leaderboard/`} class="aside-link">Leaderboard</a>
            <a href={`${base}calculator/`} class="aside-link">Pricing calculator</a>
            <a href={`${base}compare/head-to-head/`} class="aside-link">Head-to-head comparison</a>
            <a href={`${base}methodology/`} class="aside-link">Methodology and sources</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <NewsletterSignup variant="card" />

  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'The AI Resource Hub',
      url: new URL(base, Astro.site).toString(),
      description: 'Independent AI model comparison for pricing, benchmarks, tools, and live news.',
      potentialAction: {
        '@type': 'SearchAction',
        target: `${new URL(base, Astro.site).toString()}?q={search_term_string}`,
        'query-input': 'required name=search_term_string',
      },
    })}
  />
</BaseLayout>
