---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import TopModelsPreview from '../components/TopModelsPreview.astro';
import {
  getBenchmarkMatrix,
  getLLMModelsFromDB,
  getModelsByCategory,
  getPeople,
  getProvidersWithCounts,
  getRecentModels,
  getYouTubeCreators,
} from '../db/queries';
import { loadNewsItems } from '../data/news-digests';

const llmModels = getLLMModelsFromDB();
const imageModels = getModelsByCategory('image');
const videoModels = getModelsByCategory('video');
const speechModels = getModelsByCategory('speech');
const voiceModels = getModelsByCategory('voice');
const soundModels = getModelsByCategory('sound');
const providers = getProvidersWithCounts();
const benchmarkMatrix = getBenchmarkMatrix();
const recentModels = getRecentModels(6);
const people = getPeople();
const youtubeCreators = getYouTubeCreators();
const latestNews = loadNewsItems().slice(0, 4);

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const lastUpdated = new Date().toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});

const launchCards = [
  {
    title: 'Compare models properly',
    description: 'Start with pricing, context, speed, quality, and value on one surface instead of jumping between provider docs.',
    href: `${base}compare/llm/`,
    meta: `${llmModels.length} LLMs tracked`,
  },
  {
    title: 'Follow the market, not just the hype',
    description: 'Use the news stream, benchmark library, and provider context together so the headlines are easier to interpret.',
    href: `${base}news/`,
    meta: latestNews[0] ? `Latest item dated ${latestNews[0].date}` : 'News feed ready',
  },
  {
    title: 'Use the built-in tools',
    description: 'Estimate API spend, compare head to head, and check token costs without leaving the site.',
    href: `${base}tools/`,
    meta: 'Launch-ready working surfaces',
  },
];

const coreSections = [
  { title: 'LLM comparison', href: `${base}compare/llm/`, stat: `${llmModels.length} models`, note: 'Pricing, speed, context, quality, value' },
  { title: 'Benchmarks', href: `${base}benchmarks/`, stat: `${benchmarkMatrix.benchmarks.length} tracked`, note: 'MMLU, GPQA, HumanEval, SWE-bench, and more' },
  { title: 'Labs & providers', href: `${base}labs/`, stat: `${providers.length} organisations`, note: 'Who is building what, and where it fits' },
  { title: 'AI news', href: `${base}news/`, stat: `${latestNews.length > 0 ? latestNews.length : 'Live'} items`, note: 'Public-feed collection with archive fallback' },
  { title: 'Tool guide', href: `${base}tools/`, stat: 'Internal + external', note: 'Built-in calculators plus curated tools' },
  { title: 'Guides & glossary', href: `${base}guides/`, stat: `${people.length} people and ${youtubeCreators.length} creators`, note: 'Plain-English learning paths and references' },
];

const totalTracked =
  llmModels.length +
  imageModels.length +
  videoModels.length +
  speechModels.length +
  voiceModels.length +
  soundModels.length;
---

<BaseLayout title="The AI Resource Hub - Independent AI Comparison and News">
  <HeroSection modelCount={llmModels.length} lastUpdated={lastUpdated} />

  <TopModelsPreview models={llmModels} />

  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-4 lg:grid-cols-3">
      {launchCards.map((card) => (
        <a
          href={card.href}
          class="rounded-[1.75rem] border border-(--color-border) bg-(--color-bg-secondary) p-6 transition-colors hover:border-(--color-border-hover) hover:bg-(--color-bg-tertiary)"
        >
          <p class="text-[11px] font-semibold uppercase tracking-[0.28em] text-(--color-text-muted)">Start here</p>
          <h2 class="mt-4 text-2xl font-bold font-display text-(--color-text-primary)">{card.title}</h2>
          <p class="mt-3 text-sm leading-6 text-(--color-text-secondary)">{card.description}</p>
          <p class="mt-5 text-xs font-medium text-(--color-accent)">{card.meta}</p>
        </a>
      ))}
    </div>
  </section>

  <section id="categories" class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-[11px] font-semibold uppercase tracking-[0.28em] text-(--color-text-muted)">Core coverage</p>
        <h2 class="mt-2 text-3xl font-black font-display text-(--color-text-primary)">The parts of the site you will actually use first.</h2>
      </div>
      <a href={`${base}about/`} class="text-sm font-medium text-(--color-accent) hover:text-(--color-accent-hover)">
        How the hub works
      </a>
    </div>

    <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {coreSections.map((section) => (
        <a
          href={section.href}
          class="rounded-[1.5rem] border border-(--color-border) bg-(--color-bg-card) p-5 transition-colors hover:border-(--color-border-hover) hover:bg-(--color-bg-hover)"
        >
          <div class="flex items-center justify-between gap-4">
            <h3 class="text-lg font-semibold text-(--color-text-primary)">{section.title}</h3>
            <span class="text-xs font-medium text-(--color-accent)">{section.stat}</span>
          </div>
          <p class="mt-3 text-sm leading-6 text-(--color-text-secondary)">{section.note}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
      <div class="rounded-[2rem] border border-(--color-border) bg-(--color-bg-secondary) p-6 sm:p-8">
        <div class="flex items-center justify-between gap-4">
          <div>
            <p class="text-[11px] font-semibold uppercase tracking-[0.28em] text-(--color-text-muted)">Latest signal</p>
            <h2 class="mt-2 text-2xl font-bold font-display text-(--color-text-primary)">News worth checking</h2>
          </div>
          <a href={`${base}news/`} class="text-sm font-medium text-(--color-accent) hover:text-(--color-accent-hover)">Open news</a>
        </div>

        <div class="mt-6 space-y-4">
          {latestNews.length > 0 ? latestNews.map((item) => (
            <a href={item.url} target="_blank" rel="noopener noreferrer" class="block rounded-2xl border border-(--color-border) bg-(--color-bg-primary)/60 p-4 transition-colors hover:border-(--color-border-hover) hover:bg-(--color-bg-tertiary)">
              <div class="flex items-center gap-3 text-xs text-(--color-text-muted)">
                <span>{item.source}</span>
                <span>•</span>
                <span>{item.date}</span>
                <span class="rounded-full border border-(--color-border) px-2 py-0.5">{item.category}</span>
              </div>
              <h3 class="mt-3 text-base font-semibold text-(--color-text-primary)">{item.title}</h3>
              {item.summary && <p class="mt-2 text-sm leading-6 text-(--color-text-secondary)">{item.summary}</p>}
            </a>
          )) : (
            <div class="rounded-2xl border border-dashed border-(--color-border) p-5 text-sm text-(--color-text-secondary)">
              The news surface is ready, but no items are loaded yet.
            </div>
          )}
        </div>
      </div>

      <div class="space-y-6">
        <div class="rounded-[2rem] border border-(--color-border) bg-(--color-bg-secondary) p-6 sm:p-8">
          <p class="text-[11px] font-semibold uppercase tracking-[0.28em] text-(--color-text-muted)">Recently added</p>
          <h2 class="mt-2 text-2xl font-bold font-display text-(--color-text-primary)">Fresh entries in the database</h2>
          <div class="mt-6 space-y-3">
            {recentModels.map((model) => (
              <a href={`${base}models/${model.id}/`} class="flex items-start justify-between gap-4 rounded-2xl border border-(--color-border) bg-(--color-bg-primary)/60 p-4 transition-colors hover:border-(--color-border-hover) hover:bg-(--color-bg-tertiary)">
                <div>
                  <div class="flex items-center gap-2">
                    <span class="h-2 w-2 rounded-full" style={`background-color: ${model.providerColour}`}></span>
                    <p class="text-sm font-semibold text-(--color-text-primary)">{model.name}</p>
                  </div>
                  <p class="mt-1 text-xs text-(--color-text-muted)">{model.provider}</p>
                </div>
                <span class="text-xs font-medium text-(--color-accent)">{model.qualityScore}/100</span>
              </a>
            ))}
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="rounded-[1.5rem] border border-(--color-border) bg-(--color-bg-secondary) p-5">
            <p class="text-3xl font-black font-display text-(--color-text-primary)">{totalTracked}</p>
            <p class="mt-2 text-sm text-(--color-text-secondary)">Models tracked across text, image, video, speech, voice, and sound.</p>
          </div>
          <div class="rounded-[1.5rem] border border-(--color-border) bg-(--color-bg-secondary) p-5">
            <p class="text-3xl font-black font-display text-(--color-text-primary)">{benchmarkMatrix.models.length}</p>
            <p class="mt-2 text-sm text-(--color-text-secondary)">Models connected to benchmark coverage and comparison tooling.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <NewsletterSignup variant="card" />

  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'The AI Resource Hub',
    url: new URL(base, Astro.site).toString(),
    description: 'Independent AI model comparison for pricing, benchmarks, tools, and live news.',
    potentialAction: {
      '@type': 'SearchAction',
      target: `${new URL(base, Astro.site).toString()}?q={search_term_string}`,
      'query-input': 'required name=search_term_string',
    },
  })} />
</BaseLayout>
