---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SyntheticMethodologyNote from '../../components/leaderboards/SyntheticMethodologyNote.astro';
import { getSyntheticLeaderboardView } from '../../data/synthetic-leaderboards';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const view = getSyntheticLeaderboardView('reasoning', 250);
const ranked = view.rankedEntries;
const tracking = [...view.partialEntries, ...view.trackingEntries].slice(0, 12);
const benchmarkNames = Object.fromEntries(view.benchmarkRegistry.map((benchmark) => [benchmark.id, benchmark.name]));
const dedicatedReasoning = ranked.filter((model) => /o\d|reason|think|deepseek r1/i.test(model.name) || /reason/i.test(model.notes ?? '')).slice(0, 6);
---

<BaseLayout title="AI Reasoning Models - The AI Resource Hub" description="Benchmark-backed reasoning leaderboard with explicit evidence thresholds.">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    <nav class="text-xs text-(--color-text-muted) mb-4" aria-label="Breadcrumb">
      <a href={base} class="hover:text-(--color-text-secondary) transition-colors">Home</a>
      <span class="mx-2">/</span>
      <a href={`${base}leaderboard/`} class="hover:text-(--color-text-secondary) transition-colors">Leaderboard</a>
      <span class="mx-2">/</span>
      <span class="text-(--color-text-secondary)">Reasoning Models</span>
    </nav>

    <div class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-extrabold text-(--color-text-primary) mb-3">AI Reasoning Models</h1>
      <p class="text-(--color-text-secondary) max-w-3xl">This page now ranks reasoning models only when they have enough reasoning-specific benchmark evidence. Thin or missing reasoning coverage stays visible, but unranked.</p>
    </div>

    <SyntheticMethodologyNote body="Synthetic ranking. Requires 4+ relevant reasoning benchmark rows to rank. Models with fewer rows stay in tracking rather than inheriting a generic reasoning crown." />

    {dedicatedReasoning.length > 0 && <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3 my-8">{dedicatedReasoning.map((model) => <a href={`${base}models/${model.id}/`} class="p-4 rounded-xl bg-(--color-bg-card) border border-(--color-border) hover:border-(--color-accent)/30 transition-colors group"><div class="flex items-center gap-2 mb-2"><span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${model.providerColour}`}></span><h3 class="font-medium text-(--color-text-primary) group-hover:text-(--color-accent) transition-colors text-sm">{model.name}</h3></div><p class="text-xs text-(--color-text-muted)">{model.provider}</p><p class="mt-2 text-sm text-(--color-accent)">{model.score?.toFixed(1)} reasoning score</p></a>)}</div>}

    <div class="mb-10 rounded-xl border border-(--color-border) bg-(--color-bg-card) overflow-x-auto">
      <table class="w-full text-sm">
        <thead><tr class="border-b border-(--color-border)"><th class="text-center py-3 px-2 text-(--color-text-muted) font-medium w-10">#</th><th class="text-left py-3 px-4 text-(--color-text-muted) font-medium">Model</th><th class="text-right py-3 px-4 text-(--color-text-muted) font-medium">Reasoning score</th>{Object.values(benchmarkNames).slice(0, 4).map((name) => <th class="text-right py-3 px-4 text-(--color-text-muted) font-medium text-xs hidden xl:table-cell">{name}</th>)}<th class="text-right py-3 px-4 text-(--color-text-muted) font-medium hidden sm:table-cell">Evidence</th></tr></thead>
        <tbody>{ranked.map((model, index) => <tr class={`border-b border-(--color-border)/50 hover:bg-(--color-bg-hover) transition-colors ${index < 3 ? 'bg-(--color-accent)/5' : ''}`}><td class="py-3 px-2 text-center text-sm font-bold text-(--color-text-muted)">{index + 1}</td><td class="py-3 px-4"><a href={`${base}models/${model.id}/`} class="flex items-center gap-2 text-(--color-text-primary) hover:text-(--color-accent) transition-colors"><span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${model.providerColour}`}></span><span class="font-medium">{model.name}</span></a><p class="text-[10px] text-(--color-text-muted)">{model.provider}</p></td><td class="py-3 px-4 text-right font-mono font-medium text-(--color-accent)">{model.score?.toFixed(1)}</td>{Object.keys(benchmarkNames).slice(0, 4).map((benchmarkId) => { const benchmark = model.relevantBenchmarks.find((item) => item.id === benchmarkId); return <td class="py-3 px-4 text-right text-xs font-mono hidden xl:table-cell">{benchmark?.score !== null && benchmark?.score !== undefined ? benchmark.score.toFixed(1) : 'Ś'}</td>; })}<td class="py-3 px-4 text-right hidden sm:table-cell text-xs text-(--color-text-muted)">{model.relevantBenchmarkCount} rows</td></tr>)}</tbody>
      </table>
    </div>

    {tracking.length > 0 && <div class="mb-8"><h2 class="text-xl font-bold text-(--color-text-primary) mb-4">Tracking / insufficient evidence</h2><div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">{tracking.map((model) => <a href={`${base}models/${model.id}/`} class="p-4 rounded-xl bg-(--color-bg-card) border border-(--color-border) hover:border-(--color-accent)/30 transition-colors group"><div class="flex items-center gap-2 mb-2"><span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${model.providerColour}`}></span><h3 class="font-medium text-(--color-text-primary) group-hover:text-(--color-accent) transition-colors text-sm">{model.name}</h3></div><p class="text-xs text-(--color-text-muted)">{model.provider}</p><p class="mt-2 text-[10px] uppercase tracking-[0.16em] text-(--color-accent)">{model.evidenceTier}</p><p class="mt-1 text-xs text-(--color-text-muted)">{model.reasonIfNotEligible}</p></a>)}</div></div>}
  </section>
</BaseLayout>
