---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SyntheticMethodologyNote from '../../components/leaderboards/SyntheticMethodologyNote.astro';
import { getSyntheticLeaderboardView } from '../../data/synthetic-leaderboards';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const view = getSyntheticLeaderboardView('best-value', 250);
const ranked = view.rankedEntries;
const tracking = [...view.partialEntries, ...view.trackingEntries].slice(0, 12);
const leader = ranked[0] ?? null;
const bestOpen = ranked.find((model) => model.openSource) ?? null;

function formatTokens(n: number): string {
  if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(n % 1_000_000 === 0 ? 0 : 1)}M`;
  if (n >= 1_000) return `${(n / 1_000).toFixed(n % 1_000 === 0 ? 0 : 1)}K`;
  return n.toString();
}
---

<BaseLayout title="Best Value AI Models - The AI Resource Hub" description="Benchmark-backed value ranking for AI models with enough evidence to compare fairly.">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    <nav class="text-xs text-(--color-text-muted) mb-4" aria-label="Breadcrumb">
      <a href={base} class="hover:text-(--color-text-secondary) transition-colors">Home</a>
      <span class="mx-2">/</span>
      <a href={`${base}leaderboard/`} class="hover:text-(--color-text-secondary) transition-colors">Leaderboard</a>
      <span class="mx-2">/</span>
      <span class="text-(--color-text-secondary)">Best Value</span>
    </nav>

    <div class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-extrabold text-(--color-text-primary) mb-3">Best Value AI Models</h1>
      <p class="text-(--color-text-secondary) max-w-3xl">This is now a synthetic value ranking built only from models with enough benchmark evidence to compare fairly. Models without enough public evidence stay in tracking instead of being silently promoted by a fallback quality score.</p>
    </div>

    <SyntheticMethodologyNote body="Synthetic ranking. Requires 4+ relevant benchmark rows and a public price to rank. Models with thinner evidence or no comparable price stay in tracking." />

    <div class="grid gap-3 sm:grid-cols-3 my-8">
      <div class="p-4 rounded-xl bg-(--color-bg-card) border border-(--color-border)"><p class="text-2xl font-bold text-(--color-accent)">{ranked.length}</p><p class="text-xs text-(--color-text-muted)">Ranked models</p></div>
      <div class="p-4 rounded-xl bg-(--color-bg-card) border border-(--color-border)"><p class="text-2xl font-bold text-(--color-text-primary)">{tracking.length}</p><p class="text-xs text-(--color-text-muted)">Tracking / insufficient evidence</p></div>
      <div class="p-4 rounded-xl bg-(--color-bg-card) border border-(--color-border)"><p class="text-2xl font-bold text-green-400">{view.modelsWithEvidence}</p><p class="text-xs text-(--color-text-muted)">Models with evidence</p></div>
    </div>

    {(leader || bestOpen) && <div class="grid gap-3 sm:grid-cols-2 mb-8">{leader && <a href={`${base}models/${leader.id}/`} class="p-4 rounded-xl bg-(--color-bg-card) border border-(--color-border) hover:border-(--color-accent)/30 transition-colors group"><p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-(--color-accent)">Top value pick</p><div class="mt-2 flex items-center gap-2"><span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${leader.providerColour}`}></span><h2 class="font-semibold text-(--color-text-primary) group-hover:text-(--color-accent) transition-colors">{leader.name}</h2></div><p class="mt-2 text-sm text-(--color-text-secondary)">{leader.provider} with a value index of {leader.score?.toFixed(1)}.</p></a>}{bestOpen && <a href={`${base}models/${bestOpen.id}/`} class="p-4 rounded-xl bg-(--color-bg-card) border border-(--color-border) hover:border-(--color-accent)/30 transition-colors group"><p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-(--color-accent)">Best open value</p><div class="mt-2 flex items-center gap-2"><span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${bestOpen.providerColour}`}></span><h2 class="font-semibold text-(--color-text-primary) group-hover:text-(--color-accent) transition-colors">{bestOpen.name}</h2></div><p class="mt-2 text-sm text-(--color-text-secondary)">Open-weight model with enough public evidence to enter the value ranking.</p></a>}</div>}

    <div class="mb-10 rounded-xl border border-(--color-border) bg-(--color-bg-card) overflow-hidden">
      <table class="w-full text-sm">
        <thead><tr class="border-b border-(--color-border)"><th class="text-center py-3 px-2 text-(--color-text-muted) font-medium w-10">#</th><th class="text-left py-3 px-4 text-(--color-text-muted) font-medium">Model</th><th class="text-right py-3 px-4 text-(--color-text-muted) font-medium">Value index</th><th class="text-right py-3 px-4 text-(--color-text-muted) font-medium hidden sm:table-cell">Composite</th><th class="text-right py-3 px-4 text-(--color-text-muted) font-medium hidden md:table-cell">Evidence</th><th class="text-right py-3 px-4 text-(--color-text-muted) font-medium">Price</th></tr></thead>
        <tbody>
          {ranked.map((model, index) => <tr class={`border-b border-(--color-border)/50 hover:bg-(--color-bg-hover) transition-colors ${index < 3 ? 'bg-(--color-accent)/5' : ''}`}><td class="py-3 px-2 text-center text-sm font-bold text-(--color-text-muted)">{index + 1}</td><td class="py-3 px-4"><a href={`${base}models/${model.id}/`} class="flex items-center gap-2 text-(--color-text-primary) hover:text-(--color-accent) transition-colors"><span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${model.providerColour}`}></span><span class="font-medium">{model.name}</span></a><p class="text-[10px] text-(--color-text-muted)">{model.provider} / {formatTokens(model.contextWindow)} context</p></td><td class="py-3 px-4 text-right font-mono font-medium text-green-400">{model.score?.toFixed(1)}</td><td class="py-3 px-4 text-right hidden sm:table-cell font-mono text-xs text-(--color-text-secondary)">{model.benchmarkScore.toFixed(1)}</td><td class="py-3 px-4 text-right hidden md:table-cell text-xs text-(--color-text-muted)">{model.relevantBenchmarkCount} rows</td><td class="py-3 px-4 text-right font-mono text-xs text-(--color-text-secondary)">{model.inputPrice > 0 || model.outputPrice > 0 ? `$${model.inputPrice.toFixed(2)} / $${model.outputPrice.toFixed(2)}` : 'Open / free'}</td></tr>)}
        </tbody>
      </table>
    </div>

    {tracking.length > 0 && <div class="mb-8"><h2 class="text-xl font-bold text-(--color-text-primary) mb-4">Tracking / insufficient evidence</h2><div class="rounded-xl border border-(--color-border) bg-(--color-bg-card) overflow-hidden"><table class="w-full text-sm"><thead><tr class="border-b border-(--color-border)"><th class="text-left py-3 px-4 text-(--color-text-muted) font-medium">Model</th><th class="text-left py-3 px-4 text-(--color-text-muted) font-medium">Evidence</th><th class="text-right py-3 px-4 text-(--color-text-muted) font-medium hidden md:table-cell">Freshness</th></tr></thead><tbody>{tracking.map((model) => <tr class="border-b border-(--color-border)/50"><td class="py-3 px-4"><a href={`${base}models/${model.id}/`} class="flex items-center gap-2 text-(--color-text-primary) hover:text-(--color-accent) transition-colors"><span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${model.providerColour}`}></span><span class="font-medium">{model.name}</span></a><p class="text-[10px] text-(--color-text-muted)">{model.provider}</p></td><td class="py-3 px-4 text-(--color-text-secondary)"><p class="text-xs uppercase tracking-[0.16em] text-(--color-accent)">{model.evidenceTier}</p><p class="mt-1 text-xs text-(--color-text-muted)">{model.reasonIfNotEligible}</p></td><td class="py-3 px-4 text-right hidden md:table-cell font-mono text-xs text-(--color-text-secondary)">{model.freshness.toFixed(0)}</td></tr>)}</tbody></table></div></div>}

    <div class="mt-6 flex flex-wrap justify-center gap-4"><a href={`${base}leaderboard/`} class="text-sm text-(--color-accent) hover:text-(--color-accent-hover) transition-colors">Leaderboard desk &rarr;</a><a href={`${base}open-source/`} class="text-sm text-(--color-accent) hover:text-(--color-accent-hover) transition-colors">Open source models &rarr;</a><a href={`${base}cheapest/`} class="text-sm text-(--color-accent) hover:text-(--color-accent-hover) transition-colors">Cheapest models &rarr;</a></div>
  </section>
</BaseLayout>
