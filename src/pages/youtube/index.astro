---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getYouTubeCreators } from '../../db/queries';
import {
  filterAIYouTubeCreators,
  getSafeYouTubeUrl,
  getYouTubeCategoryCounts,
  getYouTubeCategoryMeta,
} from '../../data/content-curation';

const creators = filterAIYouTubeCreators(getYouTubeCreators());
const categories = getYouTubeCategoryCounts(creators);
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

function formatSubs(n: number): string {
  if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(1)}M`;
  if (n >= 1_000) return `${(n / 1_000).toFixed(0)}K`;
  return n > 0 ? String(n) : 'Unlisted';
}
---

<BaseLayout
  title="AI YouTube Channels to Follow - The AI Resource Hub"
  description="Curated AI-focused YouTube channels covering news, research, tools, interviews, and practical workflows."
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    <nav class="text-xs text-(--color-text-muted) mb-4" aria-label="Breadcrumb">
      <a href={base} class="hover:text-(--color-text-secondary) transition-colors">Home</a>
      <span class="mx-2">/</span>
      <span class="text-(--color-text-secondary)">YouTube Channels</span>
    </nav>

    <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_280px] mb-8">
      <div>
        <h1 class="text-3xl sm:text-4xl font-extrabold text-(--color-text-primary) mb-3">
          AI YouTube Channels to Follow
        </h1>
        <p class="text-(--color-text-secondary) max-w-3xl">
          {creators.length} AI-focused channels covering research, agents, tooling, interviews, and weekly news.
          The photography and general-tech spillover has been stripped out here so this page stays tightly on-topic.
        </p>
      </div>

      <div class="rounded-2xl border border-(--color-border) bg-(--color-bg-card) p-5">
        <p class="text-xs uppercase tracking-[0.18em] text-(--color-text-muted)">Quick filters</p>
        <input
          id="creator-search"
          type="search"
          placeholder="Search channel or topic..."
          class="mt-3 w-full rounded-full border border-(--color-border) bg-(--color-bg-primary) px-4 py-3 text-sm text-(--color-text-primary) placeholder:text-(--color-text-muted) focus:outline-none focus:border-(--color-accent)"
        />
        <p class="mt-3 text-xs text-(--color-text-muted)">
          Filter by channel name, presenter, or description.
        </p>
      </div>
    </div>

    <div class="flex flex-wrap gap-2 mb-8">
      {categories.map((cat) => {
        const meta = getYouTubeCategoryMeta(cat.category);
        return (
          <a
            href={`#${cat.category}`}
            class={`text-xs px-3 py-1.5 rounded-full font-medium transition-colors ${meta.className}`}
          >
            {meta.label} ({cat.count})
          </a>
        );
      })}
    </div>

    <div class="space-y-10">
      {categories.map((cat) => {
        const meta = getYouTubeCategoryMeta(cat.category);
        const catCreators = creators.filter((creator) => creator.category === cat.category);
        return (
          <section id={cat.category} data-category-group>
            <div class="flex items-end justify-between gap-4 mb-4">
              <div>
                <h2 class="text-xl font-bold text-(--color-text-primary)">{meta.label}</h2>
                <p class="text-sm text-(--color-text-secondary) mt-1">
                  {cat.count} channel{cat.count === 1 ? '' : 's'} in this track
                </p>
              </div>
              <span class={`text-xs px-3 py-1.5 rounded-full font-medium ${meta.className}`}>
                {cat.count}
              </span>
            </div>

            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
              {catCreators.map((creator) => {
                const youtubeUrl = getSafeYouTubeUrl(creator);
                return (
                  <article
                    class="rounded-2xl border border-(--color-border) bg-(--color-bg-card) p-5 transition-colors hover:border-(--color-border-hover)"
                    data-creator-card
                    data-creator-filter={`${creator.channel_name} ${creator.name} ${creator.description ?? ''} ${meta.label}`.toLowerCase()}
                  >
                    <div class="flex items-start gap-3">
                      <div class="w-11 h-11 rounded-full bg-red-500/15 text-red-400 flex items-center justify-center shrink-0">
                        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                        </svg>
                      </div>

                      <div class="flex-1 min-w-0">
                        <div class="flex items-start justify-between gap-3">
                          <div>
                            <h3 class="font-semibold text-(--color-text-primary) leading-tight">{creator.channel_name}</h3>
                            <p class="text-xs text-(--color-text-muted) mt-1">
                              {creator.name}
                              {creator.youtube_handle && <span class="ml-1">{creator.youtube_handle}</span>}
                            </p>
                          </div>
                          <span class="text-xs font-mono text-(--color-accent) whitespace-nowrap">
                            {formatSubs(creator.subscribers)}
                          </span>
                        </div>

                        {creator.description && (
                          <p class="text-sm text-(--color-text-secondary) mt-3 line-clamp-3">
                            {creator.description}
                          </p>
                        )}

                        <div class="mt-4 flex items-center gap-3 flex-wrap">
                          {youtubeUrl && (
                            <a
                              href={youtubeUrl}
                              target="_blank"
                              rel="noopener noreferrer"
                              class="inline-flex items-center gap-1 text-xs text-red-400 hover:text-red-300 transition-colors"
                            >
                              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                              </svg>
                              Channel
                            </a>
                          )}
                          {creator.twitter && (
                            <a
                              href={`https://x.com/${creator.twitter.replace('@', '')}`}
                              target="_blank"
                              rel="noopener noreferrer"
                              class="inline-flex items-center gap-1 text-xs text-(--color-accent) hover:text-(--color-accent-hover) transition-colors"
                            >
                              {creator.twitter}
                            </a>
                          )}
                          <span class={`text-[11px] px-2 py-1 rounded-full font-medium ${meta.className}`}>
                            {meta.label}
                          </span>
                        </div>
                      </div>
                    </div>
                  </article>
                );
              })}
            </div>
          </section>
        );
      })}
    </div>
  </section>

  <script is:inline>
    (() => {
      const searchInput = document.getElementById('creator-search');
      const cards = Array.from(document.querySelectorAll('[data-creator-card]'));
      const groups = Array.from(document.querySelectorAll('[data-category-group]'));

      function updateFilter() {
        const query = (searchInput instanceof HTMLInputElement ? searchInput.value : '').toLowerCase().trim();

        for (const card of cards) {
          const haystack = card.getAttribute('data-creator-filter') || '';
          const matches = !query || haystack.includes(query);
          card.classList.toggle('hidden', !matches);
        }

        for (const group of groups) {
          const visibleCards = group.querySelectorAll('[data-creator-card]:not(.hidden)');
          group.classList.toggle('hidden', visibleCards.length === 0);
        }
      }

      searchInput?.addEventListener('input', updateFilter);
    })();
  </script>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'AI YouTube Channels to Follow',
    description: `${creators.length} curated YouTube channels covering AI research, tools, news, and interviews.`,
    numberOfItems: creators.length,
    itemListElement: creators.slice(0, 20).map((creator, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      item: {
        '@type': 'Person',
        name: creator.name,
        url: getSafeYouTubeUrl(creator) ?? undefined,
      },
    })),
  })} />
</BaseLayout>
