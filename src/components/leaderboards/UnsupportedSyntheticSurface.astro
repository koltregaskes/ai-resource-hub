---
import type { SyntheticLeaderboardView } from '../../data/synthetic-leaderboards';

interface RelatedLink {
  href: string;
  label: string;
}

interface Props {
  base: string;
  title: string;
  description: string;
  view: SyntheticLeaderboardView;
  benchmarkBlurbs?: Record<string, string>;
  relatedLinks?: RelatedLink[];
}

const {
  base,
  title,
  description,
  view,
  benchmarkBlurbs = {},
  relatedLinks = [],
} = Astro.props;

function formatReleaseDate(value: string | null): string {
  if (!value) return 'Release date not mapped';
  return new Date(value).toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
  });
}
---

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
  <nav class="text-xs text-(--color-text-muted) mb-4" aria-label="Breadcrumb">
    <a href={base} class="hover:text-(--color-text-secondary) transition-colors">Home</a>
    <span class="mx-2">/</span>
    <a href={`${base}leaderboard/`} class="hover:text-(--color-text-secondary) transition-colors">Leaderboard</a>
    <span class="mx-2">/</span>
    <span class="text-(--color-text-secondary)">{title}</span>
  </nav>

  <div class="mb-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-(--color-text-primary) mb-3">{title}</h1>
    <p class="text-(--color-text-secondary) max-w-3xl">{description}</p>
  </div>

  <div class="rounded-xl border border-(--color-border-accent) bg-(--color-accent-glow) p-5 mb-8">
    <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-(--color-accent)">Tracking / insufficient evidence</p>
    <p class="mt-2 text-sm leading-6 text-(--color-text-secondary)">
      This page is intentionally not ranking models yet. We are tracking the benchmark set and current frontier models,
      but we do not have enough canonical benchmark coverage to produce an honest scored table.
    </p>
  </div>

  <div class="grid gap-3 sm:grid-cols-3 mb-8">
    <div class="p-4 rounded-xl bg-(--color-bg-card) border border-(--color-border)">
      <p class="text-2xl font-bold text-(--color-accent)">{view.benchmarkRegistry.length}</p>
      <p class="text-xs text-(--color-text-muted)">Benchmarks being watched</p>
    </div>
    <div class="p-4 rounded-xl bg-(--color-bg-card) border border-(--color-border)">
      <p class="text-2xl font-bold text-(--color-text-primary)">{view.publishedBenchmarkCount}</p>
      <p class="text-xs text-(--color-text-muted)">Published in registry</p>
    </div>
    <div class="p-4 rounded-xl bg-(--color-bg-card) border border-(--color-border)">
      <p class="text-2xl font-bold text-(--color-text-primary)">{view.trackingEntries.length}</p>
      <p class="text-xs text-(--color-text-muted)">Current models watched</p>
    </div>
  </div>

  <div class="mb-10 rounded-xl border border-(--color-border) bg-(--color-bg-card) overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-(--color-border)">
          <th class="text-left py-3 px-4 text-(--color-text-muted) font-medium">Benchmark</th>
          <th class="text-left py-3 px-4 text-(--color-text-muted) font-medium">Registry status</th>
          <th class="text-left py-3 px-4 text-(--color-text-muted) font-medium hidden md:table-cell">Notes</th>
        </tr>
      </thead>
      <tbody>
        {view.benchmarkRegistry.map((benchmark) => (
          <tr class="border-b border-(--color-border)/50 align-top">
            <td class="py-3 px-4">
              <p class="font-medium text-(--color-text-primary)">{benchmark.name}</p>
              <p class="text-[10px] text-(--color-text-muted)">{benchmark.id}</p>
            </td>
            <td class="py-3 px-4 text-(--color-text-secondary)">
              <span class={`inline-flex items-center rounded-full px-2 py-1 text-[10px] uppercase tracking-[0.18em] ${benchmark.registryState === 'published' ? 'bg-emerald-500/10 text-emerald-300' : 'bg-amber-500/10 text-amber-300'}`}>
                {benchmark.registryState === 'published' ? 'Published' : 'Tracked'}
              </span>
              <p class="mt-2 text-xs text-(--color-text-muted)">{benchmark.sourceStatus}</p>
            </td>
            <td class="py-3 px-4 text-xs text-(--color-text-muted) hidden md:table-cell">
              {benchmarkBlurbs[benchmark.id] ?? 'Benchmark description to be expanded as canonical coverage lands.'}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <div class="mb-10">
    <h2 class="text-xl font-bold text-(--color-text-primary) mb-4">Models we are watching</h2>
    <p class="text-sm text-(--color-text-secondary) max-w-3xl mb-4">
      These are current frontier or near-frontier models we expect to track once the benchmark and evidence layer is ready.
      They are shown here as a watchlist, not as ranked winners.
    </p>
    <div class="rounded-xl border border-(--color-border) bg-(--color-bg-card) overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-(--color-border)">
            <th class="text-left py-3 px-4 text-(--color-text-muted) font-medium">Model</th>
            <th class="text-left py-3 px-4 text-(--color-text-muted) font-medium">Evidence</th>
            <th class="text-left py-3 px-4 text-(--color-text-muted) font-medium hidden md:table-cell">Released</th>
            <th class="text-right py-3 px-4 text-(--color-text-muted) font-medium">Price</th>
          </tr>
        </thead>
        <tbody>
          {view.trackingEntries.map((model) => (
            <tr class="border-b border-(--color-border)/50">
              <td class="py-3 px-4">
                <a href={`${base}models/${model.id}/`} class="flex items-center gap-2 text-(--color-text-primary) hover:text-(--color-accent) transition-colors">
                  <span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${model.providerColour}`}></span>
                  <span class="font-medium">{model.name}</span>
                </a>
                <p class="text-[10px] text-(--color-text-muted)">{model.provider}</p>
              </td>
              <td class="py-3 px-4 text-(--color-text-secondary)">
                <p class="text-xs uppercase tracking-[0.16em] text-(--color-accent)">{model.evidenceTier}</p>
                <p class="mt-1 text-xs text-(--color-text-muted)">{model.reasonIfNotEligible}</p>
              </td>
              <td class="py-3 px-4 text-(--color-text-muted) hidden md:table-cell">{formatReleaseDate(model.released)}</td>
              <td class="py-3 px-4 text-right font-mono text-xs text-(--color-text-secondary)">
                {model.inputPrice > 0 || model.outputPrice > 0 ? `$${model.inputPrice.toFixed(2)} / $${model.outputPrice.toFixed(2)}` : (model.openSource ? 'Open / free' : 'Included')}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  {relatedLinks.length > 0 && (
    <div class="mt-6 flex flex-wrap justify-center gap-4">
      {relatedLinks.map((link) => (
        <a href={link.href} class="text-sm text-(--color-accent) hover:text-(--color-accent-hover) transition-colors">{link.label} &rarr;</a>
      ))}
    </div>
  )}
</section>
