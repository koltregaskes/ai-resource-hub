---
interface Props {
  modelCount: number;
  lastUpdated: string;
}

const { modelCount, lastUpdated } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

const deskRoutes = [
  {
    title: 'Comparison desk',
    href: `${base}compare/llm/`,
    note: 'Pricing, context, speed, and quality on one surface.',
  },
  {
    title: 'News desk',
    href: `${base}news/`,
    note: 'A daily read of launches, benchmarks, regulation, and market shifts.',
  },
  {
    title: 'Reference shelf',
    href: `${base}references/`,
    note: 'Sources, methodology, and traceability for the numbers on site.',
  },
];

const pulseItems = [
  `Updated ${lastUpdated}`,
  `${modelCount} LLMs tracked`,
  'Daily local refresh',
];
---

<section class="relative overflow-hidden border-b border-(--color-border-strong)">
  <div class="hero-ruling"></div>
  <div class="editorial-burst editorial-burst-left"></div>
  <div class="editorial-burst editorial-burst-right"></div>

  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,1.25fr)_minmax(320px,0.75fr)] lg:items-start">
      <div class="relative z-10 max-w-4xl">
        <div class="flex flex-wrap items-center gap-3">
          <span class="eyebrow-chip">Reference desk</span>
          <span class="hero-edition">Edition 01 / launch week</span>
        </div>

        <h1 class="mt-6 max-w-4xl text-5xl leading-[0.92] tracking-[-0.05em] text-(--color-text-primary) sm:text-6xl lg:text-[5.45rem]">
          The independent field guide to what AI can actually do.
        </h1>

        <p class="mt-6 max-w-2xl text-lg leading-8 text-(--color-text-secondary)">
          Built like a newsroom, organised like a reference book, and focused on one job:
          helping you compare models, read the market properly, and make better calls faster.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a href={`${base}compare/llm/`} class="editorial-button editorial-button-primary">
            Open model comparison
          </a>
          <a href={`${base}benchmarks/`} class="editorial-button editorial-button-secondary">
            Check benchmark coverage
          </a>
        </div>

        <div class="mt-10 grid gap-3 sm:grid-cols-3">
          {pulseItems.map((item) => (
            <div class="hero-pulse">
              <span>{item}</span>
            </div>
          ))}
        </div>
      </div>

      <aside class="hero-note-card">
        <p class="hero-note-label">How to use the hub</p>
        <div class="mt-5 space-y-3">
          {deskRoutes.map((route, index) => (
            <a href={route.href} class="hero-route">
              <span class="hero-route-index">{String(index + 1).padStart(2, '0')}</span>
              <div>
                <p class="text-base font-semibold text-(--color-text-primary)">{route.title}</p>
                <p class="mt-1 text-sm leading-6 text-(--color-text-secondary)">{route.note}</p>
              </div>
            </a>
          ))}
        </div>
        <div class="hero-note-footer">
          <span class="hero-note-tag">Independent</span>
          <span class="hero-note-tag">Readable</span>
          <span class="hero-note-tag">Updated daily</span>
        </div>
      </aside>
    </div>
  </div>
</section>
