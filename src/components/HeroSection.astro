---
interface Props {
  modelCount: number;
  lastUpdated: string;
}

const { modelCount, lastUpdated } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
---

<section class="relative overflow-hidden border-b border-white/6">
  <div class="hero-glow-bg">
    <div class="hero-glow-bg-orb"></div>
  </div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(190,242,100,0.09),transparent_28%),radial-gradient(circle_at_bottom_right,rgba(56,189,248,0.1),transparent_30%)]"></div>

  <div class="mx-auto grid min-h-[calc(100svh-4rem)] max-w-7xl items-center gap-12 px-4 py-14 sm:px-6 md:min-h-[calc(84svh-4rem)] lg:grid-cols-[minmax(0,1.15fr)_minmax(320px,0.85fr)] lg:px-8 lg:py-16">
    <div class="relative z-10 max-w-3xl">
      <p class="text-[11px] font-semibold uppercase tracking-[0.34em] text-(--color-text-muted)">
        Launch-ready AI reference
      </p>
      <h1 class="mt-5 text-5xl font-black leading-[0.98] tracking-tight text-(--color-text-primary) sm:text-6xl lg:text-7xl">
        Benchmarks, pricing, tools, and news
        <span class="mt-2 block text-gradient-vibrant">without the noise.</span>
      </h1>
      <p class="mt-6 max-w-2xl text-base leading-7 text-(--color-text-secondary) sm:text-lg">
        The AI Resource Hub is a working field guide for people trying to understand what is worth using,
        what is changing, and where the signal actually is.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href={`${base}compare/llm/`}
          class="inline-flex items-center justify-center rounded-full bg-(--color-text-primary) px-6 py-3 text-sm font-semibold text-(--color-bg-primary) transition-transform hover:-translate-y-0.5"
        >
          Start with model comparison
        </a>
        <a
          href={`${base}news/`}
          class="inline-flex items-center justify-center rounded-full border border-(--color-border) bg-(--color-bg-secondary)/70 px-6 py-3 text-sm font-semibold text-(--color-text-primary) transition-colors hover:border-(--color-border-hover) hover:bg-(--color-bg-tertiary)"
        >
          Read the latest news
        </a>
      </div>

      <div class="mt-8 flex flex-wrap gap-3 text-xs text-(--color-text-secondary)">
        <span class="rounded-full border border-(--color-border) px-3 py-1.5">Updated {lastUpdated}</span>
        <span class="rounded-full border border-(--color-border) px-3 py-1.5">{modelCount} LLMs tracked</span>
        <span class="rounded-full border border-(--color-border) px-3 py-1.5">Daily local refresh</span>
      </div>
    </div>

    <aside class="relative z-10 rounded-[2rem] border border-(--color-border) bg-(--color-bg-secondary)/85 p-6 shadow-[0_30px_90px_rgba(0,0,0,0.25)] backdrop-blur-xl">
      <p class="text-[11px] font-semibold uppercase tracking-[0.28em] text-(--color-text-muted)">Start Here</p>
      <div class="mt-5 space-y-4">
        <a href={`${base}leaderboard/`} class="block rounded-2xl border border-(--color-border) bg-(--color-bg-primary)/70 p-4 transition-colors hover:border-(--color-border-hover) hover:bg-(--color-bg-tertiary)">
          <p class="text-sm font-semibold text-(--color-text-primary)">Leaderboard</p>
          <p class="mt-1 text-sm text-(--color-text-secondary)">See the strongest models across quality, value, and speed.</p>
        </a>
        <a href={`${base}calculator/`} class="block rounded-2xl border border-(--color-border) bg-(--color-bg-primary)/70 p-4 transition-colors hover:border-(--color-border-hover) hover:bg-(--color-bg-tertiary)">
          <p class="text-sm font-semibold text-(--color-text-primary)">Pricing Calculator</p>
          <p class="mt-1 text-sm text-(--color-text-secondary)">Estimate API spend before you commit to a model or provider.</p>
        </a>
        <a href={`${base}references/`} class="block rounded-2xl border border-(--color-border) bg-(--color-bg-primary)/70 p-4 transition-colors hover:border-(--color-border-hover) hover:bg-(--color-bg-tertiary)">
          <p class="text-sm font-semibold text-(--color-text-primary)">References & Sources</p>
          <p class="mt-1 text-sm text-(--color-text-secondary)">Check where the data comes from and how often each source refreshes.</p>
        </a>
      </div>
    </aside>
  </div>
</section>
