---
interface Props {
  title: string;
  description: string;
  href: string;
  modelCount: number;
  icon: string;
  available: boolean;
  countLabel?: string;
}

const { title, description, href, modelCount, icon, available, countLabel = 'tracked' } = Astro.props;
---

<a
  href={available ? href : undefined}
  class:list={[
    'block p-6 rounded-2xl border transition-all duration-300 relative overflow-hidden group',
    available
      ? 'glass-panel glass-panel-hover cursor-pointer'
      : 'bg-(--color-bg-card)/30 border-(--color-border)/30 opacity-50 cursor-default backdrop-blur-sm',
  ]}
  aria-disabled={!available}
>
  <div class="flex items-start gap-4 relative z-10">
    <div class:list={[
      'w-12 h-12 rounded-xl flex items-center justify-center text-2xl shrink-0 transition-transform duration-300 group-hover:scale-110 group-hover:rotate-3 shadow-sm',
      available ? 'bg-gradient-to-br from-(--color-accent)/20 to-(--color-accent-hover)/5 border border-(--color-border-accent)' : 'bg-(--color-bg-tertiary)',
    ]}>
      {icon}
    </div>
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-1">
        <h3 class="text-lg font-bold font-display text-(--color-text-primary) group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-indigo-400 group-hover:to-cyan-400 transition-all duration-300">
          {title}
        </h3>
        {!available && (
          <span class="text-xs px-2 py-0.5 rounded-full bg-(--color-bg-tertiary) text-(--color-text-muted)">
            Coming soon
          </span>
        )}
      </div>
      <p class="text-sm text-(--color-text-secondary) mb-3 leading-relaxed">{description}</p>
      <div class="text-xs font-medium text-(--color-text-muted) group-hover:text-(--color-text-secondary) transition-colors">
        {available ? `${modelCount} ${countLabel}` : 'In development'}
      </div>
    </div>
    {available && (
      <svg class="w-5 h-5 text-(--color-text-muted) group-hover:text-(--color-accent) transition-colors shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    )}
  </div>
</a>
