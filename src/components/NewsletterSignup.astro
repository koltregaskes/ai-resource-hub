---
interface Props {
  variant?: 'inline' | 'card' | 'compact';
}

const { variant = 'card' } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
---

{variant === 'card' ? (
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="relative overflow-hidden rounded-[2rem] border border-(--color-border) bg-(--color-bg-secondary) p-8 sm:p-10">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(190,242,100,0.12),transparent_34%),radial-gradient(circle_at_bottom_right,rgba(56,189,248,0.12),transparent_36%)]"></div>
      <div class="relative z-10 max-w-3xl">
        <p class="text-[11px] font-semibold uppercase tracking-[0.28em] text-(--color-text-muted)">Newsletter On Hold</p>
        <h2 class="mt-3 text-3xl sm:text-4xl font-black font-display text-(--color-text-primary)">
          Follow the live site instead of a waiting list.
        </h2>
        <p class="mt-4 max-w-2xl text-(--color-text-secondary)">
          The newsletter will come back later. For launch, the site itself is the product:
          fresh model data, public news tracking, and an RSS feed you can use right now.
        </p>
        <div class="mt-6 flex flex-col sm:flex-row gap-3">
          <a
            href={`${base}news/`}
            class="inline-flex items-center justify-center rounded-full bg-(--color-text-primary) px-5 py-3 text-sm font-semibold text-(--color-bg-primary) transition-transform hover:-translate-y-0.5"
          >
            Read the latest news
          </a>
          <a
            href={`${base}rss.xml`}
            class="inline-flex items-center justify-center rounded-full border border-(--color-border) px-5 py-3 text-sm font-semibold text-(--color-text-primary) transition-colors hover:border-(--color-border-hover) hover:bg-(--color-bg-tertiary)"
          >
            Subscribe via RSS
          </a>
        </div>
      </div>
    </div>
  </section>
) : variant === 'inline' ? (
  <div class="rounded-2xl border border-(--color-border) bg-(--color-bg-secondary) p-4 text-sm text-(--color-text-secondary)">
    Newsletter is on hold. Use the <a href={`${base}news/`} class="text-(--color-accent) hover:text-(--color-accent-hover)">news page</a> or <a href={`${base}rss.xml`} class="text-(--color-accent) hover:text-(--color-accent-hover)">RSS feed</a> for updates.
  </div>
) : (
  <div class="text-xs text-(--color-text-muted)">
    Newsletter on hold. Follow <a href={`${base}rss.xml`} class="text-(--color-accent) hover:text-(--color-accent-hover)">RSS</a>.
  </div>
)}
